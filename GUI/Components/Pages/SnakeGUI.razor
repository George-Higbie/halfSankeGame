@page "/snake"
@rendermode InteractiveServer
@layout GUI.Components.Layout.EmptyLayout
@implements IDisposable
@using Blazor.Extensions
@using Blazor.Extensions.Canvas
@using Blazor.Extensions.Canvas.Canvas2D
@using System.Diagnostics
@using GUI.Components.Controllers
@using GUI.Components.Models
@using GUI.Components.Rendering
@using System.Linq
@inject IJSRuntime JsRuntime;
@inject GameController GameController
@inject GUI.Components.Controllers.NetworkController NetworkController

<PageTitle>Snake</PageTitle>

@* ── Sidebar Toggle(s) ── *@
@if (_splitScreen)
{
    <button class="sidebar-toggle sidebar-toggle-left" @onclick="(() => _p1SidebarOpen = !_p1SidebarOpen)">
        @(_p1SidebarOpen ? "✕" : "☰")
    </button>
    <button class="sidebar-toggle sidebar-toggle-right" @onclick="(() => _p2SidebarOpen = !_p2SidebarOpen)">
        @(_p2SidebarOpen ? "✕" : "☰")
    </button>
}
else
{
    <button class="sidebar-toggle sidebar-toggle-right" @onclick="(() => _sidebarOpen = !_sidebarOpen)">
        @(_sidebarOpen ? "✕" : "☰")
    </button>
}

@* ── P1 Sidebar (left in split, right in single) ── *@
<div class="snake-sidebar @(_splitScreen ? "snake-sidebar-left" : "") @((_splitScreen ? _p1SidebarOpen : _sidebarOpen) ? "open" : "")">
    <h2 style="margin:0 0 12px; font-size:1.1rem; letter-spacing:1px;">@(_splitScreen ? "PLAYER 1" : "SNAKE")</h2>

    <div class="field-group">
        <label>Server Host</label>
        <input value="@ServerHost" disabled />
    </div>
    <div class="field-group">
        <label>Game Port</label>
        <input type="number" value="@ServerPort" disabled />
    </div>
    <div class="field-group">
        <label>@(_splitScreen ? "P1 Name" : "Name")</label>
        <input id="p1NameInput" class="@(_p1MenuIndex == 0 ? "menu-focused" : "")" @bind="PlayerName" disabled="@(_p1Playing)" />
    </div>

    <div class="skin-section" style="margin-top:6px; padding:4px;">
        <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.5px;opacity:0.6;margin-bottom:4px;">@(_splitScreen ? "P1 Skin" : "Skin")</label>
        <div class="skin-grid">
            <SkinGrid SelectedIndex="_p1SkinIndex"
                      KeyboardFocusIndex="@(_p1MenuIndex == 1 ? _p1SkinIndex : -1)"
                      OnSkinSelected="((idx) => _p1SkinIndex = idx)"
                      IdPrefix="p1" />
        </div>
        <div class="skin-preview-bar">
            <BECanvas Width="160" Height="40" @ref="_p1PreviewRef"></BECanvas>
            <span style="font-size:0.72rem;opacity:0.6;">@SnakeSkin.AllSkins[_p1SkinIndex].Name</span>
        </div>
    </div>

    <button class="btn-snake @(_p1MenuIndex == 2 ? "menu-focused" : "")" style="width:100%; margin-top:8px;" @onclick="(() => Connect())">@(_splitScreen ? "Connect P1" : "Connect")</button>

    <div class="status-line">@_status @if (_status == "Disconnected" || _status == "Game Over") { <span style="opacity:0.5; font-size:0.85em;">— @(_splitScreen ? "Left Shift" : "Shift") to start</span> }</div>

    <div style="margin-top:12px; border-top:1px solid rgba(255,255,255,0.1); padding-top:10px;">
        <label class="toggle @(_p1MenuIndex == 3 ? "menu-focused" : "")"><input type="checkbox" @bind="_highQualityTextures" /> High Quality</label>
        <label class="toggle @(_p1MenuIndex == 4 ? "menu-focused" : "")"><input type="checkbox" @bind="_drawGrid" /> Grid Overlay</label>
        <label class="toggle @(_p1MenuIndex == 5 ? "menu-focused" : "")"><input type="checkbox" @bind="_showScoreboard" /> Scoreboard</label>
        <label class="toggle @(_p1MenuIndex == 6 ? "menu-focused" : "")"><input type="checkbox" @bind="_splitScreen" /> Split Screen (2P)</label>
    </div>
</div>

@* ── P2 Sidebar (right side, split screen only) ── *@
@if (_splitScreen)
{
<div class="snake-sidebar @(_p2SidebarOpen ? "open" : "")">
    <h2 style="margin:0 0 12px; font-size:1.1rem; letter-spacing:1px;">PLAYER 2</h2>

    <div class="field-group">
        <label>P2 Name</label>
        <input id="p2NameInput" class="@(_p2MenuIndex == 0 ? "menu-focused" : "")" @bind="Player2Name" disabled="@(_p2Playing)" />
    </div>

    <div class="skin-section" style="margin-top:6px; padding:4px;">
        <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.5px;opacity:0.6;margin-bottom:4px;">P2 Skin</label>
        <div class="skin-grid">
            <SkinGrid SelectedIndex="_p2SkinIndex"
                      KeyboardFocusIndex="@(_p2MenuIndex == 1 ? _p2SkinIndex : -1)"
                      OnSkinSelected="((idx) => _p2SkinIndex = idx)"
                      IdPrefix="p2" />
        </div>
        <div class="skin-preview-bar">
            <BECanvas Width="160" Height="40" @ref="_p2PreviewRef"></BECanvas>
            <span style="font-size:0.72rem;opacity:0.6;">@SnakeSkin.AllSkins[_p2SkinIndex].Name</span>
        </div>
    </div>

    <button class="btn-snake @(_p2MenuIndex == 2 ? "menu-focused" : "")" style="width:100%; margin-top:8px;" @onclick="ConnectP2">Connect P2</button>

    <div class="status-line">@_p2Status @if (_p2Status == "Disconnected" || _p2Status == "Game Over") { <span style="opacity:0.5; font-size:0.85em;">— Right Shift to start</span> }</div>
</div>
}

@* ── Canvas ── *@
<div id="snakeCanvas" style="position:fixed; inset:0; z-index:1; background:#7c9c45; overflow:hidden;">
    <BECanvas Width="1920" Height="1080" @ref="_canvasReference"></BECanvas>
</div>

@* ── Scoreboard Overlay ── *@
@if (_showScoreboard && GameController.PlayerId.HasValue)
{
    <div id="scoreboardOverlay" class="scoreboard-overlay @(_splitScreen ? "scoreboard-split" : "")">
        <strong>SCOREBOARD</strong>
        <ul>
            @foreach (var s in GameController.GetSnakes().Where(x => x.Alive == true).OrderByDescending(x => x.Score ?? 0))
            {
                <li @onclick="(() => { _centerTargetSnakeId = s.Id; })" class="@(s.Id == GameController.PlayerId ? "self" : "")">
                    <span>@(s.Name ?? "?")</span>
                    <span>@(s.Score ?? 0)</span>
                </li>
            }
        </ul>
    </div>
}

@* ── Death Overlay ── *@
@if (_showDeathScreen && !(_splitScreen ? _p1SidebarOpen : _sidebarOpen))
{
    <div class="death-overlay" style="@(_splitScreen ? "right:50%; left:0;" : "")">
        <h1>GAME OVER</h1>
        <div class="death-scores">
            <h3>High Scores</h3>
            <ul>
                @foreach (var s in GameController.GetSnakes().OrderByDescending(x => x.Score ?? 0).Take(5))
                {
                    <li>
                        <span>@(s.Name ?? "Anonymous")</span>
                        <span>@(s.Score ?? 0)</span>
                    </li>
                }
            </ul>
        </div>
        <button class="btn-respawn" @onclick="RespawnP1">Respawn</button>
        <span class="respawn-hint">@(_splitScreen ? "Shift to respawn • Tab for menu" : "Shift to respawn • Tab/Del for menu")</span>
    </div>
}
@if (_p2ShowDeath && _splitScreen && !_p2SidebarOpen)
{
    <div class="death-overlay" style="left:50%; right:0;">
        <h1>GAME OVER</h1>
        <div class="death-scores">
            <h3>High Scores</h3>
            <ul>
                @foreach (var s in (_p2Game?.GetSnakes() ?? Array.Empty<Snake>()).OrderByDescending(x => x.Score ?? 0).Take(5))
                {
                    <li>
                        <span>@(s.Name ?? "Anonymous")</span>
                        <span>@(s.Score ?? 0)</span>
                    </li>
                }
            </ul>
        </div>
        <button class="btn-respawn" @onclick="RespawnP2">Respawn</button>
        <span class="respawn-hint">Right Shift to respawn • Del for menu</span>
    </div>
}

@code
{
    // ==================== Constants ====================

    /// <summary>Target milliseconds per frame (~60 FPS).</summary>
    private const int FrameDelayMs = 16;

    // ==================== Private Fields ====================

    /// <summary>Canvas renderer responsible for all drawing operations.</summary>
    private readonly SnakeRenderer _renderer = new();

    /// <summary>Blazor reference to the main game canvas element.</summary>
    private BECanvasComponent? _canvasReference;

    /// <summary>2D drawing context for the main game canvas.</summary>
    private Canvas2DContext? _context;

    /// <summary>Blazor reference to the P1 skin-preview mini canvas.</summary>
    private BECanvasComponent? _p1PreviewRef;

    /// <summary>Blazor reference to the P2 skin-preview mini canvas.</summary>
    private BECanvasComponent? _p2PreviewRef;

    /// <summary>Cached 2D context for drawing the P1 skin preview.</summary>
    private Canvas2DContext? _p1PreviewCtx;

    /// <summary>Cached 2D context for drawing the P2 skin preview.</summary>
    private Canvas2DContext? _p2PreviewCtx;

    /// <summary>Last skin index drawn in the P1 preview (avoids redundant redraws).</summary>
    private int _lastP1PreviewSkin = -1;

    /// <summary>Last skin index drawn in the P2 preview (avoids redundant redraws).</summary>
    private int _lastP2PreviewSkin = -1;

    /// <summary>Token source for cancelling the render loop on dispose.</summary>
    private CancellationTokenSource? _renderCts;

    /// <summary>High-resolution timer for delta-time calculations.</summary>
    private readonly Stopwatch _frameStopwatch = new();

    /// <summary>Current viewport width in CSS pixels.</summary>
    private int _viewW = 1920;

    /// <summary>Current viewport height in CSS pixels.</summary>
    private int _viewH = 1080;

    // P1 per-player state (uses DI-injected controllers)

    /// <summary>Active death-explosion animations keyed by snake ID.</summary>
    private readonly Dictionary<int, SnakeRenderer.DeathAnim> _p1DeathAnims = new();

    /// <summary>Whether the P1 death overlay is displayed.</summary>
    private bool _showDeathScreen;

    /// <summary>World X to center the camera on while the death overlay is shown.</summary>
    private int _frozenCameraX;

    /// <summary>World Y to center the camera on while the death overlay is shown.</summary>
    private int _frozenCameraY;

    /// <summary>Buffered direction commands waiting to be sent (max 2).</summary>
    private readonly List<string> _p1MoveQueue = new();

    /// <summary>Synchronization lock protecting <see cref="_p1MoveQueue"/>.</summary>
    private readonly object _p1MoveLock = new();

    /// <summary>Last direction sent to the server, used for 180-degree rejection.</summary>
    private string? _p1LastSentDir;

    /// <summary>Frames remaining before the next queued move can be sent (cooldown timer).</summary>
    private int _p1MoveCooldown;

    /// <summary>Snake ID to follow with the camera (spectator mode), or null for own snake.</summary>
    private int? _centerTargetSnakeId;

    /// <summary>Set to true once the server sends P1's first body, enabling input.</summary>
    private volatile bool _p1Ready;

    /// <summary>Smooth-camera tracking state for the P1 viewport.</summary>
    private readonly SnakeRenderer.CameraState _p1Cam = new();

    // P2 per-player state (manually created controllers)

    /// <summary>Network controller for the second player (created at runtime, not via DI).</summary>
    private NetworkController? _p2Network;

    /// <summary>Game controller for the second player (created at runtime, not via DI).</summary>
    private GameController? _p2Game;

    /// <summary>Active death-explosion animations for P2 keyed by snake ID.</summary>
    private readonly Dictionary<int, SnakeRenderer.DeathAnim> _p2DeathAnims = new();

    /// <summary>Whether the P2 death overlay is displayed.</summary>
    private bool _p2ShowDeath;

    /// <summary>World X to center P2's camera on while the death overlay is shown.</summary>
    private int _p2FrozenCamX;

    /// <summary>World Y to center P2's camera on while the death overlay is shown.</summary>
    private int _p2FrozenCamY;

    /// <summary>Buffered direction commands for P2 waiting to be sent (max 2).</summary>
    private readonly List<string> _p2MoveQueue = new();

    /// <summary>Synchronization lock protecting <see cref="_p2MoveQueue"/>.</summary>
    private readonly object _p2MoveLock = new();

    /// <summary>Last direction P2 sent to the server, used for 180-degree rejection.</summary>
    private string? _p2LastSentDir;

    /// <summary>Frames remaining before P2's next queued move can be sent.</summary>
    private int _p2MoveCooldown;

    /// <summary>Set to true once the server sends P2's first body, enabling input.</summary>
    private volatile bool _p2Ready;

    /// <summary>Smooth-camera tracking state for the P2 viewport.</summary>
    private readonly SnakeRenderer.CameraState _p2Cam = new();

    /// <summary>P1 head screen-space X for scoreboard dither calculation.</summary>
    private double _p1HeadScreenX;

    /// <summary>P1 head screen-space Y for scoreboard dither calculation.</summary>
    private double _p1HeadScreenY;

    /// <summary>P2 head screen-space X for scoreboard dither calculation.</summary>
    private double _p2HeadScreenX;

    /// <summary>P2 head screen-space Y for scoreboard dither calculation.</summary>
    private double _p2HeadScreenY;

    // ==================== UI State ====================

    /// <summary>Assignment server hostname for snake game connections.</summary>
    private const string ServerHost = "localhost";

    /// <summary>Assignment server TCP port for snake game connections.</summary>
    private const int ServerPort = 11000;

    /// <summary>Player 1 display name sent to the server.</summary>
    private string PlayerName { get; set; } = "Player 1";

    /// <summary>Player 2 display name sent to the server.</summary>
    private string Player2Name { get; set; } = "Player 2";

    /// <summary>Human-readable connection status for P1 ("Disconnected", "Connecting...", "Connected", "Error: ...").</summary>
    private string _status = "Disconnected";

    /// <summary>Human-readable connection status for P2.</summary>
    private string _p2Status = "Disconnected";

    /// <summary>Whether split-screen (2-player) mode is active.</summary>
    private bool _splitScreen;

    /// <summary>Previous frame's split-screen state, used to detect toggle transitions.</summary>
    private bool _wasSplitScreen;

    /// <summary>Whether the background grid overlay is drawn.</summary>
    private bool _drawGrid = true;

    /// <summary>Whether high-quality (textured) rendering is enabled.</summary>
    private bool _highQualityTextures = true;

    /// <summary>Whether the single-player sidebar is expanded.</summary>
    private bool _sidebarOpen = true;

    /// <summary>Whether the P1 sidebar is expanded (split-screen mode).</summary>
    private bool _p1SidebarOpen = true;

    /// <summary>Whether the P2 sidebar is expanded (split-screen mode).</summary>
    private bool _p2SidebarOpen = true;

    /// <summary>Current keyboard-focused menu item index for P1.</summary>
    private int _p1MenuIndex = 1;

    /// <summary>Current keyboard-focused menu item index for P2.</summary>
    private int _p2MenuIndex = 1;

    /// <summary>Maximum menu index for P1 (0 = Name, 1 = Skin, 2 = Connect, 3–6 = toggles).</summary>
    private const int P1MenuMax = 6;

    /// <summary>Maximum menu index for P2 (0 = Name, 1 = Skin, 2 = Connect).</summary>
    private const int P2MenuMax = 2;

    /// <summary>Number of columns in the skin picker grid (used for 2D keyboard navigation).</summary>
    private const int SkinGridCols = 5;

    /// <summary>Whether P1 is actively playing (connected and not on death screen).</summary>
    private bool _p1Playing => GameController.PlayerId.HasValue && !_showDeathScreen;

    /// <summary>Whether P2 is actively playing (connected and not on death screen).</summary>
    private bool _p2Playing => _p2Game?.PlayerId.HasValue == true && !_p2ShowDeath;

    /// <summary>Whether the scoreboard overlay is visible.</summary>
    private bool _showScoreboard = true;

    /// <summary>Index into <see cref="SnakeSkin.AllSkins"/> for P1's selected skin.</summary>
    private int _p1SkinIndex;

    /// <summary>Index into <see cref="SnakeSkin.AllSkins"/> for P2's selected skin.</summary>
    private int _p2SkinIndex = 1;

    /// <summary>Maps each direction to its 180-degree opposite for queue rejection logic.</summary>
    private static readonly Dictionary<string, string> _opposites = new()
    {
        ["up"] = "down", ["down"] = "up", ["left"] = "right", ["right"] = "left"
    };

    /// <summary>Dither cell grid size in pixels.</summary>
    private const double DitherCell = 5.0;

    /// <summary>Half the dither cell size (radius baseline).</summary>
    private const double DitherHalf = DitherCell / 2.0;

    /// <summary>Maximum dither star radius (overflows cell, clips to solid).</summary>
    private const double DitherMaxR = DitherHalf * 2.0;

    /// <summary>Minimum dither star radius (always-visible dots).</summary>
    private const double DitherMinR = DitherHalf * 0.40;

    /// <summary>Computes a dither star radius for a single head position relative to a scoreboard rectangle.</summary>
    private double ComputeDitherForHead(double headX, double headY, double sbLeft, double sbTop, double sbRight, double sbBottom)
    {
        const double fadeDistance = 80.0;
        double nearX = Math.Clamp(headX, sbLeft, sbRight);
        double nearY = Math.Clamp(headY, sbTop, sbBottom);
        double dx = headX - nearX;
        double dy = headY - nearY;
        double dist = Math.Sqrt(dx * dx + dy * dy);

        if (dist >= fadeDistance) return -1;

        double tLinear = 1.0 - dist / fadeDistance;
        double t = tLinear * tLinear;
        return DitherMaxR - t * (DitherMaxR - DitherMinR);
    }

    /// <summary>Computes dither radius for single-player mode (full scoreboard).</summary>
    private double ComputeDitherRadius()
    {
        if (_showDeathScreen) return -1;
        return ComputeDitherForHead(_p1HeadScreenX, _p1HeadScreenY, 12, 12, 12 + 212, 12 + 180);
    }

    /// <summary>Computes per-half dither radii for split-screen mode. Left half reacts to P1, right half to P2.</summary>
    private (double leftR, double rightR) ComputeSplitDitherRadii()
    {
        // Scoreboard is centered at 50vw; approximate pixel bounds
        double centerX = _viewW / 2.0;
        double sbW = 212, sbH = 180;
        double sbLeft = centerX - sbW / 2.0;
        double sbTop = 36;
        double sbRight = centerX + sbW / 2.0;
        double sbBottom = sbTop + sbH;

        double leftR = _showDeathScreen ? -1 : ComputeDitherForHead(_p1HeadScreenX, _p1HeadScreenY, sbLeft, sbTop, centerX, sbBottom);
        double rightR = _p2ShowDeath ? -1 : ComputeDitherForHead(_p2HeadScreenX, _p2HeadScreenY, centerX, sbTop, sbRight, sbBottom);
        return (leftR, rightR);
    }

    // ==================== Lifecycle ====================

    /// <summary>Initializes canvases, JS interop, P2 controllers, and starts the render loop.</summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Create P2 controllers (P1 uses DI-injected ones)
        _p2Network = new NetworkController();
        _p2Game = new GameController(_p2Network, new ScoreDatabaseController());

        await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/SnakeGUI.razor.js");
        _context = await _canvasReference!.CreateCanvas2DAsync();
        await JsRuntime.InvokeAsync<object>("initRenderJS", DotNetObjectReference.Create(this));

        _renderCts = new CancellationTokenSource();
        _ = Task.Run(() => RenderLoopAsync(_renderCts.Token));

        NetworkController.OnDisconnected += () => _ = InvokeAsync(() => { _status = "Disconnected"; StateHasChanged(); });
        _p2Network.OnDisconnected += () => _ = InvokeAsync(() => { _p2Status = "Disconnected"; StateHasChanged(); });

        GameController.OnPlayerDied += OnP1Died;
        _p2Game.OnPlayerDied += OnP2Died;
    }

    /// <summary>Stops the render loop and disposes P2 network resources.</summary>
    public void Dispose()
    {
        try { _renderCts?.Cancel(); } catch { }
        GameController.OnPlayerDied -= OnP1Died;
        if (_p2Game != null) _p2Game.OnPlayerDied -= OnP2Died;
        _p2Network?.Dispose();
    }

    // ==================== Input ====================

    /// <summary>Called by JS when the browser viewport is resized.</summary>
    /// <param name="dims">Two-element array [width, height] in CSS pixels.</param>
    [JSInvokable]
    public void UpdateViewportSize(int[] dims)
    {
        if (dims is { Length: 2 } && dims[0] > 0 && dims[1] > 0)
        {
            _viewW = dims[0];
            _viewH = dims[1];
        }
    }

    /// <summary>
    /// Routes a keyboard event to the appropriate handler: sidebar navigation,
    /// menu activation, movement queueing, or respawn/connect shortcuts.
    /// Called from JS via <c>invokeMethodAsync('HandleKeyPress', key)</c>.
    /// </summary>
    /// <param name="key">The <c>KeyboardEvent.code</c> value (e.g. "KeyW", "ArrowUp", "Tab").</param>
    [JSInvokable]
    public void HandleKeyPress(string key)
    {
        bool p1SidebarVis = _splitScreen ? _p1SidebarOpen : _sidebarOpen;
        bool p2SidebarVis = _splitScreen && _p2SidebarOpen;
        bool p1CanOpen = _showDeathScreen || !GameController.PlayerId.HasValue;
        bool p2CanOpen = _p2ShowDeath || _p2Game == null || _p2Game.PlayerId.HasValue != true;

        // ── Tab: P1 menu action / open ──
        if (key == "Tab")
        {
            if (p1SidebarVis)
                ActivateP1MenuItem();
            else if (!_splitScreen && !p1SidebarVis && p1CanOpen)
                OpenP1Sidebar();
            else if (_splitScreen && !_p1SidebarOpen && p1CanOpen)
                OpenP1Sidebar();
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        // ── Delete/Backspace: P2 action (split) or P1 fallback (single) ──
        if (key == "Delete" || key == "Backspace")
        {
            if (_splitScreen)
            {
                if (p2SidebarVis) ActivateP2MenuItem();
                else if (p2CanOpen) OpenP2Sidebar();
            }
            else
            {
                if (p1SidebarVis) ActivateP1MenuItem();
                else if (p1CanOpen) OpenP1Sidebar();
            }
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        // ── Enter: activate focused item in whichever sidebar is open ──
        if (key == "Enter")
        {
            if (p1SidebarVis) ActivateP1MenuItem();
            if (p2SidebarVis) ActivateP2MenuItem();
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        // ── Shift: respawn / connect ──
        if (key == "ShiftLeft")
        {
            if (_showDeathScreen) { RespawnP1(); return; }
            if (!GameController.PlayerId.HasValue && _status != "Connecting...")
            { _ = InvokeAsync(() => Connect()); return; }
            return;
        }
        if (key == "ShiftRight")
        {
            if (_splitScreen)
            {
                if (_p2ShowDeath) { RespawnP2(); return; }
                if (_p2Game != null && !_p2Game.PlayerId.HasValue && _p2Status != "Connecting...")
                { _ = InvokeAsync(() => ConnectP2()); return; }
                return;
            }
            // Single-player: Right Shift also controls P1
            if (_showDeathScreen) { RespawnP1(); return; }
            if (!GameController.PlayerId.HasValue && _status != "Connecting...")
            { _ = InvokeAsync(() => Connect()); return; }
            return;
        }

        // ── Escape: close open sidebar ──
        if (key == "Escape")
        {
            if (p1SidebarVis) { if (_splitScreen) _p1SidebarOpen = false; else _sidebarOpen = false; }
            if (p2SidebarVis) _p2SidebarOpen = false;
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        // ── WASD: P1 menu nav (when sidebar open) or movement ──
        var wasdDir = key.ToLowerInvariant() switch
        {
            "w" => "up", "a" => "left", "s" => "down", "d" => "right",
            _ => (string?)null
        };
        if (wasdDir != null)
        {
            if (p1SidebarVis)
            {
                NavigateMenu(ref _p1MenuIndex, P1MenuMax, wasdDir, isP1: true);
                _ = InvokeAsync(StateHasChanged);
            }
            else
            {
                if (_showDeathScreen || !_p1Ready) return;
                EnqueueMove(_p1MoveQueue, _p1MoveLock, wasdDir);
            }
            return;
        }

        // ── Arrow keys: P2 menu nav (split) or P1 fallback (single) ──
        var arrowDir = key switch
        {
            "ArrowUp" => "up", "ArrowLeft" => "left",
            "ArrowDown" => "down", "ArrowRight" => "right",
            _ => (string?)null
        };
        if (arrowDir == null) return;

        if (_splitScreen)
        {
            if (p2SidebarVis)
            {
                NavigateMenu(ref _p2MenuIndex, P2MenuMax, arrowDir, isP1: false);
                _ = InvokeAsync(StateHasChanged);
            }
            else
            {
                if (_p2ShowDeath || !_p2Ready || _p2Game == null) return;
                EnqueueMove(_p2MoveQueue, _p2MoveLock, arrowDir);
            }
        }
        else
        {
            if (p1SidebarVis)
            {
                NavigateMenu(ref _p1MenuIndex, P1MenuMax, arrowDir, isP1: true);
                _ = InvokeAsync(StateHasChanged);
            }
            else
            {
                if (_showDeathScreen || !_p1Ready) return;
                EnqueueMove(_p1MoveQueue, _p1MoveLock, arrowDir);
            }
        }
    }

    /// <summary>
    /// Moves the keyboard focus index within a sidebar menu. When the focus is
    /// on the skin picker (index 1), left/right cycle through skins and up/down
    /// navigate between skin-grid rows.
    /// </summary>
    /// <param name="idx">Reference to the menu index being navigated.</param>
    /// <param name="max">Maximum valid menu index.</param>
    /// <param name="dir">Direction string ("up", "down", "left", "right").</param>
    /// <param name="isP1">True for P1 (modifies <see cref="_p1SkinIndex"/>), false for P2.</param>
    private void NavigateMenu(ref int idx, int max, string dir, bool isP1)
    {
        int skinCount = SnakeSkin.AllSkins.Length;
        ref int skinIdx = ref (isP1 ? ref _p1SkinIndex : ref _p2SkinIndex);

        switch (dir)
        {
            case "up":
                if (idx == 1)
                {
                    int row = skinIdx / SkinGridCols;
                    if (row > 0) { skinIdx -= SkinGridCols; return; }
                }
                idx = idx <= 0 ? max : idx - 1;
                break;
            case "down":
                if (idx == 1)
                {
                    int row = skinIdx / SkinGridCols;
                    int nextRow = row + 1;
                    if (nextRow * SkinGridCols < skinCount) { skinIdx = Math.Min(skinIdx + SkinGridCols, skinCount - 1); return; }
                }
                idx = idx >= max ? 0 : idx + 1;
                break;
            case "left":
                if (idx == 1) skinIdx = (skinIdx - 1 + skinCount) % skinCount;
                break;
            case "right":
                if (idx == 1) skinIdx = (skinIdx + 1) % skinCount;
                break;
        }
    }

    /// <summary>Activates the P1 menu item at the current <see cref="_p1MenuIndex"/>.</summary>
    private void ActivateP1MenuItem()
    {
        switch (_p1MenuIndex)
        {
            case 0: _ = JsRuntime.InvokeVoidAsync("focusSidebarInput", "p1NameInput"); break;
            case 1: break;
            case 2:
                if (_splitScreen) _p1SidebarOpen = false; else _sidebarOpen = false;
                _ = InvokeAsync(() => Connect());
                break;
            case 3: _highQualityTextures = !_highQualityTextures; break;
            case 4: _drawGrid = !_drawGrid; break;
            case 5: _showScoreboard = !_showScoreboard; break;
            case 6: _splitScreen = !_splitScreen; break;
        }
    }

    /// <summary>Activates the P2 menu item at the current <see cref="_p2MenuIndex"/>.</summary>
    private void ActivateP2MenuItem()
    {
        switch (_p2MenuIndex)
        {
            case 0: _ = JsRuntime.InvokeVoidAsync("focusSidebarInput", "p2NameInput"); break;
            case 1: break;
            case 2:
                _p2SidebarOpen = false;
                _ = InvokeAsync(() => ConnectP2());
                break;
        }
    }

    /// <summary>Opens the P1 sidebar and defaults focus to the skin picker.</summary>
    private void OpenP1Sidebar()
    {
        if (_splitScreen) _p1SidebarOpen = true; else _sidebarOpen = true;
        _p1MenuIndex = 1;
    }

    /// <summary>Opens the P2 sidebar and defaults focus to the skin picker.</summary>
    private void OpenP2Sidebar()
    {
        _p2SidebarOpen = true;
        _p2MenuIndex = 1;
    }

    /// <summary>
    /// Infers the current heading direction from the snake's last two body segments.
    /// Returns null if the snake has fewer than two segments.
    /// </summary>
    private static string? GetSnakeHeading(GameController gc)
    {
        var snake = gc.GetPlayerSnake();
        if (snake?.Body == null || snake.Body.Count < 2) return null;
        var head = snake.Body[^1];
        var neck = snake.Body[^2];
        var dx = head.X - neck.X;
        var dy = head.Y - neck.Y;
        if (dx == 0 && dy == 0) return null;
        return Math.Abs(dx) > Math.Abs(dy)
            ? (dx > 0 ? "right" : "left")
            : (dy > 0 ? "down" : "up");
    }

    /// <summary>
    /// Appends a direction command to the move queue (max 2 entries).
    /// Drops duplicates of the most recent queued direction.
    /// </summary>
    private static void EnqueueMove(List<string> queue, object queueLock, string cmd)
    {
        lock (queueLock)
        {
            if (queue.Count >= 2) return;
            if (queue.Count > 0 && queue[^1] == cmd) return;
            queue.Add(cmd);
        }
    }

    /// <summary>
    /// Dequeues the next valid move from the buffer, handling three special cases:
    /// cancel-pair (both directions undo each other), 180-reorder (send the valid
    /// intermediate turn first), and normal single/pair dequeue.
    /// </summary>
    /// <returns>The direction string to send, or null if no valid move is available.</returns>
    private static string? DequeueMove(List<string> queue, object queueLock, GameController gc, ref string? lastSentDir)
    {
        lock (queueLock)
        {
            if (queue.Count == 0) return null;

            var heading = lastSentDir ?? GetSnakeHeading(gc);

            if (queue.Count == 1)
            {
                var move = queue[0];
                queue.RemoveAt(0);
                if (heading != null && _opposites.TryGetValue(move, out var opp) && opp == heading)
                    return null;
                lastSentDir = move;
                return move;
            }

            var first = queue[0];
            var second = queue[1];
            bool firstIs180 = heading != null && _opposites.TryGetValue(first, out var o1) && o1 == heading;
            bool pairCancels = _opposites.TryGetValue(first, out var fo) && fo == second;

            // Two inputs that undo each other (e.g. down+up) — discard both.
            if (pairCancels)
            {
                queue.Clear();
                return null;
            }

            // 180 key pressed first (e.g. left while heading right, then down).
            // Reorder: send the valid intermediate turn now, re-queue the
            // originally-180 move which becomes valid after the turn.
            if (firstIs180)
            {
                queue.Clear();
                queue.Add(first);
                lastSentDir = second;
                return second;
            }

            // First move is valid — send it, leave second for next frame.
            queue.RemoveAt(0);
            lastSentDir = first;
            return first;
        }
    }

    // ==================== Connection ====================

    /// <summary>Disconnects any existing P1 session and connects with current settings.</summary>
    private async Task Connect()
    {
        _showDeathScreen = false;
        lock (_p1MoveLock) _p1MoveQueue.Clear();
        _p1LastSentDir = null;
        _p1Ready = false;
        _p1Cam.Reset();
        if (_splitScreen) _p1SidebarOpen = false;
        else _sidebarOpen = false;
        _renderer.ClearWallCache(GameController);
        GameController.Disconnect();
        try
        {
            _status = "Connecting...";
            StateHasChanged();
            await GameController.ConnectAsync(ServerHost, ServerPort, PlayerName, _p1SkinIndex);
            _status = "Connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _status = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    /// <summary>Disconnects any existing P2 session and connects with current settings.</summary>
    private async Task ConnectP2()
    {
        if (_p2Game == null) return;
        _p2ShowDeath = false;
        lock (_p2MoveLock) _p2MoveQueue.Clear();
        _p2LastSentDir = null;
        _p2Ready = false;
        _p2Cam.Reset();
        _renderer.ClearWallCache(_p2Game);
        _p2SidebarOpen = false;
        _p2Game.Disconnect();
        try
        {
            _p2Status = "Connecting...";
            StateHasChanged();
            await _p2Game.ConnectAsync(ServerHost, ServerPort, Player2Name, _p2SkinIndex);
            _p2Status = "Connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _p2Status = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    /// <summary>Sends a respawn command for P1 and dismisses the death overlay.</summary>
    private void RespawnP1()
    {
        _showDeathScreen = false;
        if (_splitScreen) _p1SidebarOpen = false; else _sidebarOpen = false;
        lock (_p1MoveLock) _p1MoveQueue.Clear();
        _p1LastSentDir = null;
        _ = GameController.SendMoveAsync("respawn");
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>Sends a respawn command for P2 and dismisses the death overlay.</summary>
    private void RespawnP2()
    {
        _p2ShowDeath = false;
        _p2SidebarOpen = false;
        lock (_p2MoveLock) _p2MoveQueue.Clear();
        _p2LastSentDir = null;
        if (_p2Game != null) _ = _p2Game.SendMoveAsync("respawn");
        _ = InvokeAsync(StateHasChanged);
    }

    // ==================== Game State ====================

    /// <summary>Handles the P1 death event: freezes camera and shows the death overlay.</summary>
    private void OnP1Died()
    {
        if (_showDeathScreen) return;
        _showDeathScreen = true;
        _status = "Game Over";

        var player = GameController.GetPlayerSnake();
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _frozenCameraX = head.X;
            _frozenCameraY = head.Y;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>Handles the P2 death event: freezes camera and shows the death overlay.</summary>
    private void OnP2Died()
    {
        if (_p2ShowDeath) return;
        _p2ShowDeath = true;
        _p2Status = "Game Over";

        var player = _p2Game?.GetPlayerSnake();
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _p2FrozenCamX = head.X;
            _p2FrozenCamY = head.Y;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    // ==================== Render Loop ====================

    /// <summary>
    /// Main render loop running at ~60 FPS. Each tick dequeues buffered moves
    /// (respecting the 3-frame cooldown), draws the frame, and triggers
    /// periodic Blazor UI updates.
    /// </summary>
    private async Task RenderLoopAsync(CancellationToken ct)
    {
        _frameStopwatch.Start();
        int tick = 0;
        var frameSw = new Stopwatch();
        try
        {
            while (!ct.IsCancellationRequested)
            {
                frameSw.Restart();
                try
                {
                    // P1 move — skip one frame after sending so the server
                    // processes each turn before receiving the next one.
                    if (_p1MoveCooldown > 0) _p1MoveCooldown--;
                    else
                    {
                        var move1 = DequeueMove(_p1MoveQueue, _p1MoveLock, GameController, ref _p1LastSentDir);
                        if (move1 != null) { _ = GameController.SendMoveAsync(move1); _p1MoveCooldown = 3; }
                    }

                    // P2 move
                    if (_splitScreen && _p2Game != null)
                    {
                        if (_p2MoveCooldown > 0) _p2MoveCooldown--;
                        else
                        {
                            var move2 = DequeueMove(_p2MoveQueue, _p2MoveLock, _p2Game, ref _p2LastSentDir);
                            if (move2 != null) { _ = _p2Game.SendMoveAsync(move2); _p2MoveCooldown = 3; }
                        }
                    }

                    await DrawFrame();

                    // Mark players ready once their snake has been rendered
                    if (!_p1Ready && GameController.GetPlayerSnake()?.Body?.Count > 0)
                        _p1Ready = true;
                    if (!_p2Ready && _p2Game?.GetPlayerSnake()?.Body?.Count > 0)
                        _p2Ready = true;

                    if (++tick % 6 == 0) await InvokeAsync(StateHasChanged);
                }
                catch { /* skip frame */ }
                var drawMs = (int)frameSw.ElapsedMilliseconds;
                var remaining = FrameDelayMs - drawMs;
                if (remaining > 0)
                    await Task.Delay(remaining, ct);
            }
        }
        catch (TaskCanceledException) { }
    }

    // ==================== Drawing ====================

    /// <summary>
    /// Draws a single frame: clears the canvas, renders viewports (single or split),
    /// updates skin previews, and pushes the dither mask to JS.
    /// </summary>
    private async Task DrawFrame()
    {
        if (_context == null) return;

        var elapsed = _frameStopwatch.Elapsed.TotalSeconds;
        _frameStopwatch.Restart();

        await _context.BeginBatchAsync();
        await _context.SetFillStyleAsync(_highQualityTextures ? "#7c9c45" : "#e8f5ff");
        await _context.FillRectAsync(0, 0, _viewW, _viewH);

        if (_splitScreen && _p2Game != null)
        {
            var halfW = _viewW / 2;

            // Resolve P1 center target
            if (_centerTargetSnakeId.HasValue)
            {
                if (!GameController.GetSnakes().Any(s => s.Id == _centerTargetSnakeId.Value))
                    _centerTargetSnakeId = null;
            }

            // Left viewport — P1 (WASD)
            var p1Head = await _renderer.DrawViewport(_context, GameController, _p1DeathAnims, _showDeathScreen,
                _frozenCameraX, _frozenCameraY, _centerTargetSnakeId,
                0, 0, halfW, _viewH, elapsed, _p1Cam, SnakeSkin.AllSkins[_p1SkinIndex], _drawGrid, _highQualityTextures);
            if (p1Head.HasValue) { _p1HeadScreenX = p1Head.Value.headX; _p1HeadScreenY = p1Head.Value.headY; }

            // Right viewport — P2 (Arrows)
            var p2Head = await _renderer.DrawViewport(_context, _p2Game, _p2DeathAnims, _p2ShowDeath,
                _p2FrozenCamX, _p2FrozenCamY, null,
                halfW, 0, halfW, _viewH, elapsed, _p2Cam, SnakeSkin.AllSkins[_p2SkinIndex], _drawGrid, _highQualityTextures);
            if (p2Head.HasValue) { _p2HeadScreenX = p2Head.Value.headX; _p2HeadScreenY = p2Head.Value.headY; }

            // Divider line
            await _context.SetStrokeStyleAsync("rgba(255,255,255,0.4)");
            await _context.SetLineWidthAsync(2);
            await _context.BeginPathAsync();
            await _context.MoveToAsync(halfW, 0);
            await _context.LineToAsync(halfW, _viewH);
            await _context.StrokeAsync();

            // Player labels (centered in each viewport half)
            await _context.SetFillStyleAsync("rgba(255,255,255,0.5)");
            await _context.SetFontAsync("bold 16px Arial");
            await _context.SetTextAlignAsync(TextAlign.Center);
            await _context.FillTextAsync("P1 (WASD)", halfW / 2, 24);
            await _context.FillTextAsync("P2 (Arrows)", halfW + halfW / 2, 24);
            await _context.SetTextAlignAsync(TextAlign.Start);
        }
        else
        {
            // Resolve center target
            if (_centerTargetSnakeId.HasValue)
            {
                if (!GameController.GetSnakes().Any(s => s.Id == _centerTargetSnakeId.Value))
                    _centerTargetSnakeId = null;
            }

            var p1Head = await _renderer.DrawViewport(_context, GameController, _p1DeathAnims, _showDeathScreen,
                _frozenCameraX, _frozenCameraY, _centerTargetSnakeId,
                0, 0, _viewW, _viewH, elapsed, _p1Cam, SnakeSkin.AllSkins[_p1SkinIndex], _drawGrid, _highQualityTextures);
            if (p1Head.HasValue) { _p1HeadScreenX = p1Head.Value.headX; _p1HeadScreenY = p1Head.Value.headY; }
        }

        await _context.EndBatchAsync();

        // Redraw skin previews when selection changes
        if (_p1SkinIndex != _lastP1PreviewSkin)
        {
            _p1PreviewCtx ??= _p1PreviewRef != null ? await _p1PreviewRef.CreateCanvas2DAsync() : null;
            if (_p1PreviewCtx != null) { await _renderer.DrawSkinPreview(_p1PreviewCtx, SnakeSkin.AllSkins[_p1SkinIndex]); _lastP1PreviewSkin = _p1SkinIndex; }
        }
        // Invalidate P2 preview when split-screen is (re-)enabled — the BECanvas DOM element
        // is destroyed on toggle-off and recreated on toggle-on, making the old context stale.
        if (_splitScreen && !_wasSplitScreen)
        {
            _p2PreviewCtx = null;
            _lastP2PreviewSkin = -1;
        }
        _wasSplitScreen = _splitScreen;

        if (_splitScreen && (_p2SkinIndex != _lastP2PreviewSkin || _p2PreviewCtx == null))
        {
            _p2PreviewCtx = _p2PreviewRef != null ? await _p2PreviewRef.CreateCanvas2DAsync() : null;
            if (_p2PreviewCtx != null) { await _renderer.DrawSkinPreview(_p2PreviewCtx, SnakeSkin.AllSkins[_p2SkinIndex]); _lastP2PreviewSkin = _p2SkinIndex; }
        }

        // Update scoreboard dither mask every frame via JS (bypasses Blazor render cycle)
        if (_showScoreboard && GameController.PlayerId.HasValue)
        {
            if (_splitScreen)
            {
                var (leftR, rightR) = ComputeSplitDitherRadii();
                await JsRuntime.InvokeVoidAsync("updateScoreboardDither", leftR, rightR);
            }
            else
            {
                double ditherR = ComputeDitherRadius();
                await JsRuntime.InvokeVoidAsync("updateScoreboardDither", ditherR, -1.0);
            }
        }
    }
}
