@page "/snake"
@rendermode InteractiveServer
@using Blazor.Extensions
@using Blazor.Extensions.Canvas
@using Blazor.Extensions.Canvas.Canvas2D
@using System.Diagnostics
    @using GUI.Components.Controllers
@using GUI.Components.Models
@using System.Linq
@inject IJSRuntime JsRuntime;
@inject GameController GameController
@inject GUI.Components.Controllers.NetworkController NetworkController

<PageTitle> Snake </PageTitle>

<div style="position: fixed; left: 8px; top: 8px; z-index: 10; background: rgba(255,255,255,0.9); padding:8px; border-radius:6px;">
    <label>Host: <input @bind="Host" /></label>
    <label>Port: <input type="number" @bind="Port" style="width:80px" /></label>
    <label>Name: <input @bind="PlayerName" /></label>
    <button @onclick="Connect">Connect</button>
    <button @onclick="Reconnect">Reconnect</button>
    <button @onclick="() => _showSettings = !_showSettings">⚙️ Settings</button>
        <div>Status: @_status</div>
        @if (_reconnectInProgress)
        {
            <div>Retrying... @_reconnectCountdown s</div>
            <button @onclick="(() => _reconnectCts?.Cancel())">Cancel</button>
        }
        
    @if (_showSettings)
    {
        <div style="margin-top: 8px; border-top: 1px solid #ccc; padding-top: 8px;">
            <label style="display:block;"><input type="checkbox" @bind="_highQualityTextures" /> High Quality Graphics</label>
            <label style="display:block;"><input type="checkbox" @bind="_drawGrid" /> Draw Grid Overlay</label>
        </div>
    }

    <div style="margin-top:8px; max-height:300px; overflow:auto;">
        <strong>Players</strong>
        <ul style="list-style:none; padding:0; margin:4px 0;">
            @foreach (var s in GameController.GetSnakes().OrderByDescending(x => x.score))
            {
                <li style="padding:2px; cursor:pointer;" @onclick="(() => { _centerTargetSnakeId = s.snake; })">
                    @s.name (@s.score)
                </li>
            }
        </ul>
    </div>
</div>

<div id="snakeCanvas" style="position: fixed; width: 100%; height: 100%; z-index: 1;">
    <BECanvas Width="1000" Height="1000" @ref="_canvasReference"></BECanvas>
</div>

@if (_showDeathScreen)
{
    <div style="position: fixed; left: 0; top: 0; width: 100%; height: 100%; z-index: 20; background: rgba(0,0,0,0.7); display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; animation: fadeIn 1s ease-in-out forwards; animation-delay: 0.25s; opacity: 0;">
        <style>
            @@keyframes fadeIn {
                to { opacity: 1; }
            }
        </style>
        <h1 style="font-size: 4rem; color: #ff4444; font-weight: bold; margin-bottom: 24px; text-shadow: 2px 2px 4px #000;">GAME OVER</h1>
        
        <h2>High Scores</h2>
        <ul style="list-style: none; padding: 0; min-width: 200px; text-align: left; background: rgba(255,255,255,0.1); padding: 16px; border-radius: 8px;">
            @foreach (var s in GameController.GetSnakes().OrderByDescending(x => x.score).Take(5))
            {
                <li style="font-size: 1.2rem; padding: 4px; border-bottom: 1px solid rgba(255,255,255,0.2);">
                    @(s.name ?? "Anonymous") <span style="float: right;">@s.score</span>
                </li>
            }
        </ul>

        <button style="margin-top: 24px; font-size: 1.5rem; padding: 12px 32px; background: #4caf50; color: white; border: none; border-radius: 8px; cursor: pointer; box-shadow: 0 4px 6px rgba(0,0,0,0.5);" @onclick="Respawn">
            Respawn
        </button>
    </div>
}

@code
{
    private BECanvasComponent? _canvasReference;
    private Canvas2DContext? _context;
    private IJSObjectReference? _jsModule;
    private CancellationTokenSource? _renderCts;

    // connection UI
    private string Host { get; set; } = "localhost";
    private int Port { get; set; } = 11000;
    private string PlayerName { get; set; } = "Player";
    private string _status = "disconnected";



    private bool _showDeathScreen = false;

    private bool _spawnVerified = false;

    private bool IsSpawnSafe(Snake player)
    {
        if (player.body == null || player.body.Count < 2 || player.dir == null) return false;
        var head = player.body.Last();
        var headX = (double)head.X;
        var headY = (double)head.Y;
        var dirX = (double)player.dir.X;
        var dirY = (double)player.dir.Y;
        
        // Ray length 500 units (10 tiles)
        double rayX1 = headX;
        double rayY1 = headY;
        double rayX2 = headX + dirX * 500;
        double rayY2 = headY + dirY * 500;

        foreach (var w in GameController.GetWalls())
        {
            if (w.p1 == null || w.p2 == null) continue;
            double rx1 = Math.Min(w.p1.X, w.p2.X) - 25;
            double rx2 = Math.Max(w.p1.X, w.p2.X) + 25;
            double ry1 = Math.Min(w.p1.Y, w.p2.Y) - 25;
            double ry2 = Math.Max(w.p1.Y, w.p2.Y) + 25;
            
            if (headX >= rx1 && headX <= rx2 && headY >= ry1 && headY <= ry2) return false;
            if (LineIntersectsRect(rayX1, rayY1, rayX2, rayY2, rx1, ry1, rx2, ry2)) return false;
        }

        foreach (var s in GameController.GetSnakes())
        {
            if (s.snake == player.snake || s.alive != true || s.body == null || s.body.Count < 2) continue;
            for (int i = 0; i < s.body.Count - 1; i++)
            {
                var bp1 = s.body[i];
                var bp2 = s.body[i+1];
                double rx1 = Math.Min(bp1.X, bp2.X) - 10;
                double rx2 = Math.Max(bp1.X, bp2.X) + 10;
                double ry1 = Math.Min(bp1.Y, bp2.Y) - 10;
                double ry2 = Math.Max(bp1.Y, bp2.Y) + 10;
                
                if (headX >= rx1 && headX <= rx2 && headY >= ry1 && headY <= ry2) return false;
                if (LineIntersectsRect(rayX1, rayY1, rayX2, rayY2, rx1, ry1, rx2, ry2)) return false;
            }
        }
        
        return true;
    }

    private bool LineIntersectsRect(double p1x, double p1y, double p2x, double p2y, double rx1, double ry1, double rx2, double ry2)
    {
        if (p1x == p2x) // Vertical ray
        {
            double minY = Math.Min(p1y, p2y);
            double maxY = Math.Max(p1y, p2y);
            return p1x >= rx1 && p1x <= rx2 && minY <= ry2 && maxY >= ry1;
        }
        else if (p1y == p2y) // Horizontal ray
        {
            double minX = Math.Min(p1x, p2x);
            double maxX = Math.Max(p1x, p2x);
            return p1y >= ry1 && p1y <= ry2 && minX <= rx2 && maxX >= rx1;
        }
        return false;
    }

    protected override async Task OnAfterRenderAsync( bool firstRender )
    {
        if ( firstRender )
        {
            _jsModule = await JsRuntime.InvokeAsync<IJSObjectReference>( "import", "./Components/Pages/SnakeGUI.razor.js" );
            _context = await _canvasReference.CreateCanvas2DAsync();
            await JsRuntime.InvokeAsync<object>( "initRenderJS", DotNetObjectReference.Create( this ) );

            // start render loop
            _renderCts = new CancellationTokenSource();
            _ = Task.Run(() => RenderLoopAsync(_renderCts.Token));

            // subscribe to game/network events to update UI
            _onStateUpdatedHandler = () => _ = InvokeAsync(async () => {
                var player = GameController.GetPlayerSnake();
                if (player != null)
                {
                    if (player.alive == true)
                    {
                        if (_showDeathScreen)
                        {
                            _showDeathScreen = false;
                        }
                        
                        if (!_spawnVerified)
                        {
                            if (!IsSpawnSafe(player))
                            {
                                // Disconnect and quickly reroll connection silently so the UI doesn't visually glitch out
                                _ = Task.Run(async () => {
                                    var safeHost = Host;
                                    var safePort = Port;
                                    var safeName = PlayerName;
                                    GameController.Disconnect();
                                    await Task.Delay(50);
                                    await GameController.ConnectAsync(safeHost, safePort, safeName);
                                });
                                return;
                            }
                            _spawnVerified = true;
                        }
                    }
                    else if (player.died == true && !_showDeathScreen)
                    {
                        _showDeathScreen = true;
                        _spawnVerified = false;
                        // NO disconnect here! Server auto-respawns, or user clicks Respawn manually.
                    }
                }
                StateHasChanged();
            });
            GameController.OnStateUpdated += _onStateUpdatedHandler;
            _onDisconnectedHandler = () => _ = InvokeAsync(() => { 
                _status = "disconnected"; 
                if (!_showDeathScreen) StateHasChanged(); 
            });
            NetworkController.OnDisconnected += _onDisconnectedHandler;
        }
    }



    [JSInvokable]
    public void HandleKeyPress( string key )
    {
        // map keys to moving commands
        var cmd = key.ToLowerInvariant() switch
        {
            "w" => "up",
            "a" => "left",
            "s" => "down",
            "d" => "right",
            "arrowup" => "up",
            "arrowleft" => "left",
            "arrowdown" => "down",
            "arrowright" => "right",
            _ => null
        };

        if (cmd != null)
        {
            _ = GameController.SendMoveAsync(cmd);
        }
        Debug.WriteLine("key pressed: " + key + " -> " + cmd);
    }

    private void Respawn()
    {
        _showDeathScreen = false;
        _spawnVerified = false;
        _ = Reconnect();
    }

    private async Task Connect()
    {
        _showDeathScreen = false;
        // single-shot connect (no retries)
        try
        {
            _status = "connecting";
            StateHasChanged();
            await GameController.ConnectAsync(Host, Port, PlayerName);
            _status = "connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _status = "error: " + ex.Message;
            StateHasChanged();
        }
    }

    private async Task ConnectWithRetries(int maxAttempts = 6)
    {
        _showDeathScreen = false;
        _reconnectCts?.Cancel();
        _reconnectCts = new CancellationTokenSource();
        var ct = _reconnectCts.Token;
        _reconnectInProgress = true;
        try
        {
            for (int attempt = 0; attempt < maxAttempts && !ct.IsCancellationRequested; attempt++)
            {
                try
                {
                    _status = $"connecting (attempt {attempt + 1})";
                    StateHasChanged();
                    await GameController.ConnectAsync(Host, Port, PlayerName);
                    _status = "connected";
                    _reconnectInProgress = false;
                    StateHasChanged();
                    return;
                }
                catch (Exception)
                {
                    // compute backoff in ms
                    var delayMs = Math.Min(8000, 500 * (1 << Math.Min(attempt, 6)));
                    _reconnectCountdown = (int)Math.Ceiling(delayMs / 1000.0);
                    for (int s = _reconnectCountdown; s > 0 && !ct.IsCancellationRequested; s--)
                    {
                        _status = $"reconnect in {s}s (attempt {attempt + 1})";
                        StateHasChanged();
                        await Task.Delay(1000, ct);
                    }
                }
            }

            _status = "reconnect failed";
            _reconnectInProgress = false;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            _status = "reconnect cancelled";
            _reconnectInProgress = false;
            StateHasChanged();
        }
    }

    private Action? _onStateUpdatedHandler;
    private Action? _onDisconnectedHandler;
    private int? _centerTargetSnakeId = null;

    private async Task Reconnect()
    {
        // perform reconnect attempts with UI countdown
        await ConnectWithRetries();
    }

    public void Dispose()
    {
        try { _renderCts?.Cancel(); } catch { }
        if (_onStateUpdatedHandler != null) GameController.OnStateUpdated -= _onStateUpdatedHandler;
        if (_onDisconnectedHandler != null) NetworkController.OnDisconnected -= _onDisconnectedHandler;
    }

    // single Dispose implementation

    private async Task RenderLoopAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                try
                {
                    await DrawFrame();
                }
                catch (Exception ex)
                {
                    Debug.WriteLine("DrawFrame error: " + ex.Message);
                }

                await Task.Delay(16, ct);
            }
        }
        catch (TaskCanceledException) { }
    }

    private readonly string[] _colors = new[] { "red", "green", "blue", "orange", "purple", "brown", "magenta", "teal" };
    private class DeathAnim
    {
        public double ElapsedSeconds { get; set; } = 0.0;
        public IReadOnlyList<Point2D> Path { get; set; } = Array.Empty<Point2D>();
        public string Color { get; set; } = "orange";
        public bool IsFinished { get; set; } = false;
    }

    private readonly Dictionary<int, DeathAnim> _deathAnimations = new();

    // reconnect state
    private CancellationTokenSource? _reconnectCts;
    private bool _reconnectInProgress = false;
    private int _reconnectCountdown = 0;

    private bool _showSettings = false;
    private bool _drawGrid = true;
    private bool _highQualityTextures = true;

    private async Task DrawFrame()
    {
        if (_context == null) return;

        await _context.BeginBatchAsync();

        // clear based on settings
        if (_highQualityTextures)
        {
            await _context.SetFillStyleAsync("#7c9c45"); // grass green
        }
        else
        {
            await _context.SetFillStyleAsync("#e8f5ff"); // default blueish
        }
        
        await _context.FillRectAsync(0, 0, 1000, 1000);

        var worldSize = GameController.WorldSize ?? 1000;

        // determine center target: either selected player or self
        int centerX = 0, centerY = 0;
        Snake? centerSnake = null;
        if (_centerTargetSnakeId.HasValue)
        {
            centerSnake = GameController.GetSnakes().FirstOrDefault(s => s.snake == _centerTargetSnakeId.Value);
        }
        if (centerSnake == null)
        {
            centerSnake = GameController.GetPlayerSnake();
        }
        if (centerSnake?.body?.Count > 0)
        {
            var head = centerSnake.body[centerSnake.body.Count - 1];
            centerX = head.X;
            centerY = head.Y;
        }

        // clip and transform
        await _context.BeginPathAsync();
        await _context.RectAsync(0, 0, 1000, 1000);
        await _context.ClipAsync();
        await _context.SaveAsync();

        await _context.TranslateAsync(500, 500);
        await _context.TranslateAsync(-centerX, -centerY);

        if (_drawGrid && _highQualityTextures)
        {
            await _context.SetStrokeStyleAsync("rgba(0,0,0,0.05)");
            await _context.SetLineWidthAsync(2);
            await _context.BeginPathAsync();
            var hw = worldSize / 2;
            for (int i = -hw; i <= hw; i += 50)
            {
                await _context.MoveToAsync(i, -hw);
                await _context.LineToAsync(i, hw);
                await _context.MoveToAsync(-hw, i);
                await _context.LineToAsync(hw, i);
            }
            await _context.StrokeAsync();
        }

        // draw walls background/borders (Pass 1)
        await _context.SetFillStyleAsync(_highQualityTextures ? "#2a2c2f" : "#222222");
        foreach (var w in GameController.GetWalls())
        {
            if (w.p1 == null || w.p2 == null) continue;
            var x = (double)Math.Min(w.p1.X, w.p2.X) - 25;
            var y = (double)Math.Min(w.p1.Y, w.p2.Y) - 25;
            var wdt = (double)Math.Abs(w.p1.X - w.p2.X);
            var hgt = (double)Math.Abs(w.p1.Y - w.p2.Y);
            
            if (wdt == 0) { wdt = 50; hgt += 50; }
            else { hgt = 50; wdt += 50; }
            
            // Draw slightly larger rect to act as a border under the main fills
            await _context.FillRectAsync(x - 2, y - 2, wdt + 4, hgt + 4);
        }

        // draw walls interior (Pass 2)
        foreach (var w in GameController.GetWalls())
        {
            if (w.p1 == null || w.p2 == null) continue;
            var x = (double)Math.Min(w.p1.X, w.p2.X);
            var y = (double)Math.Min(w.p1.Y, w.p2.Y);
            var wdt = (double)Math.Abs(w.p1.X - w.p2.X);
            var hgt = (double)Math.Abs(w.p1.Y - w.p2.Y);
            
            if (wdt == 0)
            {
                x -= 25;
                y -= 25;
                wdt = 50;
                hgt += 50;
            }
            else
            {
                x -= 25;
                y -= 25;
                hgt = 50;
                wdt += 50;
            }
            
            if (_highQualityTextures)
            {
                await _context.SaveAsync();
                
                await _context.SetFillStyleAsync("#65696d");
                await _context.FillRectAsync(x, y, wdt, hgt);
                
                // Clip so bricks don't spill out
                await _context.BeginPathAsync();
                await _context.RectAsync(x, y, wdt, hgt);
                await _context.ClipAsync();

                // Draw brick pattern with individual lines to avoid overlapping stroke darkness
                await _context.SetStrokeStyleAsync("#3a3c3f");
                await _context.SetLineWidthAsync(2);
                await _context.BeginPathAsync();
                
                // Horizontal lines
                for (int by = (int)y; by <= (int)(y + hgt); by += 25)
                {
                    await _context.MoveToAsync(x, by);
                    await _context.LineToAsync(x + wdt, by);
                }
                
                // Vertical lines (staggered)
                for (int by = (int)y; by < (int)(y + hgt); by += 25)
                {
                    var offset = (Math.Abs(by) / 25) % 2 == 0 ? 0 : 12;
                    for (int bx = (int)x - offset; bx <= (int)(x + wdt) + 25; bx += 25)
                    {
                        await _context.MoveToAsync(bx, by);
                        await _context.LineToAsync(bx, by + 25);
                    }
                }
                await _context.StrokeAsync();
                
                await _context.RestoreAsync(); // restore from clip
            }
            else 
            {
                await _context.SetFillStyleAsync("#555555");
                await _context.FillRectAsync(x, y, wdt, hgt);
            }
        }

        // draw powerups
        foreach (var p in GameController.GetPowerups())
        {
            if (p.loc == null || p.died) continue;
            var pulse = _highQualityTextures ? Math.Abs(Math.Sin(DateTime.Now.TimeOfDay.TotalSeconds * 5)) * 3 : 0;
            
            await _context.SetFillStyleAsync("gold");
            await _context.BeginPathAsync();
            await _context.ArcAsync(p.loc.X, p.loc.Y, 8 + pulse, 0, Math.PI * 2);
            await _context.FillAsync();

            if (_highQualityTextures)
            {
                await _context.SetFillStyleAsync("yellow");
                await _context.BeginPathAsync();
                await _context.ArcAsync(p.loc.X, p.loc.Y, 4, 0, Math.PI * 2);
                await _context.FillAsync();
            }
        }

        // draw snakes (smoothed body + head, death animation)
        foreach (var s in GameController.GetSnakes())
        {
            if (s.dc == true) continue;

            var color = _colors[s.snake % _colors.Length];

            if (s.alive == true) 
            {
                // Clear any old death animations if the snake respawned with the same ID
                _deathAnimations.Remove(s.snake);
            }
            else if (s.died == true && !_deathAnimations.ContainsKey(s.snake))
            {
                _deathAnimations[s.snake] = new DeathAnim 
                { 
                    ElapsedSeconds = 0.0, 
                    Path = s.body?.ToList() ?? new List<Point2D>(),
                    Color = color
                };
            }

            if (s.alive != true || _deathAnimations.ContainsKey(s.snake)) continue;
            if (s.body == null || s.body.Count < 2) continue;

            // draw path exactly as the server specifies
            await _context.SetStrokeStyleAsync(color);
            await _context.SetLineWidthAsync(10);
            await _context.SetLineCapAsync(LineCap.Round);
            await _context.SetLineJoinAsync(LineJoin.Round);
            await _context.BeginPathAsync();
            var sf = s.body[0];
            await _context.MoveToAsync(sf.X, sf.Y);
            for (int i = 1; i < s.body.Count; i++)
            {
                var pt = s.body[i];
                await _context.LineToAsync(pt.X, pt.Y);
            }
            await _context.StrokeAsync();

            // draw head
            var head = s.body.Last();
            
            // optionally draw snake eyes if high quality
            if (_highQualityTextures)
            {
                await _context.SetFillStyleAsync("black");
                await _context.BeginPathAsync();
                await _context.ArcAsync(head.X, head.Y, 9, 0, Math.PI * 2);
                await _context.FillAsync();
            }

            await _context.SetFillStyleAsync("white");
            await _context.BeginPathAsync();
            await _context.ArcAsync(head.X, head.Y, 8, 0, Math.PI * 2);
            await _context.FillAsync();
            await _context.SetFillStyleAsync(color);
            await _context.BeginPathAsync();
            await _context.ArcAsync(head.X, head.Y, 6, 0, Math.PI * 2);
            await _context.FillAsync();

            if (!string.IsNullOrEmpty(s.name))
            {
                await _context.SetFillStyleAsync("white");
                await _context.SetFontAsync("bold 14px Arial");
                await _context.FillTextAsync($"{s.name}: {s.score}", head.X + 12, head.Y - 12);
            }
        }

        // process and draw death animations independently
        var oldGhosts = new List<int>();
        foreach (var kvp in _deathAnimations)
        {
            var id = kvp.Key;
            var anim = kvp.Value;
            if (anim.IsFinished) 
            {
                // Purge if the snake is no longer in the active list (e.g. disconnected)
                if (!GameController.GetSnakes().Any(s => s.snake == id)) 
                {
                    oldGhosts.Add(id);
                }
                continue;
            }
            var path = anim.Path;
            if (path == null || path.Count < 2)
            {
                anim.IsFinished = true;
                continue;
            }

            var head = path.Last();
            
            // Calculate total length
            double totalLength = 0;
            var lengths = new List<double>();
            for (int i = 0; i < path.Count - 1; i++)
            {
                var dx = path[i + 1].X - path[i].X;
                var dy = path[i + 1].Y - path[i].Y;
                var dist = Math.Sqrt(dx * dx + dy * dy);
                lengths.Add(dist);
                totalLength += dist;
            }
            
            // Explosion settings: 1 bit = 10 units of distance, explodes every 0.05s
            double bitDistance = 20.0;
            double explosionDelaySeconds = 0.05;
            double explosionSpeed = bitDistance / explosionDelaySeconds; // units per second
            
            double explodedLength = anim.ElapsedSeconds * explosionSpeed;
            double currentDist = 0;
            
            // Draw the unexploded body backwards from the tail to the explosion front
            await _context.SetStrokeStyleAsync(anim.Color);
            await _context.SetLineWidthAsync(10);
            await _context.SetLineCapAsync(LineCap.Round);
            await _context.SetLineJoinAsync(LineJoin.Round);
            await _context.BeginPathAsync();
            
            bool moved = false;
            for (int i = 0; i < path.Count - 1; i++)
            {
                var segLen = lengths[i];
                var segDistStart = totalLength - currentDist - segLen; // dist from head to path[i+1]
                var segDistEnd = totalLength - currentDist;            // dist from head to path[i]

                if (segDistEnd > explodedLength) // path[i] is unexploded
                {
                    if (!moved) 
                    {
                        await _context.MoveToAsync(path[i].X, path[i].Y);
                        moved = true;
                    }
                    
                    if (segDistStart > explodedLength) // path[i+1] is also unexploded
                    {
                        await _context.LineToAsync(path[i+1].X, path[i+1].Y);
                    }
                    else // Explosion splits this segment
                    {
                        var t = segLen > 0.001 ? (segDistEnd - explodedLength) / segLen : 0;
                        var endX = path[i].X + (path[i+1].X - path[i].X) * t;
                        var endY = path[i].Y + (path[i+1].Y - path[i].Y) * t;
                        await _context.LineToAsync(endX, endY);
                        break; // Nothing closer to the head is unexploded
                    }
                }
                currentDist += segLen;
            }
            if (moved)
            {
                await _context.StrokeAsync();
            }

            currentDist = 0; // reset for particles pass

            // Draw chain explosions along the body segments backwards
            for (int i = path.Count - 1; i > 0; i--)
            {
                var segLen = lengths[i - 1];
                double steps = Math.Max(1, Math.Ceiling(segLen / bitDistance)); 
                
                for (int j = 0; j <= steps; j++)
                {
                    var t = j / steps;
                    var ptDist = currentDist + (segLen * t); // distance from head
                    
                    var bitDetonationTime = ptDist / explosionSpeed;
                    var timeSinceExplosion = anim.ElapsedSeconds - bitDetonationTime;
                    
                    if (timeSinceExplosion >= 0 && timeSinceExplosion <= 0.6) // 0.6s particle lifespan
                    {
                        var bx = path[i].X + (path[i - 1].X - path[i].X) * t;
                        var by = path[i].Y + (path[i - 1].Y - path[i].Y) * t;
                        
                        var bAlpha = Math.Max(0, 1.0 - (timeSinceExplosion / 0.6));
                        var baseRadius = ptDist < bitDistance ? 20 : 5; // Head explosion is bigger
                        var expandFactor = ptDist < bitDistance ? 60 : 25; // Expand further if head
                        var bRadius = baseRadius + (timeSinceExplosion / 0.6) * expandFactor;
                        
                        await _context.SetGlobalAlphaAsync((float)bAlpha);
                        await _context.SetFillStyleAsync(anim.Color);
                        await _context.BeginPathAsync();
                        await _context.ArcAsync(bx, by, bRadius, 0, Math.PI * 2);
                        await _context.FillAsync();
                    }
                }
                currentDist += segLen;
            }
            
            await _context.SetGlobalAlphaAsync(1.0f); // Reset alpha

            // Advance frame time (16ms typical 60fps)
            anim.ElapsedSeconds += 0.016; 
            
            // allow full cleanup when wave has passed body by ~1 second
            var timeToFinishSnake = totalLength / explosionSpeed;
            if (anim.ElapsedSeconds > timeToFinishSnake + 1.0) 
            {
                anim.IsFinished = true;
            }
        }
        foreach (var id in oldGhosts)
        {
            _deathAnimations.Remove(id);
        }
        
        await _context.RestoreAsync();
        
        await _context.EndBatchAsync();
    }

}