    /// <summary>
    /// Infers the current heading direction from the snake's last two body segments.
    /// Returns null if the snake has fewer than two segments.
    /// </summary>
    private static string? GetSnakeHeading(GameController gc)
    {
        var snake = gc.GetRenderSnapshot().PlayerSnake;
        if (snake?.Body == null || snake.Body.Count < 2) return null;
        var head = snake.Body[^1];
        var neck = snake.Body[^2];
        var dx = head.X - neck.X;
        var dy = head.Y - neck.Y;
        if (dx == 0 && dy == 0) return null;
        return Math.Abs(dx) > Math.Abs(dy)
            ? (dx > 0 ? "right" : "left")
            : (dy > 0 ? "down" : "up");
    }

    /// <summary>
    /// Appends a direction command to the move queue (max 2 entries).
    /// Drops duplicates of the most recent queued direction.
    /// </summary>
    private static void EnqueueMove(List<string> queue, object queueLock, string cmd)
    {
        lock (queueLock)
        {
            if (queue.Count >= 2) return;
            if (queue.Count > 0 && queue[^1] == cmd) return;
            queue.Add(cmd);
        }
    }

    /// <summary>
    /// Dequeues the next valid move from the buffer, handling three special cases:
    /// cancel-pair (both directions undo each other), 180-reorder (send the valid
    /// intermediate turn first), and normal single/pair dequeue.
    /// </summary>
    /// <returns>The direction string to send, or null if no valid move is available.</returns>
    private static string? DequeueMove(List<string> queue, object queueLock, GameController gc, ref string? lastSentDir)
    {
        lock (queueLock)
        {
            if (queue.Count == 0) return null;

            var heading = lastSentDir ?? GetSnakeHeading(gc);

            if (queue.Count == 1)
            {
                var move = queue[0];
                queue.RemoveAt(0);
                if (heading != null && _opposites.TryGetValue(move, out var opp) && opp == heading)
                    return null;
                lastSentDir = move;
                return move;
            }

            var first = queue[0];
            var second = queue[1];
            bool firstIs180 = heading != null && _opposites.TryGetValue(first, out var o1) && o1 == heading;
            bool pairCancels = _opposites.TryGetValue(first, out var fo) && fo == second;

            // Two inputs that undo each other (e.g. down+up) — discard both.
            if (pairCancels)
            {
                queue.Clear();
                return null;
            }

            // 180 key pressed first (e.g. left while heading right, then down).
            // Reorder: send the valid intermediate turn now, re-queue the
            // originally-180 move which becomes valid after the turn.
            if (firstIs180)
            {
                queue.Clear();
                queue.Add(first);
                lastSentDir = second;
                return second;
            }

            // First move is valid — send it, leave second for next frame.
            queue.RemoveAt(0);
            lastSentDir = first;
            return first;
        }
    }

    // ==================== Connection ====================

    /// <summary>Loads open game sessions from SQL and preserves selection when possible.</summary>
    private Task RefreshOpenGamesAsync()
    {
        try
        {
            var selected = _selectedGameId;
            _openGames.Clear();
            _openGames.AddRange(ScoreDatabase.GetOpenGameSessions());

            if (selected.HasValue && _openGames.Any(g => g.GameId == selected.Value))
            {
                _selectedGameId = selected;
            }
            else
            {
                _selectedGameId = _openGames.FirstOrDefault()?.GameId;
            }

            _dbStatusMessage = _openGames.Count == 0
                ? "No active sessions are currently advertised."
                : $"{_openGames.Count} active session(s) available.";
        }
        catch (Exception ex)
        {
            _dbStatusMessage = "Unable to load games from the database.";
            SetFatalError("Database Unavailable", ex.Message);
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    /// <summary>Selects a game in the open-session list.</summary>
    private void SelectGame(int gameId)
    {
        _selectedGameId = gameId;
    }

    /// <summary>Dismisses the current full-screen error panel.</summary>
    private void DismissFatalError()
    {
        _fatalErrorTitle = null;
        _fatalErrorMessage = null;
    }

    /// <summary>Sets the full-screen error panel content.</summary>
    private void SetFatalError(string title, string message)
    {
        _fatalErrorTitle = title;
        _fatalErrorMessage = message;
    }

    /// <summary>Creates a new game endpoint advertisement and connects P1 to it.</summary>
    private Task CreateAndConnectGame() => ConnectToEndpoint(_defaultGameHost, _defaultGamePort, PlayerName, _p1SkinIndex, isP1: true, advertisedHost: _advertisedGameHost);

    /// <summary>Connects P1 to the selected advertised game endpoint.</summary>
    private Task ConnectSelectedGame()
    {
        var selected = _openGames.FirstOrDefault(g => g.GameId == _selectedGameId);
        if (selected == null)
        {
            _status = "Select a game first";
            SetFatalError("No Game Selected", "Choose an active game from the list or create a new one.");
            StateHasChanged();
            return Task.CompletedTask;
        }

        return ConnectToEndpoint(selected.Host, selected.Port, PlayerName, _p1SkinIndex, isP1: true);
    }

    /// <summary>Connects P2 to the selected advertised game endpoint.</summary>
    private Task ConnectP2SelectedGame()
    {
        var selected = _openGames.FirstOrDefault(g => g.GameId == _selectedGameId);
        if (selected == null)
        {
            _p2Status = "Select a game first";
            SetFatalError("No Game Selected", "Choose an active game from the list before connecting Player 2.");
            StateHasChanged();
            return Task.CompletedTask;
        }

        return ConnectToEndpoint(selected.Host, selected.Port, Player2Name, _p2SkinIndex, isP1: false);
    }

    /// <summary>Connect helper that routes to P1/P2 controller paths.</summary>
    private async Task ConnectToEndpoint(string host, int port, string playerName, int skinIndex, bool isP1, string? advertisedHost = null)
    {
        if (isP1)
        {
            _showDeathScreen = false;
            lock (_p1MoveLock) _p1MoveQueue.Clear();
            _p1LastSentDir = null;
            _p1Ready = false;
            if (_splitScreen) _p1SidebarOpen = false;
            else _sidebarOpen = false;
            _renderer.ClearWallCache(GameController);
            GameController.Disconnect();
        }
        else
        {
            if (_p2Game == null) return;
            _p2ShowDeath = false;
            lock (_p2MoveLock) _p2MoveQueue.Clear();
            _p2LastSentDir = null;
            _p2Ready = false;
            _renderer.ClearWallCache(_p2Game);
            _p2SidebarOpen = false;
            _p2Game.Disconnect();
        }

        var hostCandidates = HostCandidateParser.Parse(host);
        hostCandidates = HostCandidateParser.FilterBlockedHosts(hostCandidates, _blockedGameHosts);
        if (hostCandidates.Count == 0)
        {
            if (isP1)
            {
                _status = "Error: invalid host";
            }
            else
            {
                _p2Status = "Error: invalid host";
            }

            SetFatalError("Connection Failed", "No valid host candidates were provided.");
            StateHasChanged();
            return;
        }

        Exception? lastException = null;
        string? connectedHost = null;

        try
        {
            if (isP1)
            {
                _status = "Connecting...";
            }
            else
            {
                _p2Status = "Connecting...";
            }

            StateHasChanged();

            foreach (var candidateHost in hostCandidates)
            {
                try
                {
                    if (isP1)
                    {
                        await GameController.ConnectAsync(candidateHost, port, playerName, skinIndex, advertisedHost);
                    }
                    else if (_p2Game != null)
                    {
                        await _p2Game.ConnectAsync(candidateHost, port, playerName, skinIndex, advertisedHost);
                    }

                    connectedHost = candidateHost;
                    break;
                }
                catch (Exception ex)
                {
                    lastException = ex;
                }
            }

            if (connectedHost == null)
            {
                throw lastException ?? new InvalidOperationException("No host candidates succeeded.");
            }

            if (isP1)
            {
                _status = "Connected";
            }
            else
            {
                _p2Status = "Connected";
            }

            DismissFatalError();
            await RefreshOpenGamesAsync();
        }
        catch (Exception ex)
        {
            var attemptedHosts = string.Join(", ", hostCandidates);
            if (isP1)
            {
                _status = "Error: " + ex.Message;
            }
            else
            {
                _p2Status = "Error: " + ex.Message;
            }

            SetFatalError("Connection Failed", $"Could not connect to any host [{attemptedHosts}] on port {port}. {ex.Message}");
            StateHasChanged();
        }
    }

    /// <summary>Disconnects any existing P1 session and connects with current settings.</summary>
    private async Task Connect()
    {
        await ConnectToEndpoint(Host, Port, PlayerName, _p1SkinIndex, isP1: true);
    }

    /// <summary>Disconnects any existing P2 session and connects with current settings.</summary>
    private async Task ConnectP2()
    {
        await ConnectToEndpoint(Host, Port, Player2Name, _p2SkinIndex, isP1: false);
    }

    /// <summary>Sends a respawn command for P1 and dismisses the death overlay.</summary>
    private void RespawnP1()
    {
        _showDeathScreen = false;
        if (_splitScreen) _p1SidebarOpen = false; else _sidebarOpen = false;
        lock (_p1MoveLock) _p1MoveQueue.Clear();
        _p1LastSentDir = null;
        _ = GameController.SendMoveAsync("respawn");
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>Sends a respawn command for P2 and dismisses the death overlay.</summary>
    private void RespawnP2()
    {
        _p2ShowDeath = false;
        _p2SidebarOpen = false;
        lock (_p2MoveLock) _p2MoveQueue.Clear();
        _p2LastSentDir = null;
        if (_p2Game != null) _ = _p2Game.SendMoveAsync("respawn");
        _ = InvokeAsync(StateHasChanged);
    }

