        letter-spacing: 4px;
    }
    .death-scores {
        background: rgba(255,255,255,0.07);
        border-radius: 10px;
        padding: 16px 24px;
        min-width: 220px;
    }
    .death-scores h3 {
        margin: 0 0 10px;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.7;
    }
    .death-scores ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .death-scores li {
        display: flex;
        justify-content: space-between;
        padding: 5px 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        font-size: 1rem;
