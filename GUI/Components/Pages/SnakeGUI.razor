    .snake-sidebar input[type="number"],
    .snake-sidebar input:not([type]) {
        width: 100%;
        padding: 6px 8px;
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 4px;
        background: rgba(255,255,255,0.08);
        color: #fff;
        font-size: 0.85rem;
