@page "/snake"
@layout GUI.Components.Layout.EmptyLayout
@implements IDisposable
@rendermode InteractiveServer
@using Blazor.Extensions
@using Blazor.Extensions.Canvas
@using Blazor.Extensions.Canvas.Canvas2D
@using System.Diagnostics
@using GUI.Components.Controllers
@using GUI.Components.Models
@using System.Linq
@inject IJSRuntime JsRuntime;
@inject GameController GameController
@inject GUI.Components.Controllers.NetworkController NetworkController

<PageTitle>Snake</PageTitle>

@* ── Sidebar Toggle ── *@
<button class="sidebar-toggle" @onclick="(() => _sidebarOpen = !_sidebarOpen)">
    @(_sidebarOpen ? "✕" : "☰")
</button>

@* ── Sidebar ── *@
<div class="snake-sidebar @(_sidebarOpen ? "open" : "")">
    <h2 style="margin:0 0 12px; font-size:1.3rem; letter-spacing:1px;">SNAKE</h2>

    <div class="field-group">
        <label>Host</label>
        <input @bind="Host" />
    </div>
    <div class="field-group">
        <label>Port</label>
        <input type="number" @bind="Port" />
    </div>
    <div class="field-group">
        <label>@(_splitScreen ? "P1 Name" : "Name")</label>
        <input @bind="PlayerName" />
    </div>

    <div style="display:flex; gap:6px; margin-top:8px;">
        <button class="btn-snake" @onclick="(() => Connect())">@(_splitScreen ? "Connect P1" : "Connect")</button>
        <button class="btn-snake btn-secondary" @onclick="(() => Reconnect())">Reconnect</button>
    </div>

    <div class="status-line">@_status</div>

    <div style="margin-top:12px; border-top:1px solid rgba(255,255,255,0.1); padding-top:10px;">
        <label class="toggle"><input type="checkbox" @bind="_highQualityTextures" /> High Quality</label>
        <label class="toggle"><input type="checkbox" @bind="_drawGrid" /> Grid Overlay</label>
        <label class="toggle"><input type="checkbox" @bind="_showScoreboard" /> Scoreboard</label>
        <label class="toggle"><input type="checkbox" @bind="_splitScreen" /> Split Screen (2P)</label>
    </div>

    @if (_splitScreen)
    {
    <div style="margin-top:12px; border-top:1px solid rgba(255,255,255,0.1); padding-top:10px;">
        <strong style="font-size:0.85rem; text-transform:uppercase; letter-spacing:1px; opacity:0.7;">Player 2 (Arrows)</strong>
        <div class="field-group" style="margin-top:6px;">
            <label>P2 Name</label>
            <input @bind="Player2Name" />
        </div>
        <div style="display:flex; gap:6px; margin-top:8px;">
            <button class="btn-snake" @onclick="ConnectP2">Connect P2</button>
        </div>
        <div class="status-line">@_p2Status</div>
    </div>
    }

</div>

@* ── Canvas ── *@
<div id="snakeCanvas" style="position:fixed; inset:0; z-index:1; background:#7c9c45; overflow:hidden;">
    <BECanvas Width="1920" Height="1080" @ref="_canvasReference"></BECanvas>
</div>

@* ── Scoreboard Overlay ── *@
@if (_showScoreboard && GameController.PlayerId.HasValue)
{
    var sbStyle = GetScoreboardStyle();
    <div class="scoreboard-overlay @(sbStyle.dither ? "scoreboard-dithered" : "")" style="opacity: @sbStyle.opacity.ToString("F2");">
        <strong>SCOREBOARD</strong>
        <ul>
            @foreach (var s in GameController.GetSnakes().Where(x => x.Alive == true).OrderByDescending(x => x.Score ?? 0))
            {
                <li @onclick="(() => { _centerTargetSnakeId = s.Id; })" class="@(s.Id == GameController.PlayerId ? "self" : "")">
                    <span>@(s.Name ?? "?")</span>
                    <span>@(s.Score ?? 0)</span>
                </li>
            }
        </ul>
    </div>
}

@* ── Death Overlay ── *@
@if (_showDeathScreen)
{
    <div class="death-overlay" style="@(_splitScreen ? "right:50%; left:0;" : "")">
        <h1>GAME OVER</h1>
        <div class="death-scores">
            <h3>High Scores</h3>
            <ul>
                @foreach (var s in GameController.GetSnakes().OrderByDescending(x => x.Score ?? 0).Take(5))
                {
                    <li>
                        <span>@(s.Name ?? "Anonymous")</span>
                        <span>@(s.Score ?? 0)</span>
                    </li>
                }
            </ul>
        </div>
        <button class="btn-respawn" @onclick="RespawnP1">Respawn</button>
        <span class="respawn-hint">@(_splitScreen ? "or press Left Shift" : "or press Shift")</span>
    </div>
}
@if (_p2ShowDeath && _splitScreen)
{
    <div class="death-overlay" style="left:50%; right:0;">
        <h1>GAME OVER</h1>
        <div class="death-scores">
            <h3>High Scores</h3>
            <ul>
                @foreach (var s in (_p2Game?.GetSnakes() ?? Array.Empty<Snake>()).OrderByDescending(x => x.Score ?? 0).Take(5))
                {
                    <li>
                        <span>@(s.Name ?? "Anonymous")</span>
                        <span>@(s.Score ?? 0)</span>
                    </li>
                }
            </ul>
        </div>
        <button class="btn-respawn" @onclick="RespawnP2">Respawn</button>
        <span class="respawn-hint">or press Right Shift</span>
    </div>
}

@* ── Scoped Styles ── *@
