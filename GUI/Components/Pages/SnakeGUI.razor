        {
            _viewW = dims[0];
            _viewH = dims[1];
        }
    }

    [JSInvokable]
    public void HandleKeyPress(string key)
    {
        // Tab: P1 death menu toggle
        if (key == "Tab")
        {
            if (_showDeathScreen)
            {
                _p1ShowMenu = !_p1ShowMenu;
                if (_p1ShowMenu) _p1MenuFocus = 0;
                _ = InvokeAsync(StateHasChanged);
            }
            return;
        }

        // Delete/Backspace: P2 death menu toggle (or P1 if single player)
        if (key == "Delete" || key == "Backspace")
        {
            if (_splitScreen)
            {
                if (_p2ShowDeath)
                {
                    _p2ShowMenu = !_p2ShowMenu;
                    if (_p2ShowMenu) _p2MenuFocus = 0;
                    _ = InvokeAsync(StateHasChanged);
                }
            }
            else
            {
                if (_showDeathScreen)
                {
                    _p1ShowMenu = !_p1ShowMenu;
                    if (_p1ShowMenu) _p1MenuFocus = 0;
                    _ = InvokeAsync(StateHasChanged);
                }
            }
            return;
        }

        // Enter: P2 confirm in menu, or P1 confirm in single player menu
        if (key == "Enter")
        {
            if (_splitScreen && _p2ShowMenu)
            {
                ActivateP2MenuItem();
                return;
            }
            if (!_splitScreen && _p1ShowMenu)
            {
                ActivateP1MenuItem();
                return;
            }
            return;
        }

        // Shift: confirm in menu, respawn if dead, or connect if not yet connected
        if (key == "ShiftLeft")
        {
            if (_p1ShowMenu) { ActivateP1MenuItem(); return; }
            if (_showDeathScreen) { RespawnP1(); return; }
            if (!GameController.PlayerId.HasValue && _status != "Connecting...")
            { _ = InvokeAsync(() => Connect()); return; }
            return;
        }
        if (key == "ShiftRight")
        {
            if (_splitScreen)
            {
                if (_p2ShowMenu) { ActivateP2MenuItem(); return; }
                if (_p2ShowDeath) { RespawnP2(); return; }
                if (_p2Game != null && !_p2Game.PlayerId.HasValue && _p2Status != "Connecting...")
                { _ = InvokeAsync(() => ConnectP2()); return; }
                return;
            }
            if (_p1ShowMenu) { ActivateP1MenuItem(); return; }
            if (_showDeathScreen) { RespawnP1(); return; }
            if (!GameController.PlayerId.HasValue && _status != "Connecting...")
            { _ = InvokeAsync(() => Connect()); return; }
            return;
        }

        // WASD → P1 menu nav or movement
        var p1Cmd = key.ToLowerInvariant() switch
        {
            "w" => "up", "a" => "left", "s" => "down", "d" => "right",
            _ => (string?)null
        };
        if (p1Cmd != null)
        {
            if (_p1ShowMenu) { HandleMenuNav(ref _p1MenuFocus, ref _p1SkinIndex, p1Cmd); return; }
            if (_showDeathScreen || !_p1Ready) return;
            EnqueueMove(_p1MoveQueue, _p1MoveLock, p1Cmd);
            return;
        }

        // Arrow keys → P2 (split) or P1 (single), menu nav or movement
        var arrowCmd = key switch
        {
            "ArrowUp" => "up", "ArrowLeft" => "left",
            "ArrowDown" => "down", "ArrowRight" => "right",
            _ => (string?)null
        };
        if (arrowCmd == null) return;

        if (_splitScreen && _p2Game != null)
        {
            if (_p2ShowMenu) { HandleMenuNav(ref _p2MenuFocus, ref _p2SkinIndex, arrowCmd); return; }
            if (_p2ShowDeath || !_p2Ready) return;
            EnqueueMove(_p2MoveQueue, _p2MoveLock, arrowCmd);
        }
        else
        {
            if (_p1ShowMenu) { HandleMenuNav(ref _p1MenuFocus, ref _p1SkinIndex, arrowCmd); return; }
            if (_showDeathScreen || !_p1Ready) return;
            EnqueueMove(_p1MoveQueue, _p1MoveLock, arrowCmd);
        }
    }

    private void HandleMenuNav(ref int focus, ref int skinIndex, string dir)
    {
        switch (dir)
        {
            case "up": focus = Math.Max(0, focus - 1); break;
            case "down": focus = Math.Min(2, focus + 1); break;
            case "left":
                if (focus == 0) skinIndex = (skinIndex - 1 + SnakeSkin.AllSkins.Length) % SnakeSkin.AllSkins.Length;
                break;
            case "right":
                if (focus == 0) skinIndex = (skinIndex + 1) % SnakeSkin.AllSkins.Length;
                break;
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private void ActivateP1MenuItem()
    {
        switch (_p1MenuFocus)
        {
            case 0: break; // skin — already handled by left/right
            case 1: _p1ShowMenu = false; RespawnP1(); break;
            case 2: _p1ShowMenu = false; _ = InvokeAsync(() => Connect()); break;
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private void ActivateP2MenuItem()
    {
        switch (_p2MenuFocus)
        {
            case 0: break;
            case 1: _p2ShowMenu = false; RespawnP2(); break;
            case 2: _p2ShowMenu = false; _ = InvokeAsync(() => ConnectP2()); break;
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private static string? GetSnakeHeading(GameController gc)
    {
        var snake = gc.GetPlayerSnake();
        if (snake?.Body == null || snake.Body.Count < 2) return null;
        var head = snake.Body[^1];
        var neck = snake.Body[^2];
        var dx = head.X - neck.X;
        var dy = head.Y - neck.Y;
        if (dx == 0 && dy == 0) return null;
        return Math.Abs(dx) > Math.Abs(dy)
            ? (dx > 0 ? "right" : "left")
            : (dy > 0 ? "down" : "up");
    }

    private static void EnqueueMove(List<string> queue, object queueLock, string cmd)
    {
        lock (queueLock)
        {
            if (queue.Count >= 2) return;
            if (queue.Count > 0 && queue[^1] == cmd) return;
            queue.Add(cmd);
        }
    }

    private static string? DequeueMove(List<string> queue, object queueLock, GameController gc, ref string? lastSentDir)
    {
        lock (queueLock)
        {
            if (queue.Count == 0) return null;

            var heading = lastSentDir ?? GetSnakeHeading(gc);

            if (queue.Count == 1)
            {
                var move = queue[0];
                queue.RemoveAt(0);
                if (heading != null && _opposites.TryGetValue(move, out var opp) && opp == heading)
                    return null;
                lastSentDir = move;
                return move;
            }

            var first = queue[0];
            var second = queue[1];
            bool firstIs180 = heading != null && _opposites.TryGetValue(first, out var o1) && o1 == heading;
            bool secondIs180 = heading != null && _opposites.TryGetValue(second, out var o2) && o2 == heading;

            if (firstIs180 && !secondIs180)
            {
                queue.RemoveAt(1);
                lastSentDir = second;
                return second;
            }

            queue.RemoveAt(0);
            if (firstIs180) return null;
            lastSentDir = first;
            return first;
        }
    }

    // ==================== Connection ====================

    private async Task Connect(bool closeSidebar = true)
    {
        _showDeathScreen = false;
        _p1ShowMenu = false;
        lock (_p1MoveLock) _p1MoveQueue.Clear();
        _p1LastSentDir = null;
        _p1Ready = false;
        _p1Cam.Reset();
        if (closeSidebar) _sidebarOpen = false;
        _wallCaches.Remove(GameController);
        GameController.Disconnect();
        try
        {
            _status = "Connecting...";
            StateHasChanged();
            await GameController.ConnectAsync(Host, Port, PlayerName, _p1SkinIndex);
            _status = "Connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _status = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    private Task Reconnect() => Connect(closeSidebar: false);

    private async Task ConnectP2()
    {
        if (_p2Game == null) return;
        _p2ShowDeath = false;
        _p2ShowMenu = false;
        lock (_p2MoveLock) _p2MoveQueue.Clear();
        _p2LastSentDir = null;
        _p2Ready = false;
        _p2Cam.Reset();
        _wallCaches.Remove(_p2Game);
        _sidebarOpen = false;
        _p2Game.Disconnect();
        try
        {
            _p2Status = "Connecting...";
            StateHasChanged();
            await _p2Game.ConnectAsync(Host, Port, Player2Name, _p2SkinIndex);
            _p2Status = "Connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _p2Status = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    private void RespawnP1()
    {
        _showDeathScreen = false;
        _p1ShowMenu = false;
        lock (_p1MoveLock) _p1MoveQueue.Clear();
        _p1LastSentDir = null;
        _ = GameController.SendMoveAsync("respawn");
        _ = InvokeAsync(StateHasChanged);
    }

    private void RespawnP2()
    {
        _p2ShowDeath = false;
        _p2ShowMenu = false;
        lock (_p2MoveLock) _p2MoveQueue.Clear();
        _p2LastSentDir = null;
        if (_p2Game != null) _ = _p2Game.SendMoveAsync("respawn");
        _ = InvokeAsync(StateHasChanged);
    }

    private void Respawn() => RespawnP1();

    // ==================== Game State ====================

    private void OnP1Died()
    {
        if (_showDeathScreen) return;
        _showDeathScreen = true;
        _status = "Game Over";

        var player = GameController.GetPlayerSnake();
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _frozenCameraX = head.X;
            _frozenCameraY = head.Y;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    private void OnP2Died()
    {
        if (_p2ShowDeath) return;
        _p2ShowDeath = true;
        _p2Status = "Game Over";

        var player = _p2Game?.GetPlayerSnake();
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _p2FrozenCamX = head.X;
            _p2FrozenCamY = head.Y;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    // ==================== Render Loop ====================

    private async Task RenderLoopAsync(CancellationToken ct)
    {
        _frameStopwatch.Start();
        int tick = 0;
        var frameSw = new Stopwatch();
        try
        {
            while (!ct.IsCancellationRequested)
            {
                frameSw.Restart();
                try
                {
                    // P1 move
                    var move1 = DequeueMove(_p1MoveQueue, _p1MoveLock, GameController, ref _p1LastSentDir);
                    if (move1 != null) _ = GameController.SendMoveAsync(move1);

                    // P2 move
                    if (_splitScreen && _p2Game != null)
                    {
                        var move2 = DequeueMove(_p2MoveQueue, _p2MoveLock, _p2Game, ref _p2LastSentDir);
                        if (move2 != null) _ = _p2Game.SendMoveAsync(move2);
                    }

                    await DrawFrame();

                    // Mark players ready once their snake has been rendered
                    if (!_p1Ready && GameController.GetPlayerSnake()?.Body?.Count > 0)
                        _p1Ready = true;
                    if (!_p2Ready && _p2Game?.GetPlayerSnake()?.Body?.Count > 0)
                        _p2Ready = true;

                    if (++tick % 6 == 0) await InvokeAsync(StateHasChanged);
                }
                catch { /* skip frame */ }
                var drawMs = (int)frameSw.ElapsedMilliseconds;
                var remaining = FrameDelayMs - drawMs;
                if (remaining > 0)
                    await Task.Delay(remaining, ct);
            }
        }
        catch (TaskCanceledException) { }
    }

    // ==================== Drawing ====================

    private async Task DrawFrame()
    {
        if (_context == null) return;

        var elapsed = _frameStopwatch.Elapsed.TotalSeconds;
        _frameStopwatch.Restart();

        await _context.BeginBatchAsync();
        await _context.SetFillStyleAsync(_highQualityTextures ? "#7c9c45" : "#e8f5ff");
        await _context.FillRectAsync(0, 0, _viewW, _viewH);

        if (_splitScreen && _p2Game != null)
        {
            var halfW = _viewW / 2;

            // Resolve P1 center target
            if (_centerTargetSnakeId.HasValue)
            {
                if (!GameController.GetSnakes().Any(s => s.Id == _centerTargetSnakeId.Value))
                    _centerTargetSnakeId = null;
            }

            // Left viewport — P1 (WASD)
            await DrawViewport(GameController, _p1DeathAnims, _showDeathScreen,
                _frozenCameraX, _frozenCameraY, _centerTargetSnakeId,
                0, 0, halfW, _viewH, elapsed, _p1Cam, SnakeSkin.AllSkins[_p1SkinIndex]);

            // Right viewport — P2 (Arrows)
            await DrawViewport(_p2Game, _p2DeathAnims, _p2ShowDeath,
                _p2FrozenCamX, _p2FrozenCamY, null,
                halfW, 0, halfW, _viewH, elapsed, _p2Cam, SnakeSkin.AllSkins[_p2SkinIndex]);

            // Divider line
            await _context.SetStrokeStyleAsync("rgba(255,255,255,0.4)");
            await _context.SetLineWidthAsync(2);
            await _context.BeginPathAsync();
            await _context.MoveToAsync(halfW, 0);
            await _context.LineToAsync(halfW, _viewH);
            await _context.StrokeAsync();

            // Player labels
            await _context.SetFillStyleAsync("rgba(255,255,255,0.5)");
            await _context.SetFontAsync("bold 16px Arial");
            await _context.FillTextAsync("P1 (WASD)", 10, 24);
            await _context.FillTextAsync("P2 (Arrows)", halfW + 10, 24);
        }
        else
        {
            // Resolve center target
            if (_centerTargetSnakeId.HasValue)
            {
                if (!GameController.GetSnakes().Any(s => s.Id == _centerTargetSnakeId.Value))
                    _centerTargetSnakeId = null;
            }

            await DrawViewport(GameController, _p1DeathAnims, _showDeathScreen,
                _frozenCameraX, _frozenCameraY, _centerTargetSnakeId,
                0, 0, _viewW, _viewH, elapsed, _p1Cam, SnakeSkin.AllSkins[_p1SkinIndex]);
        }

        await _context.EndBatchAsync();

        // Redraw skin previews when selection changes
        if (_p1SkinIndex != _lastP1PreviewSkin)
        {
            _p1PreviewCtx ??= _p1PreviewRef != null ? await _p1PreviewRef.CreateCanvas2DAsync() : null;
            if (_p1PreviewCtx != null) { await DrawSkinPreview(_p1PreviewCtx, SnakeSkin.AllSkins[_p1SkinIndex]); _lastP1PreviewSkin = _p1SkinIndex; }
        }
        if (_splitScreen && _p2SkinIndex != _lastP2PreviewSkin)
        {
            _p2PreviewCtx ??= _p2PreviewRef != null ? await _p2PreviewRef.CreateCanvas2DAsync() : null;
            if (_p2PreviewCtx != null) { await DrawSkinPreview(_p2PreviewCtx, SnakeSkin.AllSkins[_p2SkinIndex]); _lastP2PreviewSkin = _p2SkinIndex; }
        }

        // Update scoreboard dither mask every frame via JS (bypasses Blazor render cycle)
        if (_showScoreboard && GameController.PlayerId.HasValue)
        {
            double ditherR = ComputeDitherRadius();
            await JsRuntime.InvokeVoidAsync("updateScoreboardDither", ditherR);
        }
    }

    private async Task DrawViewport(
        GameController gc, Dictionary<int, DeathAnim> deathAnims,
        bool showDeath, int frozenCamX, int frozenCamY, int? centerTargetId,
        int vx, int vy, int vw, int vh, double elapsed, CameraState cam, SnakeSkin playerSkin)
    {
        var worldSize = gc.WorldSize ?? 2000;

        Snake? centerSnake = null;
        if (centerTargetId.HasValue)
            centerSnake = gc.GetSnakes().FirstOrDefault(s => s.Id == centerTargetId.Value);
        centerSnake ??= gc.GetPlayerSnake();

        double targetCamX = 0, targetCamY = 0;
        if (showDeath) { targetCamX = frozenCamX; targetCamY = frozenCamY; }
        else if (centerSnake?.Body?.Count > 0)
        {
            var head = centerSnake.Body[^1];
            targetCamX = head.X;
            targetCamY = head.Y;
        }

        var halfWorld = worldSize / 2;
        var minCx = -halfWorld + vw / 2;
        var maxCx = halfWorld - vw / 2;
        var minCy = -halfWorld + vh / 2;
        var maxCy = halfWorld - vh / 2;
        if (minCx < maxCx) targetCamX = Math.Clamp(targetCamX, minCx, maxCx);
        else targetCamX = 0;
        if (minCy < maxCy) targetCamY = Math.Clamp(targetCamY, minCy, maxCy);
        else targetCamY = 0;

        // Smooth camera lerp — use exponential decay for frame-rate-independent smoothing
        if (!cam.Initialized) { cam.X = targetCamX; cam.Y = targetCamY; cam.Initialized = true; }
        else
        {
            double smoothing = 8.0; // lower = smoother, higher = snappier
            double lerpFactor = 1.0 - Math.Exp(-smoothing * elapsed);
            cam.X += (targetCamX - cam.X) * lerpFactor;
            cam.Y += (targetCamY - cam.Y) * lerpFactor;
        }

        await _context!.SaveAsync();
        await _context.BeginPathAsync();
        await _context.RectAsync(vx, vy, vw, vh);
        await _context.ClipAsync();

        var camX = vx + vw / 2.0 - cam.X;
        var camY = vy + vh / 2.0 - cam.Y;
        await _context.TranslateAsync(camX, camY);

        // Track P1 head screen position for scoreboard dithering
        if (gc == GameController)
        {
            var playerSnake = gc.GetPlayerSnake();
            if (playerSnake?.Body?.Count > 0)
            {
                var h = playerSnake.Body[^1];
                _p1HeadScreenX = h.X + camX;
                _p1HeadScreenY = h.Y + camY;
            }
        }

        if (_drawGrid && _highQualityTextures)
            await DrawGrid(worldSize);

        await DrawDeathAnimations(elapsed, deathAnims);
        await DrawWalls(gc);
        await DrawPowerups(gc);
        await DrawSnakes(gc, deathAnims, showDeath, playerSkin);

        await _context.RestoreAsync();
    }

    private async Task DrawGrid(int worldSize)
    {
        await _context!.SetStrokeStyleAsync("rgba(0,0,0,0.05)");
        await _context.SetLineWidthAsync(2);
        await _context.BeginPathAsync();
        var hw = worldSize / 2;
        var gs = GridSpacing;
        for (int i = -hw; i <= hw; i += gs)
        {
            await _context.MoveToAsync(i, -hw);
            await _context.LineToAsync(i, hw);
        }
        for (int i = -hw; i <= hw; i += gs)
        {
            await _context.MoveToAsync(-hw, i);
            await _context.LineToAsync(hw, i);
        }
        await _context.StrokeAsync();
    }

    private async Task DrawDeathAnimations(double elapsed, Dictionary<int, DeathAnim> deathAnims)
    {
        foreach (var (id, anim) in deathAnims)
        {
            if (anim.IsFinished) continue;

            var path = anim.Path;
            if (path == null || path.Count < 2) { anim.IsFinished = true; continue; }

            double totalLength = 0;
            var lengths = new List<double>();
            for (int i = 0; i < path.Count - 1; i++)
            {
                var dx = path[i + 1].X - path[i].X;
                var dy = path[i + 1].Y - path[i].Y;
                lengths.Add(Math.Sqrt(dx * dx + dy * dy));
                totalLength += lengths[^1];
            }

            double explosionSpeed = BitDistance / ExplosionDelay;
            double explodedLength = anim.ElapsedSeconds * explosionSpeed;
            double currentDist = 0;

            // Build remaining body points
            var remainPts = new List<Point2D>();
            for (int i = 0; i < path.Count - 1; i++)
            {
                var segLen = lengths[i];
                var segDistEnd = totalLength - currentDist;
                if (segDistEnd > explodedLength)
                {
                    if (remainPts.Count == 0) remainPts.Add(path[i]);
                    if (segDistEnd - segLen > explodedLength)
                        remainPts.Add(path[i + 1]);
                    else
                    {
                        var t = segLen > 0.001 ? (segDistEnd - explodedLength) / segLen : 0;
                        remainPts.Add(new Point2D(
                            (int)Math.Round(path[i].X + (path[i + 1].X - path[i].X) * t),
                            (int)Math.Round(path[i].Y + (path[i + 1].Y - path[i].Y) * t)));
                        break;
                    }
                }
                currentDist += segLen;
            }

            // Draw remaining body with full skin (outline + fill + pattern + head)
            if (remainPts.Count >= 2)
            {
                await DrawSnakeBody(_context!, remainPts, anim.Skin);
            }

            // Explosion particles
            currentDist = 0;
            bool headParticleDone = false;
            for (int i = path.Count - 1; i > 0; i--)
            {
                var segLen = lengths[i - 1];
                double steps = Math.Max(1, Math.Ceiling(segLen / BitDistance));
                for (int j = 0; j <= steps; j++)
                {
                    var t = j / steps;
                    var ptDist = currentDist + segLen * t;
                    var timeSinceExplosion = anim.ElapsedSeconds - ptDist / explosionSpeed;

                    if (timeSinceExplosion >= 0 && timeSinceExplosion <= ParticleLifespan)
                    {
                        var bx = path[i].X + (path[i - 1].X - path[i].X) * t;
                        var by = path[i].Y + (path[i - 1].Y - path[i].Y) * t;
                        var bAlpha = Math.Max(0, 1.0 - timeSinceExplosion / ParticleLifespan);
                        bool isHead = !headParticleDone && ptDist < 1.0;
                        if (isHead) headParticleDone = true;
                        var baseRadius = isHead ? 10 : 3;
                        var expandFactor = isHead ? 25 : 12;
                        var bRadius = baseRadius + timeSinceExplosion / ParticleLifespan * expandFactor;

                        await _context!.SetGlobalAlphaAsync((float)bAlpha);
                        await _context.SetFillStyleAsync(anim.Skin.DeathColor);
                        await _context.BeginPathAsync();
                        await _context.ArcAsync(bx, by, bRadius, 0, Math.PI * 2);
                        await _context.FillAsync();
                    }
                }
                currentDist += segLen;
            }
            await _context!.SetGlobalAlphaAsync(1.0f);

            anim.ElapsedSeconds += elapsed;
            if (anim.ElapsedSeconds > totalLength / explosionSpeed + 1.0)
                anim.IsFinished = true;
        }
    }

    private async Task DrawWalls(GameController gc)
    {
        var ctx = _context;
        if (ctx == null) return;

        var walls = gc.GetWalls();
        const int bs = BrickSize;

        if (!_highQualityTextures)
        {
            await ctx.SetFillStyleAsync("#555555");
            foreach (var w in walls)
            {
                if (w.Point1 == null || w.Point2 == null) continue;
                var (x, y, wdt, hgt) = WallRect(w);
                await ctx.FillRectAsync(x, y, wdt, hgt);
            }
            return;
        }

        // Cache brick grid cells
        if (!_wallCaches.TryGetValue(gc, out var occupied) ||
            (occupied.Count == 0 && walls.Count > 0))
        {
            occupied = new HashSet<(int cx, int cy)>();
            foreach (var w in walls)
            {
                if (w.Point1 == null || w.Point2 == null) continue;
                var (rx, ry, rw, rh) = WallRect(w);
                int cols = (int)Math.Round(rw / bs);
                int rows = (int)Math.Round(rh / bs);
                int startCx = (int)Math.Round(rx / bs);
                int startCy = (int)Math.Round(ry / bs);
                for (int r = 0; r < rows; r++)
                    for (int c = 0; c < cols; c++)
                        occupied.Add((startCx + c, startCy + r));
            }
            _wallCaches[gc] = occupied;
        }

        // ── Wipe under walls ──
        await ctx.SetFillStyleAsync("#7c9c45");
        foreach (var (cx, cy) in occupied)
            await ctx.FillRectAsync(cx * bs - 3, cy * bs - 3, bs + 6, bs + 6);

        static int FM(int a, int b) => ((a % b) + b) % b;

        // Brick ID: running bond — 2 cells wide, offset by 1 cell on odd rows
        static (int col, int row) BrickId(int cx, int cy) =>
            (FM(cy, 2) == 0 ? (int)Math.Floor(cx / 2.0) : (int)Math.Floor((cx - 1) / 2.0), cy);

        static int BrickHash(int a, int b)
        {
            int h = a * 374761393 + b * 668265263;
            h = (h ^ (h >> 13)) * 1274126177;
            return (h ^ (h >> 16)) & 0x7FFFFFFF;
        }

        // ── Group cells into bricks ──
        // Each brick is keyed by (brickCol, row). Collect the occupied cells per brick
        // and compute the actual pixel rect from the cells that exist.
        var bricks = new Dictionary<(int, int), (int minCx, int maxCx, int cy)>();
        foreach (var (cx, cy) in occupied)
        {
            var bid = BrickId(cx, cy);
            if (bricks.TryGetValue(bid, out var prev))
                bricks[bid] = (Math.Min(prev.minCx, cx), Math.Max(prev.maxCx, cx), cy);
            else
                bricks[bid] = (cx, cx, cy);
        }

        const int mt = 1; // mortar half-thickness (1px each side = 2px total gap)

        // ── 1. Outer border with concave-corner patches ──
        const double bdr = 3;
        await ctx.SetFillStyleAsync("#1a1c1e");
        foreach (var (cx, cy) in occupied)
        {
            double px = cx * bs, py = cy * bs;
            bool nT = occupied.Contains((cx, cy - 1));
            bool nB = occupied.Contains((cx, cy + 1));
            bool nL = occupied.Contains((cx - 1, cy));
            bool nR = occupied.Contains((cx + 1, cy));

            if (!nT) await ctx.FillRectAsync(px - (nL ? 0 : bdr), py - bdr,
                        bs + (nL ? 0 : bdr) + (nR ? 0 : bdr), bdr);
            if (!nB) await ctx.FillRectAsync(px - (nL ? 0 : bdr), py + bs,
                        bs + (nL ? 0 : bdr) + (nR ? 0 : bdr), bdr);
            if (!nL) await ctx.FillRectAsync(px - bdr, py - (nT ? 0 : bdr),
                        bdr, bs + (nT ? 0 : bdr) + (nB ? 0 : bdr));
            if (!nR) await ctx.FillRectAsync(px + bs, py - (nT ? 0 : bdr),
                        bdr, bs + (nT ? 0 : bdr) + (nB ? 0 : bdr));

            if (nT && nR && !occupied.Contains((cx + 1, cy - 1)))
                await ctx.FillRectAsync(px + bs, py - bdr, bdr, bdr);
            if (nT && nL && !occupied.Contains((cx - 1, cy - 1)))
                await ctx.FillRectAsync(px - bdr, py - bdr, bdr, bdr);
            if (nB && nR && !occupied.Contains((cx + 1, cy + 1)))
                await ctx.FillRectAsync(px + bs, py + bs, bdr, bdr);
            if (nB && nL && !occupied.Contains((cx - 1, cy + 1)))
                await ctx.FillRectAsync(px - bdr, py + bs, bdr, bdr);
        }

        // ── 2. Mortar background — fill entire wall interior with mortar color ──
        await ctx.SetFillStyleAsync("#2a2420");
        foreach (var (cx, cy) in occupied)
            await ctx.FillRectAsync(cx * bs, cy * bs, bs, bs);

        // ── 3. Brick faces — each brick drawn as ONE inset rectangle ──
        // Mortar gaps are created by the inset; no per-cell mortar lines needed.
        string[] palette = { "#7a6e63", "#6e6358", "#736860", "#80756a",
                             "#6b6055", "#78706b", "#847a6f", "#716659" };
        for (int ci = 0; ci < palette.Length; ci++)
        {
            await ctx.SetFillStyleAsync(palette[ci]);
            foreach (var (bid, info) in bricks)
            {
                if (BrickHash(bid.Item1, bid.Item2) % palette.Length != ci) continue;
                double bx = info.minCx * bs + mt;
                double by = info.cy * bs + mt;
                double bw = (info.maxCx - info.minCx + 1) * bs - mt * 2;
                double bh = bs - mt * 2;
                await ctx.FillRectAsync(bx, by, bw, bh);
            }
        }

        // ── 4. Per-brick bevel (drawn on the brick rect, not per-cell) ──
        const int bv = 2;
        // Top highlight
        await ctx.SetFillStyleAsync("rgba(255,255,255,0.13)");
        foreach (var (_, info) in bricks)
        {
            double bx = info.minCx * bs + mt;
            double by = info.cy * bs + mt;
            double bw = (info.maxCx - info.minCx + 1) * bs - mt * 2;
            await ctx.FillRectAsync(bx, by, bw, bv);
        }
        // Left highlight
        await ctx.SetFillStyleAsync("rgba(255,255,255,0.08)");
        foreach (var (_, info) in bricks)
        {
            double bx = info.minCx * bs + mt;
            double by = info.cy * bs + mt;
            double bh = bs - mt * 2;
            await ctx.FillRectAsync(bx, by, bv, bh);
        }
        // Bottom shadow
        await ctx.SetFillStyleAsync("rgba(0,0,0,0.18)");
        foreach (var (_, info) in bricks)
        {
            double bx = info.minCx * bs + mt;
            double by = info.cy * bs + mt;
            double bw = (info.maxCx - info.minCx + 1) * bs - mt * 2;
            double bh = bs - mt * 2;
            await ctx.FillRectAsync(bx, by + bh - bv, bw, bv);
        }
        // Right shadow
        await ctx.SetFillStyleAsync("rgba(0,0,0,0.12)");
        foreach (var (_, info) in bricks)
        {
            double bx = info.minCx * bs + mt;
            double by = info.cy * bs + mt;
            double bw = (info.maxCx - info.minCx + 1) * bs - mt * 2;
            double bh = bs - mt * 2;
            await ctx.FillRectAsync(bx + bw - bv, by, bv, bh);
        }
    }

    private static (double x, double y, double w, double h) WallRect(Wall wall)
    {
        var x = (double)Math.Min(wall.Point1!.X, wall.Point2!.X) - WallHalfWidth;
        var y = (double)Math.Min(wall.Point1.Y, wall.Point2.Y) - WallHalfWidth;
        var wdt = (double)Math.Abs(wall.Point1.X - wall.Point2.X);
        var hgt = (double)Math.Abs(wall.Point1.Y - wall.Point2.Y);
        if (wdt == 0) { wdt = WallThickness; hgt += WallThickness; }
        else { hgt = WallThickness; wdt += WallThickness; }
        return (x, y, wdt, hgt);
    }

    private async Task DrawPowerups(GameController gc)
    {
        var ctx = _context;
        if (ctx == null) return;

        var now = DateTime.UtcNow;
        foreach (var p in gc.GetPowerups())
        {
            if (p.Location == null || p.Died) continue;
            var pulse = _highQualityTextures ? Math.Abs(Math.Sin(now.TimeOfDay.TotalSeconds * 5)) * 3 : 0;

            await ctx.SetFillStyleAsync("gold");
            await ctx.BeginPathAsync();
            await ctx.ArcAsync(p.Location.X, p.Location.Y, 8 + pulse, 0, Math.PI * 2);
            await ctx.FillAsync();

            if (_highQualityTextures)
            {
                await ctx.SetFillStyleAsync("yellow");
                await ctx.BeginPathAsync();
                await ctx.ArcAsync(p.Location.X, p.Location.Y, 4, 0, Math.PI * 2);
                await ctx.FillAsync();
            }
        }
    }

    private async Task DrawSnakes(GameController gc, Dictionary<int, DeathAnim> deathAnims, bool showDeath, SnakeSkin playerSkin)
    {
        var playerId = gc.GetPlayerSnake()?.Id;
        foreach (var s in gc.GetSnakes())
        {
            if (s.Disconnected == true) continue;
            if (s.Alive != true) continue;
            if (deathAnims.ContainsKey(s.Id)) continue;
            if (s.Id == playerId && showDeath) continue;

            var body = s.Body;
            if (body == null || body.Count < 2) continue;
            bool isPlayer = s.Id == playerId;
            var skin = isPlayer ? playerSkin : ResolveSkin(s.Skin);

            await DrawSnakeBody(_context!, body, skin);

            // ── 7. Nameplate ──
            if (!string.IsNullOrEmpty(s.Name))
            {
                var scoreTxt = (s.Score ?? 0).ToString();
                var nameTxt = s.Name;
                var fullTxt = $"{nameTxt}  {scoreTxt}";

                var npHead = body[^1];
                double npHeadR = SnakeWidth / 2.0;

                await _context.SetFontAsync("bold 11px 'Segoe UI', Arial, sans-serif");
                var fullMeasure = await _context.MeasureTextAsync(fullTxt);
                var tw = fullMeasure.Width;

                var padX = 8.0;
                var pillH = 18.0;
                var pillW = tw + padX * 2;
                var rr = pillH / 2.0;
                var px = npHead.X - pillW / 2.0;
                var py = npHead.Y - (npHeadR + 2) - pillH - 6;

                // Shadow
                await _context.SetFillStyleAsync("rgba(0,0,0,0.3)");
                await DrawRoundRect(px + 1, py + 1, pillW, pillH, rr);
                await _context.FillAsync();

                // Background pill
                await _context.SetFillStyleAsync("rgba(0,0,0,0.65)");
                await DrawRoundRect(px, py, pillW, pillH, rr);
                await _context.FillAsync();

                // Subtle border
                await _context.SetStrokeStyleAsync("rgba(255,255,255,0.12)");
                await _context.SetLineWidthAsync(1);
                await DrawRoundRect(px, py, pillW, pillH, rr);
                await _context.StrokeAsync();

                // Name text
                var textY = py + pillH / 2.0 + 4.0;
                await _context.SetFillStyleAsync("rgba(255,255,255,0.95)");
                await _context.SetTextAlignAsync(TextAlign.Center);
                await _context.FillTextAsync(fullTxt, npHead.X, textY);
                await _context.SetTextAlignAsync(TextAlign.Left);
            }
        }

        // Create death animations for ANY snake that just died
        foreach (var s in gc.GetSnakes())
        {
            if ((s.Died == true || s.Alive != true) && s.Body?.Count >= 2 && !deathAnims.ContainsKey(s.Id) && s.Disconnected != true)
            {
                var deathSkin = (s.Id == playerId) ? playerSkin : ResolveSkin(s.Skin);
                deathAnims[s.Id] = new DeathAnim
                {
                    Path = s.Body.ToList(),
                    Skin = deathSkin
                };
            }
            else if (s.Alive == true && deathAnims.ContainsKey(s.Id))
            {
                deathAnims.Remove(s.Id);
            }
        }
    }

    /// <summary>Draws a rounded rectangle path (needs Fill/Stroke after).</summary>
    private async Task DrawRoundRect(double x, double y, double w, double h, double r)
    {
        await _context!.BeginPathAsync();
        await _context.MoveToAsync(x + r, y);
        await _context.LineToAsync(x + w - r, y);
        await _context.ArcAsync(x + w - r, y + r, r, -Math.PI / 2, 0);
        await _context.LineToAsync(x + w, y + h - r);
        await _context.ArcAsync(x + w - r, y + h - r, r, 0, Math.PI / 2);
        await _context.LineToAsync(x + r, y + h);
        await _context.ArcAsync(x + r, y + h - r, r, Math.PI / 2, Math.PI);
        await _context.LineToAsync(x, y + r);
        await _context.ArcAsync(x + r, y + r, r, Math.PI, Math.PI * 1.5);
    }

    /// <summary>Resolves a skin from the server-provided index, falling back to a color-based default.</summary>
    private SnakeSkin ResolveSkin(int? skinIndex)
    {
        if (skinIndex.HasValue && skinIndex.Value >= 0 && skinIndex.Value < SnakeSkin.AllSkins.Length)
            return SnakeSkin.AllSkins[skinIndex.Value];
        return SnakeSkin.AllSkins[0];
    }

    /// <summary>Draws a complete snake (outline, fill, pattern, belly, specular, head+eyes) on any canvas context.</summary>
    private async Task DrawSnakeBody(Canvas2DContext ctx, IReadOnlyList<Point2D> body, SnakeSkin skin)
    {
        if (body.Count < 2) return;

        var outlineCol = skin.OutlineColor ?? "rgba(0,0,0,0.35)";

        // 1. Outline
        await ctx.SetStrokeStyleAsync(outlineCol);
        await ctx.SetLineWidthAsync(SnakeWidth + 4);
        await ctx.SetLineCapAsync(LineCap.Round);
        await ctx.SetLineJoinAsync(LineJoin.Round);
        await ctx.BeginPathAsync();
        await ctx.MoveToAsync(body[0].X, body[0].Y);
        for (int i = 1; i < body.Count; i++)
            await ctx.LineToAsync(body[i].X, body[i].Y);
        await ctx.StrokeAsync();

        // 2. Fill
        await ctx.SetStrokeStyleAsync(skin.BodyColor);
        await ctx.SetLineWidthAsync(SnakeWidth);
        await ctx.SetLineCapAsync(LineCap.Round);
        await ctx.SetLineJoinAsync(LineJoin.Round);
        await ctx.BeginPathAsync();
        await ctx.MoveToAsync(body[0].X, body[0].Y);
        for (int i = 1; i < body.Count; i++)
            await ctx.LineToAsync(body[i].X, body[i].Y);
        await ctx.StrokeAsync();

        // 3. Pattern
        if (skin.BodyAccent != null && skin.Pattern != BodyPattern.Solid)
            await DrawBodyPattern(ctx, body, skin);

        // 4. Belly
        if (skin.BellyColor != null)
        {
            await ctx.SetStrokeStyleAsync(skin.BellyColor);
            await ctx.SetLineWidthAsync(3);
            await ctx.SetLineCapAsync(LineCap.Round);
            await ctx.SetLineJoinAsync(LineJoin.Round);
            await ctx.SetGlobalAlphaAsync(0.35f);
            await ctx.BeginPathAsync();
            await ctx.MoveToAsync(body[0].X, body[0].Y);
            for (int i = 1; i < body.Count; i++)
                await ctx.LineToAsync(body[i].X, body[i].Y);
            await ctx.StrokeAsync();
            await ctx.SetGlobalAlphaAsync(1.0f);
        }

        // 5. Specular
        await ctx.SetStrokeStyleAsync("rgba(255,255,255,0.12)");
        await ctx.SetLineWidthAsync(2);
        await ctx.SetLineCapAsync(LineCap.Round);
        await ctx.SetLineJoinAsync(LineJoin.Round);
        await ctx.BeginPathAsync();
        await ctx.MoveToAsync(body[0].X, body[0].Y);
        for (int i = 1; i < body.Count; i++)
            await ctx.LineToAsync(body[i].X, body[i].Y);
        await ctx.StrokeAsync();

        // 6. Head
        var head = body[^1];
        var neck = body[^2];
        double headAngle = Math.Atan2(head.Y - neck.Y, head.X - neck.X);
        double headR = SnakeWidth * 0.7;

        await ctx.SaveAsync();
        await ctx.TranslateAsync(head.X, head.Y);
        await ctx.RotateAsync((float)headAngle);

        await ctx.SetFillStyleAsync(skin.HeadColor);
        await ctx.BeginPathAsync();
        await ctx.ArcAsync(1, 0, (float)headR, 0, Math.PI * 2);
        await ctx.FillAsync();

        float eyeOff = (float)(headR * 0.45);
        float eyeR = (float)(headR * 0.42);
        float pupilR = (float)(headR * 0.22);
        float eyeFwd = (float)(headR * 0.35);

        await ctx.SetFillStyleAsync(skin.EyeColor);
        await ctx.BeginPathAsync();
        await ctx.ArcAsync(eyeFwd, -eyeOff, eyeR, 0, Math.PI * 2);
        await ctx.FillAsync();
        await ctx.BeginPathAsync();
        await ctx.ArcAsync(eyeFwd, eyeOff, eyeR, 0, Math.PI * 2);
        await ctx.FillAsync();

        await ctx.SetFillStyleAsync(skin.PupilColor);
        await ctx.BeginPathAsync();
        await ctx.ArcAsync(eyeFwd + pupilR * 0.3f, -eyeOff, pupilR, 0, Math.PI * 2);
        await ctx.FillAsync();
        await ctx.BeginPathAsync();
        await ctx.ArcAsync(eyeFwd + pupilR * 0.3f, eyeOff, pupilR, 0, Math.PI * 2);
        await ctx.FillAsync();

        await ctx.RestoreAsync();
    }

    /// <summary>Static preview path — a wavy snake shape for the skin preview canvases.</summary>
    private static readonly IReadOnlyList<Point2D> PreviewPath = BuildPreviewPath();
    private static List<Point2D> BuildPreviewPath()
    {
        var pts = new List<Point2D>();
        for (int x = 10; x <= 140; x += 5)
            pts.Add(new Point2D(x, 18 + (int)(5 * Math.Sin(x * 0.065))));
        return pts;
    }

    /// <summary>Draws a skin preview on a small canvas using the same rendering as in-game snakes.</summary>
    private async Task DrawSkinPreview(Canvas2DContext ctx, SnakeSkin skin)
    {
        await ctx.ClearRectAsync(0, 0, 160, 40);
        await ctx.SetFillStyleAsync("rgba(255,255,255,0.05)");
        await ctx.FillRectAsync(0, 0, 160, 40);
        await DrawSnakeBody(ctx, PreviewPath, skin);
    }

    /// <summary>Draws pattern marks along the snake body.</summary>
    private async Task DrawBodyPattern(Canvas2DContext ctx, IReadOnlyList<Point2D> body, SnakeSkin skin)
    {
        if (skin.BodyAccent == null || skin.Pattern == BodyPattern.Solid) return;
        if (body.Count < 2) return;

        // === STRIPE: dashed stroke on body centerline — Canvas2D handles corner geometry natively ===
        if (skin.Pattern == BodyPattern.Stripe)
        {
            float band = 10f;
            int colorCount = skin.BodyAccent2 != null ? 3 : 2;

            await ctx.SaveAsync();
            await ctx.SetLineWidthAsync(SnakeWidth);
            await ctx.SetLineCapAsync(LineCap.Butt);
            await ctx.SetLineJoinAsync(LineJoin.Round);

            if (colorCount == 2)
            {
                // 2-color: body + accent — accent on odd bands (1, 3, 5, ...)
                await ctx.SetStrokeStyleAsync(skin.BodyAccent!);
                await ctx.SetLineDashAsync(new float[] { band, band });
                await ctx.SetLineDashOffsetAsync(band);
                await ctx.BeginPathAsync();
                await ctx.MoveToAsync(body[0].X, body[0].Y);
                for (int i = 1; i < body.Count; i++)
                    await ctx.LineToAsync(body[i].X, body[i].Y);
                await ctx.StrokeAsync();
            }
            else
            {
                // 3-color: body + accent1 + accent2
                // accent1 on bands 1, 4, 7, ...
                await ctx.SetStrokeStyleAsync(skin.BodyAccent!);
                await ctx.SetLineDashAsync(new float[] { band, 2 * band });
                await ctx.SetLineDashOffsetAsync(2 * band);
                await ctx.BeginPathAsync();
                await ctx.MoveToAsync(body[0].X, body[0].Y);
                for (int i = 1; i < body.Count; i++)
                    await ctx.LineToAsync(body[i].X, body[i].Y);
                await ctx.StrokeAsync();

                // accent2 on bands 2, 5, 8, ...
                await ctx.SetStrokeStyleAsync(skin.BodyAccent2!);
                await ctx.SetLineDashAsync(new float[] { band, 2 * band });
                await ctx.SetLineDashOffsetAsync(band);
                await ctx.BeginPathAsync();
                await ctx.MoveToAsync(body[0].X, body[0].Y);
                for (int i = 1; i < body.Count; i++)
                    await ctx.LineToAsync(body[i].X, body[i].Y);
                await ctx.StrokeAsync();
            }

            // Reset dash state
            await ctx.SetLineDashAsync(new float[] { });
            await ctx.RestoreAsync();
            return;
        }

        // === OTHER PATTERNS: perpendicular marks with corner-blended normals ===
        int segCount = body.Count - 1;
        var segNormals = new (double nx, double ny)[segCount];
        for (int s = 0; s < segCount; s++)
        {
            double dx = body[s + 1].X - body[s].X;
            double dy = body[s + 1].Y - body[s].Y;
            double len = Math.Sqrt(dx * dx + dy * dy);
            if (len < 0.001) { segNormals[s] = (0, 1); continue; }
            segNormals[s] = (-dy / len, dx / len);
        }

        // Bisector normals at each vertex (average of adjacent segment normals, normalized)
        var vtxNormals = new (double nx, double ny)[body.Count];
        vtxNormals[0] = segCount > 0 ? segNormals[0] : (0, 1);
        vtxNormals[^1] = segCount > 0 ? segNormals[^1] : (0, 1);
        for (int v = 1; v < body.Count - 1; v++)
        {
            double bx = segNormals[v - 1].nx + segNormals[v].nx;
            double by = segNormals[v - 1].ny + segNormals[v].ny;
            double bLen = Math.Sqrt(bx * bx + by * by);
            if (bLen > 0.001) { bx /= bLen; by /= bLen; }
            else { bx = segNormals[v].nx; by = segNormals[v].ny; }
            vtxNormals[v] = (bx, by);
        }

        double spacing = skin.Pattern switch
        {
            BodyPattern.Checker => 12,
            BodyPattern.Diamond => 18,
            BodyPattern.Wave => 10,
            _ => 14
        };

        double blendDist = SnakeWidth * 1.5;
        double accumulated = 0;
        int markIdx = 0;
        for (int i = 1; i < body.Count; i++)
        {
            int seg = i - 1;
            double sdx = body[i].X - body[i - 1].X;
            double sdy = body[i].Y - body[i - 1].Y;
            double segLen = Math.Sqrt(sdx * sdx + sdy * sdy);
            if (segLen < 0.001) continue;
            double dirX = sdx / segLen;
            double dirY = sdy / segLen;

            var (snx, sny) = segNormals[seg];
            // Bisector normals at the start and end vertices of this segment
            var (bisStartNx, bisStartNy) = vtxNormals[seg];
            var (bisEndNx, bisEndNy) = vtxNormals[seg + 1];

            double walked = 0;
            while (walked + (spacing - accumulated) <= segLen)
            {
                walked += spacing - accumulated;
                accumulated = 0;
                double px = body[i - 1].X + sdx * (walked / segLen);
                double py = body[i - 1].Y + sdy * (walked / segLen);

                double distFromStart = walked;
                double distFromEnd = segLen - walked;

                double nx, ny;
                if (distFromStart < blendDist && seg > 0)
                {
                    // Blend: bisector at vertex → segment normal at blendDist away
                    double t = distFromStart / blendDist;
                    t = t * t * (3 - 2 * t); // smoothstep
                    nx = bisStartNx + (snx - bisStartNx) * t;
                    ny = bisStartNy + (sny - bisStartNy) * t;
                }
                else if (distFromEnd < blendDist && seg < segCount - 1)
                {
                    double t = distFromEnd / blendDist;
                    t = t * t * (3 - 2 * t); // smoothstep
                    nx = bisEndNx + (snx - bisEndNx) * t;
                    ny = bisEndNy + (sny - bisEndNy) * t;
                }
                else
                {
                    nx = snx;
                    ny = sny;
                }

                double nLen = Math.Sqrt(nx * nx + ny * ny);
                if (nLen > 0.001) { nx /= nLen; ny /= nLen; }

                await DrawPatternMark(ctx, skin, px, py, nx, ny, dirX, dirY, markIdx);
                markIdx++;
            }
            accumulated += segLen - walked;
        }
    }

    private async Task DrawPatternMark(Canvas2DContext ctx, SnakeSkin skin, double px, double py, double nx, double ny, double dx, double dy, int idx)
    {
        double halfW = SnakeWidth / 2.0;

        switch (skin.Pattern)
        {
            case BodyPattern.Stripe:
                int colorCount = skin.BodyAccent2 != null ? 3 : 2;
                int bandPhase = idx % colorCount; // 0=body(skip), 1=accent1, 2=accent2
                if (bandPhase == 0) break;
                string stripeCol = (bandPhase == 2 && skin.BodyAccent2 != null) ? skin.BodyAccent2 : skin.BodyAccent!;
                await ctx.SetStrokeStyleAsync(stripeCol);
                await ctx.SetLineWidthAsync(SnakeWidth);
                await ctx.SetLineCapAsync(LineCap.Butt);
                await ctx.BeginPathAsync();
                double ext = SnakeWidth;
                await ctx.MoveToAsync(px + nx * ext, py + ny * ext);
                await ctx.LineToAsync(px - nx * ext, py - ny * ext);
                await ctx.StrokeAsync();
                break;

            case BodyPattern.Checker:
                string checkCol = (skin.BodyAccent2 != null && idx % 2 == 1) ? skin.BodyAccent2 : skin.BodyAccent!;
                await ctx.SetFillStyleAsync(checkCol);
                double side = idx % 2 == 0 ? 1 : -1;
                double ccx = px + nx * halfW * 0.4 * side;
                double ccy = py + ny * halfW * 0.4 * side;
                await ctx.BeginPathAsync();
                await ctx.ArcAsync(ccx, ccy, 3.5, 0, Math.PI * 2);
                await ctx.FillAsync();
                break;

            case BodyPattern.Diamond:
                string diaCol = (skin.BodyAccent2 != null && idx % 2 == 1) ? skin.BodyAccent2 : skin.BodyAccent!;
                await ctx.SetFillStyleAsync(diaCol);
                double dSize = halfW * 0.7;
                await ctx.BeginPathAsync();
                await ctx.MoveToAsync(px + dx * dSize, py + dy * dSize);
                await ctx.LineToAsync(px + nx * dSize, py + ny * dSize);
                await ctx.LineToAsync(px - dx * dSize, py - dy * dSize);
                await ctx.LineToAsync(px - nx * dSize, py - ny * dSize);
                await ctx.ClosePathAsync();
                await ctx.FillAsync();
                break;

            case BodyPattern.Wave:
                string waveCol = (skin.BodyAccent2 != null && idx % 2 == 1) ? skin.BodyAccent2 : skin.BodyAccent!;
                await ctx.SetFillStyleAsync(waveCol);
                double waveSide = Math.Sin(idx * 1.2) * halfW * 0.5;
                double wx = px + nx * waveSide;
                double wy = py + ny * waveSide;
                await ctx.SetGlobalAlphaAsync(0.8f);
                await ctx.BeginPathAsync();
                await ctx.ArcAsync(wx, wy, 3.0, 0, Math.PI * 2);
                await ctx.FillAsync();
                await ctx.SetGlobalAlphaAsync(1.0f);
                break;
        }
    }
}
