@code
{
    // ==================== Constants ====================
    private const int SnakeWidth = 10;
    private const int WallHalfWidth = 25;
    private const int WallThickness = 50;
    private const double BitDistance = 20.0;
    private const double ExplosionDelay = 0.05;
    private const double ParticleLifespan = 0.6;
    private const int HeadOuterRadius = 9;
    private const int HeadMiddleRadius = 8;
    private const int HeadInnerRadius = 6;
    private const int FrameDelayMs = 16;
    private const int GridSpacing = 50;
    private const int BrickSize = 25;
    private const double MinSpawnClearance = 100.0;

    // ==================== Private Fields ====================
    private BECanvasComponent? _canvasReference;
    private Canvas2DContext? _context;
    private CancellationTokenSource? _renderCts;
    private readonly Stopwatch _frameStopwatch = new();
    private Action? _onDisconnectedHandler;
    private readonly Dictionary<int, DeathAnim> _deathAnimations = new();
    private readonly string[] _colors = { "red", "green", "blue", "orange", "purple", "brown", "magenta", "teal" };
    private int _viewW = 1920;
    private int _viewH = 1080;

    // ==================== UI State ====================
    private string Host { get; set; } = "localhost";
    private int Port { get; set; } = 11000;
    private string PlayerName { get; set; } = "Player";
    private string _status = "Disconnected";
    private bool _showDeathScreen;
    private bool _spawnSafe;
    private bool _rerolling;
    private CancellationTokenSource? _rerollCts;
    private bool _drawGrid = true;
    private bool _highQualityTextures = true;
    private bool _sidebarOpen = true;
    private bool _showScoreboard = true;
    private int? _centerTargetSnakeId;
    private int _frozenCameraX;
    private int _frozenCameraY;

    // ==================== Inner Types ====================

    private class DeathAnim
    {
        public double ElapsedSeconds { get; set; }
        public IReadOnlyList<Point2D> Path { get; set; } = Array.Empty<Point2D>();
        public string Color { get; set; } = "orange";
        public bool IsFinished { get; set; }
    }

    // ==================== Lifecycle ====================

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/SnakeGUI.razor.js");
        _context = await _canvasReference!.CreateCanvas2DAsync();
        await JsRuntime.InvokeAsync<object>("initRenderJS", DotNetObjectReference.Create(this));

        _renderCts = new CancellationTokenSource();
        _ = Task.Run(() => RenderLoopAsync(_renderCts.Token));

        _onDisconnectedHandler = () => _ = InvokeAsync(() =>
        {
            _status = "Disconnected";
            StateHasChanged();
        });
        NetworkController.OnDisconnected += _onDisconnectedHandler;

        GameController.OnPlayerDied += OnPlayerDied;
    }

    public void Dispose()
    {
        try { _renderCts?.Cancel(); } catch { }
        try { _rerollCts?.Cancel(); } catch { }
        if (_onDisconnectedHandler != null) NetworkController.OnDisconnected -= _onDisconnectedHandler;
        GameController.OnPlayerDied -= OnPlayerDied;
    }

    // ==================== Input ====================

    [JSInvokable]
    public void HandleKeyPress(string key)
    {
        if (_showDeathScreen) return;

        var cmd = key.ToLowerInvariant() switch
        {
            "w" or "arrowup" => "up",
            "a" or "arrowleft" => "left",
            "s" or "arrowdown" => "down",
            "d" or "arrowright" => "right",
            _ => null
        };
        if (cmd != null) _ = GameController.SendMoveAsync(cmd);
    }

    // ==================== Connection ====================

    private async Task Connect()
    {
        try { _rerollCts?.Cancel(); } catch { }
        _showDeathScreen = false;
        _spawnSafe = false;
        _rerolling = false;
        _sidebarOpen = false;
        GameController.Disconnect();
        try
        {
            _status = "Connecting...";
            StateHasChanged();
            await GameController.ConnectAsync(Host, Port, PlayerName);
            _status = "Connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _status = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    private async Task Reconnect()
    {
        try { _rerollCts?.Cancel(); } catch { }
        _showDeathScreen = false;
        _spawnSafe = false;
        _rerolling = false;
        await ConnectInternal();
    }

    private void Respawn()
    {
        try { _rerollCts?.Cancel(); } catch { }
        _showDeathScreen = false;
        _spawnSafe = false;
        _rerolling = false;
        // Server already auto-respawned — just clear the death overlay
    }

    /// <summary>Reconnects without touching death-screen state. Used by spawn reroll.</summary>
    private async Task RerollReconnect()
    {
        _spawnSafe = false;
        _rerolling = false;
        await ConnectInternal();
    }

    private async Task ConnectInternal()
    {
        GameController.Disconnect();
        try
        {
            _status = "Connecting...";
            StateHasChanged();
            await GameController.ConnectAsync(Host, Port, PlayerName);
            _status = "Connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _status = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    // ==================== Game State ====================

    private void OnPlayerDied()
    {
        if (_showDeathScreen) return;

        try { _rerollCts?.Cancel(); } catch { }
        _showDeathScreen = true;
        _spawnSafe = false;
        _rerolling = false;
        _status = "Game Over";

        // Freeze camera at the player's death position
        var player = GameController.GetPlayerSnake();
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _frozenCameraX = head.X;
            _frozenCameraY = head.Y;
        }
        if (player != null) StartDeathAnimation(player);

        // Don't disconnect — keep the connection alive so the world stays populated.
        // The server auto-respawns, but we hide the player until they click Respawn.

        _ = InvokeAsync(StateHasChanged);
    }

    private void CheckPlayerState()
    {
        var player = GameController.GetPlayerSnake();
        if (player == null) return;

        if (player.Alive == true && !_spawnSafe && !_showDeathScreen)
        {
            if (player.Body == null || player.Body.Count < 2) return;

            if (IsSpawnSafe(player))
            {
                _spawnSafe = true;
                _rerolling = false;
            }
            else if (!_rerolling)
            {
                _rerolling = true;
                try { _rerollCts?.Cancel(); } catch { }
                _rerollCts = new CancellationTokenSource();
                var token = _rerollCts.Token;
                _ = Task.Run(async () =>
                {
                    try
                    {
                        await Task.Delay(80, token);
                        if (token.IsCancellationRequested || _showDeathScreen)
                        {
                            _rerolling = false;
                            return;
                        }

                        await InvokeAsync(async () =>
                        {
                            if (_showDeathScreen)
                            {
                                _rerolling = false;
                                return;
                            }
                            await RerollReconnect();
                        });
                    }
                    catch (TaskCanceledException)
                    {
                        _rerolling = false;
                    }
                });
            }
        }
    }

    private bool IsSpawnSafe(Snake player)
    {
        if (player.Body == null || player.Body.Count < 2) return false;
        var head = player.Body[^1];

        foreach (var w in GameController.GetWalls())
        {
            if (w.Point1 == null || w.Point2 == null) continue;
            double wx1 = Math.Min(w.Point1.X, w.Point2.X) - WallHalfWidth;
            double wx2 = Math.Max(w.Point1.X, w.Point2.X) + WallHalfWidth;
            double wy1 = Math.Min(w.Point1.Y, w.Point2.Y) - WallHalfWidth;
            double wy2 = Math.Max(w.Point1.Y, w.Point2.Y) + WallHalfWidth;

            if (DistToRect(head.X, head.Y, wx1, wy1, wx2, wy2) < MinSpawnClearance)
                return false;
        }

        foreach (var s in GameController.GetSnakes())
        {
            if (s.Id == player.Id || s.Alive != true || s.Body == null || s.Body.Count < 2) continue;

            for (int i = 0; i < s.Body.Count - 1; i++)
            {
                var a = s.Body[i];
                var b = s.Body[i + 1];
                for (int j = 0; j < player.Body.Count - 1; j++)
                {
                    var c = player.Body[j];
                    var d = player.Body[j + 1];
                    if (SegmentDist(a.X, a.Y, b.X, b.Y, c.X, c.Y, d.X, d.Y) < MinSpawnClearance)
                        return false;
                }
            }

            var otherHead = s.Body[^1];
            for (int j = 0; j < player.Body.Count - 1; j++)
            {
                var c = player.Body[j];
                var d = player.Body[j + 1];
                if (PointToSegDist(otherHead.X, otherHead.Y, c.X, c.Y, d.X, d.Y) < MinSpawnClearance)
                    return false;
            }

            for (int i = 0; i < s.Body.Count - 1; i++)
            {
                var a = s.Body[i];
                var b = s.Body[i + 1];
                if (PointToSegDist(head.X, head.Y, a.X, a.Y, b.X, b.Y) < MinSpawnClearance)
                    return false;
            }
        }
        return true;
    }

    private static double DistToRect(double px, double py, double rx1, double ry1, double rx2, double ry2)
    {
        double cx = Math.Max(rx1, Math.Min(px, rx2));
        double cy = Math.Max(ry1, Math.Min(py, ry2));
        double dx = px - cx, dy = py - cy;
        return Math.Sqrt(dx * dx + dy * dy);
    }

    private static double PointToSegDist(double px, double py, double ax, double ay, double bx, double by)
    {
        double abx = bx - ax, aby = by - ay;
        double len2 = abx * abx + aby * aby;
        double t = len2 < 0.0001 ? 0 : Math.Clamp(((px - ax) * abx + (py - ay) * aby) / len2, 0, 1);
        double cx = ax + t * abx, cy = ay + t * aby;
        double dx = px - cx, dy = py - cy;
        return Math.Sqrt(dx * dx + dy * dy);
    }

    private static double SegmentDist(double a1x, double a1y, double a2x, double a2y, double b1x, double b1y, double b2x, double b2y)
    {
        return Math.Min(
            Math.Min(PointToSegDist(a1x, a1y, b1x, b1y, b2x, b2y), PointToSegDist(a2x, a2y, b1x, b1y, b2x, b2y)),
            Math.Min(PointToSegDist(b1x, b1y, a1x, a1y, a2x, a2y), PointToSegDist(b2x, b2y, a1x, a1y, a2x, a2y)));
    }

    private void StartDeathAnimation(Snake snake)
    {
        if (_deathAnimations.ContainsKey(snake.Id)) return;
        _deathAnimations[snake.Id] = new DeathAnim
        {
            Path = snake.Body?.ToList() ?? new List<Point2D>(),
            Color = _colors[snake.Id % _colors.Length]
        };
    }

    // ==================== Render Loop ====================

    private async Task RenderLoopAsync(CancellationToken ct)
    {
        _frameStopwatch.Start();
        int tick = 0;
        try
        {
            while (!ct.IsCancellationRequested)
            {
                try
                {
                    await DrawFrame();
                    if (++tick % 6 == 0)
                    {
                        CheckPlayerState();
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch { /* skip frame */ }
                await Task.Delay(FrameDelayMs, ct);
            }
        }
        catch (TaskCanceledException) { }
    }

    // ==================== Drawing ====================

    private async Task DrawFrame()
    {
        if (_context == null) return;

        var elapsed = _frameStopwatch.Elapsed.TotalSeconds;
        _frameStopwatch.Restart();

        try
        {
            var dims = await JsRuntime.InvokeAsync<int[]>("getViewportSize");
            if (dims is { Length: 2 } && dims[0] > 0 && dims[1] > 0)
            {
                _viewW = dims[0];
                _viewH = dims[1];
            }
        }
        catch { }

        await _context.BeginBatchAsync();
        await _context.SetFillStyleAsync(_highQualityTextures ? "#7c9c45" : "#e8f5ff");
        await _context.FillRectAsync(0, 0, _viewW, _viewH);

        var worldSize = GameController.WorldSize ?? 2000;

        Snake? centerSnake = null;
        if (_centerTargetSnakeId.HasValue)
            centerSnake = GameController.GetSnakes().FirstOrDefault(s => s.Id == _centerTargetSnakeId.Value);
        centerSnake ??= GameController.GetPlayerSnake();

        int centerX = 0, centerY = 0;
        if (_showDeathScreen)
        {
            // Keep camera locked where the player died
            centerX = _frozenCameraX;
            centerY = _frozenCameraY;
        }
        else if (centerSnake?.Body?.Count > 0)
        {
            var head = centerSnake.Body[^1];
            centerX = head.X;
            centerY = head.Y;
        }

        var halfWorld = worldSize / 2;
        centerX = Math.Clamp(centerX, -halfWorld + _viewW / 2, halfWorld - _viewW / 2);
        centerY = Math.Clamp(centerY, -halfWorld + _viewH / 2, halfWorld - _viewH / 2);

        await _context.BeginPathAsync();
        await _context.RectAsync(0, 0, _viewW, _viewH);
        await _context.ClipAsync();
        await _context.SaveAsync();
        // Pixel-align camera translation so wall edges don't anti-alias inconsistently.
        var camX = Math.Round(_viewW / 2.0 - centerX);
        var camY = Math.Round(_viewH / 2.0 - centerY);
        await _context.TranslateAsync(camX, camY);

        if (_drawGrid && _highQualityTextures)
            await DrawGrid(worldSize);

        await DrawDeathAnimations(elapsed);
        await DrawWalls();
        await DrawPowerups();
        await DrawSnakes();

        await _context.RestoreAsync();
        await _context.EndBatchAsync();
    }

    private async Task DrawGrid(int worldSize)
    {
        await _context!.SetStrokeStyleAsync("rgba(0,0,0,0.05)");
        await _context.SetLineWidthAsync(2);
        await _context.BeginPathAsync();
        var hw = worldSize / 2;
        for (int i = -hw; i <= hw; i += GridSpacing)
        {
            await _context.MoveToAsync(i, -hw);
            await _context.LineToAsync(i, hw);
            await _context.MoveToAsync(-hw, i);
            await _context.LineToAsync(hw, i);
        }
        await _context.StrokeAsync();
    }

    private async Task DrawDeathAnimations(double elapsed)
    {
        var finished = new List<int>();
        foreach (var (id, anim) in _deathAnimations)
        {
            if (anim.IsFinished)
            {
                if (!GameController.GetSnakes().Any(s => s.Id == id))
                    finished.Add(id);
                continue;
            }

            var path = anim.Path;
            if (path == null || path.Count < 2) { anim.IsFinished = true; continue; }

            double totalLength = 0;
            var lengths = new List<double>();
            for (int i = 0; i < path.Count - 1; i++)
            {
                var dx = path[i + 1].X - path[i].X;
                var dy = path[i + 1].Y - path[i].Y;
                lengths.Add(Math.Sqrt(dx * dx + dy * dy));
                totalLength += lengths[^1];
            }

            double explosionSpeed = BitDistance / ExplosionDelay;
            double explodedLength = anim.ElapsedSeconds * explosionSpeed;
            double currentDist = 0;

            // Remaining body
            await _context!.SetStrokeStyleAsync(anim.Color);
            await _context.SetLineWidthAsync(SnakeWidth);
            await _context.SetLineCapAsync(LineCap.Round);
            await _context.SetLineJoinAsync(LineJoin.Round);
            await _context.BeginPathAsync();

            bool moved = false;
            for (int i = 0; i < path.Count - 1; i++)
            {
                var segLen = lengths[i];
                var segDistEnd = totalLength - currentDist;

                if (segDistEnd > explodedLength)
                {
                    if (!moved) { await _context.MoveToAsync(path[i].X, path[i].Y); moved = true; }
                    if (segDistEnd - segLen > explodedLength)
                        await _context.LineToAsync(path[i + 1].X, path[i + 1].Y);
                    else
                    {
                        var t = segLen > 0.001 ? (segDistEnd - explodedLength) / segLen : 0;
                        await _context.LineToAsync(
                            path[i].X + (path[i + 1].X - path[i].X) * t,
                            path[i].Y + (path[i + 1].Y - path[i].Y) * t);
                        break;
                    }
                }
                currentDist += segLen;
            }
            if (moved) await _context.StrokeAsync();

            // Explosion particles
            currentDist = 0;
            for (int i = path.Count - 1; i > 0; i--)
            {
                var segLen = lengths[i - 1];
                double steps = Math.Max(1, Math.Ceiling(segLen / BitDistance));
                for (int j = 0; j <= steps; j++)
                {
                    var t = j / steps;
                    var ptDist = currentDist + segLen * t;
                    var timeSinceExplosion = anim.ElapsedSeconds - ptDist / explosionSpeed;

                    if (timeSinceExplosion >= 0 && timeSinceExplosion <= ParticleLifespan)
                    {
                        var bx = path[i].X + (path[i - 1].X - path[i].X) * t;
                        var by = path[i].Y + (path[i - 1].Y - path[i].Y) * t;
                        var bAlpha = Math.Max(0, 1.0 - timeSinceExplosion / ParticleLifespan);
                        var baseRadius = ptDist < BitDistance ? 10 : 3;
                        var expandFactor = ptDist < BitDistance ? 25 : 12;
                        var bRadius = baseRadius + timeSinceExplosion / ParticleLifespan * expandFactor;

                        await _context.SetGlobalAlphaAsync((float)bAlpha);
                        await _context.SetFillStyleAsync(anim.Color);
                        await _context.BeginPathAsync();
                        await _context.ArcAsync(bx, by, bRadius, 0, Math.PI * 2);
                        await _context.FillAsync();
                    }
                }
                currentDist += segLen;
            }
            await _context.SetGlobalAlphaAsync(1.0f);

            anim.ElapsedSeconds += elapsed;
            if (anim.ElapsedSeconds > totalLength / explosionSpeed + 1.0)
                anim.IsFinished = true;
        }
        foreach (var id in finished)
            _deathAnimations.Remove(id);
    }

    private async Task DrawWalls()
    {
        var ctx = _context;
        if (ctx == null) return;

        var walls = GameController.GetWalls();
        const int bs = BrickSize;

        if (!_highQualityTextures)
        {
            await ctx.SetFillStyleAsync("#555555");
            foreach (var w in walls)
            {
                if (w.Point1 == null || w.Point2 == null) continue;
                var (x, y, wdt, hgt) = WallRect(w);
                await ctx.FillRectAsync(x, y, wdt, hgt);
            }
            return;
        }

        // ── Step 1: Rasterize all walls into a global grid of occupied cells ──
        var occupied = new HashSet<(int cx, int cy)>();
        foreach (var w in walls)
        {
            if (w.Point1 == null || w.Point2 == null) continue;
            var (rx, ry, rw, rh) = WallRect(w);
            int cols = (int)Math.Round(rw / bs);
            int rows = (int)Math.Round(rh / bs);
            int startCx = (int)Math.Round(rx / bs);
            int startCy = (int)Math.Round(ry / bs);
            for (int r = 0; r < rows; r++)
                for (int c = 0; c < cols; c++)
                    occupied.Add((startCx + c, startCy + r));
        }

        // ── Step 2: Dark underpaint — each cell expanded by 3px on exposed sides ──
        // This creates a continuous outline naturally, no edge strips needed.
        const int border = 3;
        await ctx.SetFillStyleAsync("#1a1c1f");
        foreach (var (cx, cy) in occupied)
        {
            double px = cx * bs, py = cy * bs;
            bool nT = occupied.Contains((cx, cy - 1));
            bool nB = occupied.Contains((cx, cy + 1));
            bool nL = occupied.Contains((cx - 1, cy));
            bool nR = occupied.Contains((cx + 1, cy));
            double ex = px - (nL ? 0 : border);
            double ey = py - (nT ? 0 : border);
            double ew = bs + (nL ? 0 : border) + (nR ? 0 : border);
            double eh = bs + (nT ? 0 : border) + (nB ? 0 : border);
            await ctx.FillRectAsync(ex, ey, ew, eh);
        }

        // ── Step 3: Mortar base — fill each cell with mortar color ──
        await ctx.SetFillStyleAsync("#3a3c3f");
        foreach (var (cx, cy) in occupied)
            await ctx.FillRectAsync(cx * bs, cy * bs, bs, bs);

        // ── Step 4: Draw brick faces with mortar insets + running bond stagger ──
        // FM = floor-mod, always returns 0..(b-1) even for negative coords
        static int FM(int a, int b) => ((a % b) + b) % b;
        const int m = 1; // mortar thickness on each side

        foreach (var (cx, cy) in occupied)
        {
            double px = cx * bs, py = cy * bs;
            bool nT = occupied.Contains((cx, cy - 1));
            bool nB = occupied.Contains((cx, cy + 1));
            bool nL = occupied.Contains((cx - 1, cy));
            bool nR = occupied.Contains((cx + 1, cy));

            // Every cell gets a horizontal mortar inset on interior top/bottom edges
            int topInset = nT ? m : 0;
            int botInset = nB ? m : 0;

            // Vertical mortar: running bond — even rows split at FM(cx,2)==1, odd at FM(cx,2)==0
            bool evenRow = FM(cy, 2) == 0;
            bool jointLeft = evenRow ? FM(cx, 2) == 0 : FM(cx, 2) == 1;
            bool jointRight = evenRow ? FM(cx, 2) == 1 : FM(cx, 2) == 0;
            // Only inset if there's a neighbor to create a joint with
            int leftInset = (nL && jointLeft) ? m : 0;
            int rightInset = (nR && jointRight) ? m : 0;

            double fx = px + leftInset;
            double fy = py + topInset;
            double fw = bs - leftInset - rightInset;
            double fh = bs - topInset - botInset;

            // Alternate shade per brick for subtle depth
            int brickCol = evenRow
                ? (int)Math.Floor(cx / 2.0)
                : (int)Math.Floor((cx - 1) / 2.0);
            int shade = FM(brickCol + cy, 2);
            await ctx.SetFillStyleAsync(shade == 0 ? "#6d7175" : "#62666a");
            await ctx.FillRectAsync(fx, fy, fw, fh);
        }
    }

    private static (double x, double y, double w, double h) WallRect(Wall wall)
    {
        var x = (double)Math.Min(wall.Point1!.X, wall.Point2!.X) - WallHalfWidth;
        var y = (double)Math.Min(wall.Point1.Y, wall.Point2.Y) - WallHalfWidth;
        var wdt = (double)Math.Abs(wall.Point1.X - wall.Point2.X);
        var hgt = (double)Math.Abs(wall.Point1.Y - wall.Point2.Y);
        if (wdt == 0) { wdt = WallThickness; hgt += WallThickness; }
        else { hgt = WallThickness; wdt += WallThickness; }
        return (x, y, wdt, hgt);
    }

    private async Task DrawPowerups()
    {
        var ctx = _context;
        if (ctx == null) return;

        var now = DateTime.UtcNow;
        foreach (var p in GameController.GetPowerups())
        {
            if (p.Location == null || p.Died) continue;
            var pulse = _highQualityTextures ? Math.Abs(Math.Sin(now.TimeOfDay.TotalSeconds * 5)) * 3 : 0;

            await ctx.SetFillStyleAsync("gold");
            await ctx.BeginPathAsync();
            await ctx.ArcAsync(p.Location.X, p.Location.Y, 8 + pulse, 0, Math.PI * 2);
            await ctx.FillAsync();

            if (_highQualityTextures)
            {
                await ctx.SetFillStyleAsync("yellow");
                await ctx.BeginPathAsync();
                await ctx.ArcAsync(p.Location.X, p.Location.Y, 4, 0, Math.PI * 2);
                await ctx.FillAsync();
            }
        }
    }

    private async Task DrawSnakes()
    {
        var playerId = GameController.GetPlayerSnake()?.Id;
        foreach (var s in GameController.GetSnakes())
        {
            if (s.Disconnected == true) continue;
            if (s.Alive != true) continue;
            if (_deathAnimations.ContainsKey(s.Id)) continue;
            // Hide the player snake while death screen is showing or during spawn safety check
            if (s.Id == playerId && (_showDeathScreen || !_spawnSafe)) continue;

            var body = s.Body;
            if (body == null || body.Count < 2) continue;
            var color = _colors[s.Id % _colors.Length];

            // Body
            await _context!.SetStrokeStyleAsync(color);
            await _context.SetLineWidthAsync(SnakeWidth);
            await _context.SetLineCapAsync(LineCap.Round);
            await _context.SetLineJoinAsync(LineJoin.Round);
            await _context.BeginPathAsync();
            await _context.MoveToAsync(body[0].X, body[0].Y);
            for (int i = 1; i < body.Count; i++)
                await _context.LineToAsync(body[i].X, body[i].Y);
            await _context.StrokeAsync();

            // Head
            var head = body[^1];
            if (_highQualityTextures)
            {
                await _context.SetFillStyleAsync("black");
                await _context.BeginPathAsync();
                await _context.ArcAsync(head.X, head.Y, HeadOuterRadius, 0, Math.PI * 2);
                await _context.FillAsync();
            }
            await _context.SetFillStyleAsync("white");
            await _context.BeginPathAsync();
            await _context.ArcAsync(head.X, head.Y, HeadMiddleRadius, 0, Math.PI * 2);
            await _context.FillAsync();
            await _context.SetFillStyleAsync(color);
            await _context.BeginPathAsync();
            await _context.ArcAsync(head.X, head.Y, HeadInnerRadius, 0, Math.PI * 2);
            await _context.FillAsync();

            // Nametag
            if (!string.IsNullOrEmpty(s.Name))
            {
                await _context.SetFillStyleAsync("white");
                await _context.SetFontAsync("bold 14px Arial");
                await _context.FillTextAsync($"{s.Name}: {s.Score ?? 0}", head.X + 12, head.Y - 12);
            }
        }

        // Create death animations for ANY snake that just died (not just the player)
        foreach (var s in GameController.GetSnakes())
        {
            if (s.Died == true && !_deathAnimations.ContainsKey(s.Id))
            {
                _deathAnimations[s.Id] = new DeathAnim
                {
                    Path = s.Body?.ToList() ?? new List<Point2D>(),
                    Color = _colors[s.Id % _colors.Length]
                };
            }
            else if (s.Alive == true)
            {
                _deathAnimations.Remove(s.Id);
            }
        }
    }
}
