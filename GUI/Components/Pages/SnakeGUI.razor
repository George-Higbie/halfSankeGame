    .btn-respawn {
        margin-top: 24px;
        font-size: 1.3rem;
        padding: 12px 40px;
        background: #4caf50;
        color: #fff;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 4px 16px rgba(76,175,80,0.4);
        transition: background 0.15s, transform 0.1s;
    }
    .btn-respawn:hover { background: #43a047; transform: translateY(-1px); }
    .respawn-hint {
        margin-top: 10px;
        font-size: 0.85rem;
        opacity: 0.5;
        letter-spacing: 0.5px;
    }
    @@keyframes fadeIn { to { opacity: 1; } }
</style>

@code
{
    // ==================== Constants ====================
    private const int SnakeWidth = 10;
    private const int WallHalfWidth = 25;
    private const int WallThickness = 50;
    private const double BitDistance = 20.0;
    private const double ExplosionDelay = 0.05;
    private const double ParticleLifespan = 0.6;
    private const int HeadOuterRadius = 9;
    private const int HeadMiddleRadius = 8;
    private const int HeadInnerRadius = 6;
    private const int FrameDelayMs = 16;
    private const int GridSpacing = 50;
    private const int BrickSize = 25;

    // ==================== Private Fields ====================
    private BECanvasComponent? _canvasReference;
    private Canvas2DContext? _context;
    private CancellationTokenSource? _renderCts;
    private readonly Stopwatch _frameStopwatch = new();
    private readonly string[] _colors = { "red", "green", "blue", "orange", "purple", "brown", "magenta", "teal" };
    private int _viewW = 1920;
    private int _viewH = 1080;

    // P1 per-player state (uses DI-injected controllers)
    private readonly Dictionary<int, DeathAnim> _p1DeathAnims = new();
    private bool _showDeathScreen;
    private int _frozenCameraX;
    private int _frozenCameraY;
    private string? _p1PendingMove;
    private int? _centerTargetSnakeId;
    private volatile bool _p1Ready;

    // P2 per-player state (manually created controllers)
    private NetworkController? _p2Network;
    private GameController? _p2Game;
    private readonly Dictionary<int, DeathAnim> _p2DeathAnims = new();
    private bool _p2ShowDeath;
    private int _p2FrozenCamX;
    private int _p2FrozenCamY;
    private string? _p2PendingMove;
    private volatile bool _p2Ready;

    // Wall cache keyed by controller (walls are static per connection)
    private readonly Dictionary<GameController, HashSet<(int cx, int cy)>> _wallCaches = new();

    // ==================== UI State ====================
    private string Host { get; set; } = "localhost";
    private int Port { get; set; } = 11000;
    private string PlayerName { get; set; } = "Player 1";
    private string Player2Name { get; set; } = "Player 2";
    private string _status = "Disconnected";
    private string _p2Status = "Disconnected";
    private bool _splitScreen;
    private bool _drawGrid = true;
    private bool _highQualityTextures = true;
    private bool _sidebarOpen = true;
    private bool _showScoreboard = true;
    private static readonly Dictionary<string, string> _opposites = new()
    {
        ["up"] = "down", ["down"] = "up", ["left"] = "right", ["right"] = "left"
    };

    // ==================== Inner Types ====================

    private class DeathAnim
    {
        public double ElapsedSeconds { get; set; }
        public IReadOnlyList<Point2D> Path { get; set; } = Array.Empty<Point2D>();
        public string Color { get; set; } = "orange";
        public bool IsFinished { get; set; }
    }

    // ==================== Lifecycle ====================

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Create P2 controllers (P1 uses DI-injected ones)
        _p2Network = new NetworkController();
        _p2Game = new GameController(_p2Network);

        await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/SnakeGUI.razor.js");
        _context = await _canvasReference!.CreateCanvas2DAsync();
        await JsRuntime.InvokeAsync<object>("initRenderJS", DotNetObjectReference.Create(this));

        _renderCts = new CancellationTokenSource();
        _ = Task.Run(() => RenderLoopAsync(_renderCts.Token));

        NetworkController.OnDisconnected += () => _ = InvokeAsync(() => { _status = "Disconnected"; StateHasChanged(); });
        _p2Network.OnDisconnected += () => _ = InvokeAsync(() => { _p2Status = "Disconnected"; StateHasChanged(); });

        GameController.OnPlayerDied += OnP1Died;
        _p2Game.OnPlayerDied += OnP2Died;
    }

    public void Dispose()
    {
        try { _renderCts?.Cancel(); } catch { }
        GameController.OnPlayerDied -= OnP1Died;
        if (_p2Game != null) _p2Game.OnPlayerDied -= OnP2Died;
        _p2Network?.Dispose();
    }

    // ==================== Input ====================

    [JSInvokable]
    public void UpdateViewportSize(int[] dims)
    {
        if (dims is { Length: 2 } && dims[0] > 0 && dims[1] > 0)
        {
            _viewW = dims[0];
            _viewH = dims[1];
        }
    }

    [JSInvokable]
    public void HandleKeyPress(string key)
    {
        // Shift respawn controls
        if (key == "ShiftLeft")
        {
            if (_showDeathScreen) { RespawnP1(); return; }
        }
        if (key == "ShiftRight")
        {
            if (_splitScreen && _p2ShowDeath) { RespawnP2(); return; }
            if (!_splitScreen && _showDeathScreen) { RespawnP1(); return; }
        }

        // WASD → P1
        var p1Cmd = key.ToLowerInvariant() switch
        {
            "w" => "up", "a" => "left", "s" => "down", "d" => "right",
            _ => (string?)null
        };
        if (p1Cmd != null)
        {
            if (_showDeathScreen || !_p1Ready) return;
            var heading = GetSnakeHeading(GameController);
            if (heading != null && _opposites.TryGetValue(p1Cmd, out var opp) && opp == heading) return;
            Interlocked.Exchange(ref _p1PendingMove, p1Cmd);
            return;
        }

        // Arrow keys → P2 when split screen is active; otherwise P1
        var arrowCmd = key switch
        {
            "ArrowUp" => "up", "ArrowLeft" => "left",
            "ArrowDown" => "down", "ArrowRight" => "right",
            _ => (string?)null
        };
        if (arrowCmd == null) return;

        if (_splitScreen && _p2Game != null)
        {
            if (_p2ShowDeath || !_p2Ready) return;
            var h2 = GetSnakeHeading(_p2Game);
            if (h2 != null && _opposites.TryGetValue(arrowCmd, out var opp2) && opp2 == h2) return;
            Interlocked.Exchange(ref _p2PendingMove, arrowCmd);
        }
        else
        {
            if (_showDeathScreen || !_p1Ready) return;
            var heading = GetSnakeHeading(GameController);
            if (heading != null && _opposites.TryGetValue(arrowCmd, out var opp) && opp == heading) return;
            Interlocked.Exchange(ref _p1PendingMove, arrowCmd);
        }
    }

    private static string? GetSnakeHeading(GameController gc)
    {
        var snake = gc.GetPlayerSnake();
        if (snake?.Body == null || snake.Body.Count < 2) return null;
        var head = snake.Body[^1];
        var neck = snake.Body[^2];
        var dx = head.X - neck.X;
        var dy = head.Y - neck.Y;
        if (dx == 0 && dy == 0) return null;
        return Math.Abs(dx) > Math.Abs(dy)
            ? (dx > 0 ? "right" : "left")
            : (dy > 0 ? "down" : "up");
    }

    // ==================== Connection ====================

    private async Task Connect(bool closeSidebar = true)
    {
        _showDeathScreen = false;
        _p1PendingMove = null;
        _p1Ready = false;
        if (closeSidebar) _sidebarOpen = false;
        _wallCaches.Remove(GameController);
        GameController.Disconnect();
        try
        {
            _status = "Connecting...";
            StateHasChanged();
            await GameController.ConnectAsync(Host, Port, PlayerName);
            _status = "Connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _status = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    private Task Reconnect() => Connect(closeSidebar: false);

    private async Task ConnectP2()
    {
        if (_p2Game == null) return;
        _p2ShowDeath = false;
        _p2PendingMove = null;
        _p2Ready = false;
        _wallCaches.Remove(_p2Game);
        _sidebarOpen = false;
        _p2Game.Disconnect();
        try
        {
            _p2Status = "Connecting...";
            StateHasChanged();
            await _p2Game.ConnectAsync(Host, Port, Player2Name);
            _p2Status = "Connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _p2Status = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    private void RespawnP1()
    {
        _showDeathScreen = false;
        _p1PendingMove = null;
        _ = GameController.SendMoveAsync("respawn");
        _ = InvokeAsync(StateHasChanged);
    }

    private void RespawnP2()
    {
        _p2ShowDeath = false;
        _p2PendingMove = null;
        if (_p2Game != null) _ = _p2Game.SendMoveAsync("respawn");
        _ = InvokeAsync(StateHasChanged);
    }

    private void Respawn() => RespawnP1();

    // ==================== Game State ====================

    private void OnP1Died()
    {
        if (_showDeathScreen) return;
        _showDeathScreen = true;
        _status = "Game Over";

        var player = GameController.GetPlayerSnake();
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _frozenCameraX = head.X;
            _frozenCameraY = head.Y;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    private void OnP2Died()
    {
        if (_p2ShowDeath) return;
        _p2ShowDeath = true;
        _p2Status = "Game Over";

        var player = _p2Game?.GetPlayerSnake();
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _p2FrozenCamX = head.X;
            _p2FrozenCamY = head.Y;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    // ==================== Render Loop ====================

    private async Task RenderLoopAsync(CancellationToken ct)
    {
        _frameStopwatch.Start();
        int tick = 0;
        try
        {
            while (!ct.IsCancellationRequested)
            {
                try
                {
                    // P1 move
                    var move1 = Interlocked.Exchange(ref _p1PendingMove, null);
                    if (move1 != null) _ = GameController.SendMoveAsync(move1);

                    // P2 move
                    if (_splitScreen && _p2Game != null)
                    {
                        var move2 = Interlocked.Exchange(ref _p2PendingMove, null);
                        if (move2 != null) _ = _p2Game.SendMoveAsync(move2);
                    }

                    await DrawFrame();

                    // Mark players ready once their snake has been rendered
                    if (!_p1Ready && GameController.GetPlayerSnake()?.Body?.Count > 0)
                        _p1Ready = true;
                    if (!_p2Ready && _p2Game?.GetPlayerSnake()?.Body?.Count > 0)
                        _p2Ready = true;

                    if (++tick % 6 == 0) await InvokeAsync(StateHasChanged);
                }
                catch { /* skip frame */ }
                await Task.Delay(FrameDelayMs, ct);
            }
        }
        catch (TaskCanceledException) { }
    }

    // ==================== Drawing ====================

    private async Task DrawFrame()
    {
        if (_context == null) return;

        var elapsed = _frameStopwatch.Elapsed.TotalSeconds;
        _frameStopwatch.Restart();

        await _context.BeginBatchAsync();
        await _context.SetFillStyleAsync(_highQualityTextures ? "#7c9c45" : "#e8f5ff");
        await _context.FillRectAsync(0, 0, _viewW, _viewH);

        if (_splitScreen && _p2Game != null)
        {
            var halfW = _viewW / 2;

            // Resolve P1 center target
            if (_centerTargetSnakeId.HasValue)
            {
                if (!GameController.GetSnakes().Any(s => s.Id == _centerTargetSnakeId.Value))
                    _centerTargetSnakeId = null;
            }

            // Left viewport — P1 (WASD)
            await DrawViewport(GameController, _p1DeathAnims, _showDeathScreen,
                _frozenCameraX, _frozenCameraY, _centerTargetSnakeId,
                0, 0, halfW, _viewH, elapsed);

            // Right viewport — P2 (Arrows)
            await DrawViewport(_p2Game, _p2DeathAnims, _p2ShowDeath,
                _p2FrozenCamX, _p2FrozenCamY, null,
                halfW, 0, halfW, _viewH, elapsed);

            // Divider line
            await _context.SetStrokeStyleAsync("rgba(255,255,255,0.4)");
            await _context.SetLineWidthAsync(2);
            await _context.BeginPathAsync();
            await _context.MoveToAsync(halfW, 0);
            await _context.LineToAsync(halfW, _viewH);
            await _context.StrokeAsync();

            // Player labels
            await _context.SetFillStyleAsync("rgba(255,255,255,0.5)");
            await _context.SetFontAsync("bold 16px Arial");
            await _context.FillTextAsync("P1 (WASD)", 10, 24);
            await _context.FillTextAsync("P2 (Arrows)", halfW + 10, 24);
        }
        else
        {
            // Resolve center target
            if (_centerTargetSnakeId.HasValue)
            {
                if (!GameController.GetSnakes().Any(s => s.Id == _centerTargetSnakeId.Value))
                    _centerTargetSnakeId = null;
            }

            await DrawViewport(GameController, _p1DeathAnims, _showDeathScreen,
                _frozenCameraX, _frozenCameraY, _centerTargetSnakeId,
                0, 0, _viewW, _viewH, elapsed);
        }

        await _context.EndBatchAsync();
    }

    private async Task DrawViewport(
        GameController gc, Dictionary<int, DeathAnim> deathAnims,
        bool showDeath, int frozenCamX, int frozenCamY, int? centerTargetId,
        int vx, int vy, int vw, int vh, double elapsed)
    {
        var worldSize = gc.WorldSize ?? 2000;

        Snake? centerSnake = null;
        if (centerTargetId.HasValue)
            centerSnake = gc.GetSnakes().FirstOrDefault(s => s.Id == centerTargetId.Value);
        centerSnake ??= gc.GetPlayerSnake();

        int centerX = 0, centerY = 0;
        if (showDeath) { centerX = frozenCamX; centerY = frozenCamY; }
        else if (centerSnake?.Body?.Count > 0)
        {
            var head = centerSnake.Body[^1];
            centerX = head.X;
            centerY = head.Y;
        }

        var halfWorld = worldSize / 2;
        var minCx = -halfWorld + vw / 2;
        var maxCx = halfWorld - vw / 2;
        var minCy = -halfWorld + vh / 2;
        var maxCy = halfWorld - vh / 2;
        if (minCx < maxCx) centerX = Math.Clamp(centerX, minCx, maxCx);
        else centerX = 0;
        if (minCy < maxCy) centerY = Math.Clamp(centerY, minCy, maxCy);
        else centerY = 0;

        await _context!.SaveAsync();
        await _context.BeginPathAsync();
        await _context.RectAsync(vx, vy, vw, vh);
        await _context.ClipAsync();

        var camX = Math.Round(vx + vw / 2.0 - centerX);
        var camY = Math.Round(vy + vh / 2.0 - centerY);
        await _context.TranslateAsync(camX, camY);

        if (_drawGrid && _highQualityTextures)
            await DrawGrid(worldSize);

        await DrawDeathAnimations(elapsed, deathAnims);
        await DrawWalls(gc);
        await DrawPowerups(gc);
        await DrawSnakes(gc, deathAnims, showDeath);

        // In-viewport "GAME OVER" text when dead in split mode
        if (showDeath && _splitScreen)
        {
            await _context.SetFillStyleAsync("rgba(255,68,68,0.7)");
            await _context.SetFontAsync("bold 48px Arial");
            await _context.FillTextAsync("GAME OVER", centerX - 140, centerY);
        }

        await _context.RestoreAsync();
    }

    private async Task DrawGrid(int worldSize)
    {
        await _context!.SetStrokeStyleAsync("rgba(0,0,0,0.05)");
        await _context.SetLineWidthAsync(2);
        await _context.BeginPathAsync();
        var hw = worldSize / 2;
        for (int i = -hw; i <= hw; i += GridSpacing)
        {
            await _context.MoveToAsync(i, -hw);
            await _context.LineToAsync(i, hw);
            await _context.MoveToAsync(-hw, i);
            await _context.LineToAsync(hw, i);
        }
        await _context.StrokeAsync();
    }

    private async Task DrawDeathAnimations(double elapsed, Dictionary<int, DeathAnim> deathAnims)
    {
        foreach (var (id, anim) in deathAnims)
        {
            if (anim.IsFinished) continue;

            var path = anim.Path;
            if (path == null || path.Count < 2) { anim.IsFinished = true; continue; }

            double totalLength = 0;
            var lengths = new List<double>();
            for (int i = 0; i < path.Count - 1; i++)
            {
                var dx = path[i + 1].X - path[i].X;
                var dy = path[i + 1].Y - path[i].Y;
                lengths.Add(Math.Sqrt(dx * dx + dy * dy));
                totalLength += lengths[^1];
            }

            double explosionSpeed = BitDistance / ExplosionDelay;
            double explodedLength = anim.ElapsedSeconds * explosionSpeed;
            double currentDist = 0;

            // Remaining body
            await _context!.SetStrokeStyleAsync(anim.Color);
            await _context.SetLineWidthAsync(SnakeWidth);
            await _context.SetLineCapAsync(LineCap.Round);
            await _context.SetLineJoinAsync(LineJoin.Round);
            await _context.BeginPathAsync();

            bool moved = false;
            for (int i = 0; i < path.Count - 1; i++)
            {
                var segLen = lengths[i];
                var segDistEnd = totalLength - currentDist;

                if (segDistEnd > explodedLength)
                {
                    if (!moved) { await _context.MoveToAsync(path[i].X, path[i].Y); moved = true; }
                    if (segDistEnd - segLen > explodedLength)
                        await _context.LineToAsync(path[i + 1].X, path[i + 1].Y);
                    else
                    {
                        var t = segLen > 0.001 ? (segDistEnd - explodedLength) / segLen : 0;
                        await _context.LineToAsync(
                            path[i].X + (path[i + 1].X - path[i].X) * t,
                            path[i].Y + (path[i + 1].Y - path[i].Y) * t);
                        break;
                    }
                }
                currentDist += segLen;
            }
            if (moved) await _context.StrokeAsync();

            // Explosion particles
            currentDist = 0;
            bool headParticleDone = false;
            for (int i = path.Count - 1; i > 0; i--)
            {
                var segLen = lengths[i - 1];
                double steps = Math.Max(1, Math.Ceiling(segLen / BitDistance));
                for (int j = 0; j <= steps; j++)
                {
                    var t = j / steps;
                    var ptDist = currentDist + segLen * t;
                    var timeSinceExplosion = anim.ElapsedSeconds - ptDist / explosionSpeed;

                    if (timeSinceExplosion >= 0 && timeSinceExplosion <= ParticleLifespan)
                    {
                        var bx = path[i].X + (path[i - 1].X - path[i].X) * t;
                        var by = path[i].Y + (path[i - 1].Y - path[i].Y) * t;
                        var bAlpha = Math.Max(0, 1.0 - timeSinceExplosion / ParticleLifespan);
                        bool isHead = !headParticleDone && ptDist < 1.0;
                        if (isHead) headParticleDone = true;
                        var baseRadius = isHead ? 10 : 3;
                        var expandFactor = isHead ? 25 : 12;
                        var bRadius = baseRadius + timeSinceExplosion / ParticleLifespan * expandFactor;

                        await _context.SetGlobalAlphaAsync((float)bAlpha);
                        await _context.SetFillStyleAsync(anim.Color);
                        await _context.BeginPathAsync();
                        await _context.ArcAsync(bx, by, bRadius, 0, Math.PI * 2);
                        await _context.FillAsync();
                    }
                }
                currentDist += segLen;
            }
            await _context.SetGlobalAlphaAsync(1.0f);

            anim.ElapsedSeconds += elapsed;
            if (anim.ElapsedSeconds > totalLength / explosionSpeed + 1.0)
                anim.IsFinished = true;
        }
    }

    private async Task DrawWalls(GameController gc)
    {
        var ctx = _context;
        if (ctx == null) return;

        var walls = gc.GetWalls();
        const int bs = BrickSize;

        if (!_highQualityTextures)
        {
            await ctx.SetFillStyleAsync("#555555");
            foreach (var w in walls)
            {
                if (w.Point1 == null || w.Point2 == null) continue;
                var (x, y, wdt, hgt) = WallRect(w);
                await ctx.FillRectAsync(x, y, wdt, hgt);
            }
            return;
        }

        // ── Step 1: Rasterize all walls into a global grid of occupied cells (cached) ──
        // Rebuild if the cache was built empty (race during handshake) but walls are now available
        if (!_wallCaches.TryGetValue(gc, out var occupied) ||
            (occupied.Count == 0 && walls.Count > 0))
        {
            occupied = new HashSet<(int cx, int cy)>();
            foreach (var w in walls)
            {
                if (w.Point1 == null || w.Point2 == null) continue;
                var (rx, ry, rw, rh) = WallRect(w);
                int cols = (int)Math.Round(rw / bs);
                int rows = (int)Math.Round(rh / bs);
                int startCx = (int)Math.Round(rx / bs);
                int startCy = (int)Math.Round(ry / bs);
                for (int r = 0; r < rows; r++)
                    for (int c = 0; c < cols; c++)
                        occupied.Add((startCx + c, startCy + r));
            }
            _wallCaches[gc] = occupied;
        }

        // ── Step 2: Mortar fill — each cell expanded on exposed sides to form the wall border ──
        const int border = 2;
        await ctx.SetFillStyleAsync("#2e3033");
        foreach (var (cx, cy) in occupied)
        {
            double px = cx * bs, py = cy * bs;
            bool nT = occupied.Contains((cx, cy - 1));
            bool nB = occupied.Contains((cx, cy + 1));
            bool nL = occupied.Contains((cx - 1, cy));
            bool nR = occupied.Contains((cx + 1, cy));
            double ex = px - (nL ? 0 : border);
            double ey = py - (nT ? 0 : border);
            double ew = bs + (nL ? 0 : border) + (nR ? 0 : border);
            double eh = bs + (nT ? 0 : border) + (nB ? 0 : border);
            await ctx.FillRectAsync(ex, ey, ew, eh);
        }

        // ── Step 3: Draw brick faces with running bond ──
        static int FM(int a, int b) => ((a % b) + b) % b;
        const int m = 1;

        foreach (var (cx, cy) in occupied)
        {
            double px = cx * bs, py = cy * bs;

            int topInset = m;
            int botInset = m;

            bool evenRow = FM(cy, 2) == 0;
            bool isJoint = evenRow ? FM(cx, 2) == 0 : FM(cx, 2) == 1;
            int leftInset = isJoint ? m : 0;
            int rightInset = isJoint ? 0 : m;

            double fx = px + leftInset;
            double fy = py + topInset;
            double fw = bs - leftInset - rightInset;
            double fh = bs - topInset - botInset;

            int brickCol = evenRow
                ? (int)Math.Floor(cx / 2.0)
                : (int)Math.Floor((cx - 1) / 2.0);
            int shade = FM(brickCol + cy, 2);
            await ctx.SetFillStyleAsync(shade == 0 ? "#787c80" : "#6a6e72");
            await ctx.FillRectAsync(fx, fy, fw, fh);
        }
    }

    private static (double x, double y, double w, double h) WallRect(Wall wall)
    {
        var x = (double)Math.Min(wall.Point1!.X, wall.Point2!.X) - WallHalfWidth;
        var y = (double)Math.Min(wall.Point1.Y, wall.Point2.Y) - WallHalfWidth;
        var wdt = (double)Math.Abs(wall.Point1.X - wall.Point2.X);
        var hgt = (double)Math.Abs(wall.Point1.Y - wall.Point2.Y);
        if (wdt == 0) { wdt = WallThickness; hgt += WallThickness; }
        else { hgt = WallThickness; wdt += WallThickness; }
        return (x, y, wdt, hgt);
    }

    private async Task DrawPowerups(GameController gc)
    {
        var ctx = _context;
        if (ctx == null) return;

        var now = DateTime.UtcNow;
        foreach (var p in gc.GetPowerups())
        {
            if (p.Location == null || p.Died) continue;
            var pulse = _highQualityTextures ? Math.Abs(Math.Sin(now.TimeOfDay.TotalSeconds * 5)) * 3 : 0;

            await ctx.SetFillStyleAsync("gold");
            await ctx.BeginPathAsync();
            await ctx.ArcAsync(p.Location.X, p.Location.Y, 8 + pulse, 0, Math.PI * 2);
            await ctx.FillAsync();

            if (_highQualityTextures)
            {
                await ctx.SetFillStyleAsync("yellow");
                await ctx.BeginPathAsync();
                await ctx.ArcAsync(p.Location.X, p.Location.Y, 4, 0, Math.PI * 2);
                await ctx.FillAsync();
            }
        }
    }

    private async Task DrawSnakes(GameController gc, Dictionary<int, DeathAnim> deathAnims, bool showDeath)
    {
        var playerId = gc.GetPlayerSnake()?.Id;
        foreach (var s in gc.GetSnakes())
        {
            if (s.Disconnected == true) continue;
            if (s.Alive != true) continue;
            if (deathAnims.ContainsKey(s.Id)) continue;
            if (s.Id == playerId && showDeath) continue;

            var body = s.Body;
            if (body == null || body.Count < 2) continue;
            var color = _colors[s.Id % _colors.Length];

            // Body
            await _context!.SetStrokeStyleAsync(color);
            await _context.SetLineWidthAsync(SnakeWidth);
            await _context.SetLineCapAsync(LineCap.Round);
            await _context.SetLineJoinAsync(LineJoin.Round);
            await _context.BeginPathAsync();
            await _context.MoveToAsync(body[0].X, body[0].Y);
            for (int i = 1; i < body.Count; i++)
                await _context.LineToAsync(body[i].X, body[i].Y);
            await _context.StrokeAsync();

            // Head
            var head = body[^1];
            if (_highQualityTextures)
            {
                await _context.SetFillStyleAsync("black");
                await _context.BeginPathAsync();
                await _context.ArcAsync(head.X, head.Y, HeadOuterRadius, 0, Math.PI * 2);
                await _context.FillAsync();
            }
            await _context.SetFillStyleAsync("white");
            await _context.BeginPathAsync();
            await _context.ArcAsync(head.X, head.Y, HeadMiddleRadius, 0, Math.PI * 2);
            await _context.FillAsync();
            await _context.SetFillStyleAsync(color);
            await _context.BeginPathAsync();
            await _context.ArcAsync(head.X, head.Y, HeadInnerRadius, 0, Math.PI * 2);
            await _context.FillAsync();

            // Nametag
            if (!string.IsNullOrEmpty(s.Name))
            {
                await _context.SetFillStyleAsync("white");
                await _context.SetFontAsync("bold 14px Arial");
                await _context.FillTextAsync($"{s.Name}: {s.Score ?? 0}", head.X + 12, head.Y - 12);
            }
        }

        // Create death animations for ANY snake that just died
        foreach (var s in gc.GetSnakes())
        {
            if ((s.Died == true || s.Alive != true) && s.Body?.Count >= 2 && !deathAnims.ContainsKey(s.Id) && s.Disconnected != true)
            {
                deathAnims[s.Id] = new DeathAnim
                {
                    Path = s.Body.ToList(),
                    Color = _colors[s.Id % _colors.Length]
                };
            }
            else if (s.Alive == true && deathAnims.ContainsKey(s.Id))
            {
                deathAnims.Remove(s.Id);
            }
        }
    }
}
