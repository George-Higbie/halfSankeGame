@page "/snake"
@layout GUI.Components.Layout.EmptyLayout
@implements IDisposable
@rendermode InteractiveServer
@using Blazor.Extensions
@using Blazor.Extensions.Canvas
@using Blazor.Extensions.Canvas.Canvas2D
@using System.Diagnostics
@using GUI.Components.Controllers
@using GUI.Components.Models
@using GUI.Components.Rendering
@using System.Linq
@inject IJSRuntime JsRuntime;
@inject GameController GameController
@inject GUI.Components.Controllers.NetworkController NetworkController

<PageTitle>Snake</PageTitle>

@* ── Sidebar Toggle(s) ── *@
@if (_splitScreen)
{
    <button class="sidebar-toggle sidebar-toggle-left" @onclick="(() => _p1SidebarOpen = !_p1SidebarOpen)">
        @(_p1SidebarOpen ? "✕" : "☰")
    </button>
    <button class="sidebar-toggle sidebar-toggle-right" @onclick="(() => _p2SidebarOpen = !_p2SidebarOpen)">
        @(_p2SidebarOpen ? "✕" : "☰")
    </button>
}
else
{
    <button class="sidebar-toggle sidebar-toggle-right" @onclick="(() => _sidebarOpen = !_sidebarOpen)">
        @(_sidebarOpen ? "✕" : "☰")
    </button>
}

@* ── P1 Sidebar (left in split, right in single) ── *@
<div class="snake-sidebar @(_splitScreen ? "snake-sidebar-left" : "") @((_splitScreen ? _p1SidebarOpen : _sidebarOpen) ? "open" : "")">
    <h2 style="margin:0 0 12px; font-size:1.1rem; letter-spacing:1px;">@(_splitScreen ? "PLAYER 1" : "SNAKE")</h2>

    <div class="field-group">
        <label>Host</label>
        <input @bind="Host" />
    </div>
    <div class="field-group">
        <label>Port</label>
        <input type="number" @bind="Port" />
    </div>
    <div class="field-group @(_p1MenuIndex == 0 ? "menu-focused" : "")">
        <label>@(_splitScreen ? "P1 Name" : "Name")</label>
        <input id="p1NameInput" @bind="PlayerName" disabled="@(_p1Playing)" />
    </div>

    <div class="skin-section @(_p1MenuIndex == 1 ? "menu-focused" : "")" style="margin-top:6px; padding:4px;">
        <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.5px;opacity:0.6;margin-bottom:4px;">@(_splitScreen ? "P1 Skin" : "Skin")</label>
        <div class="skin-grid">
            <SkinGrid SelectedIndex="_p1SkinIndex"
                      OnSkinSelected="((idx) => _p1SkinIndex = idx)"
                      IdPrefix="p1" />
        </div>
        <div class="skin-preview-bar">
            <BECanvas Width="160" Height="40" @ref="_p1PreviewRef"></BECanvas>
            <span style="font-size:0.72rem;opacity:0.6;">@SnakeSkin.AllSkins[_p1SkinIndex].Name</span>
        </div>
    </div>

    <div style="display:flex; gap:6px; margin-top:8px;">
        <button class="btn-snake @(_p1MenuIndex == 2 ? "menu-focused" : "")" @onclick="(() => Connect())">@(_splitScreen ? "Connect P1" : "Connect")</button>
        <button class="btn-snake btn-secondary @(_p1MenuIndex == 3 ? "menu-focused" : "")" @onclick="(() => Reconnect())">Reconnect</button>
    </div>

    <div class="status-line">@_status @if (_status == "Disconnected" || _status == "Game Over") { <span style="opacity:0.5; font-size:0.85em;">— @(_splitScreen ? "Left Shift" : "Shift") to start</span> }</div>

    <div style="margin-top:12px; border-top:1px solid rgba(255,255,255,0.1); padding-top:10px;">
        <label class="toggle @(_p1MenuIndex == 4 ? "menu-focused" : "")"><input type="checkbox" @bind="_highQualityTextures" /> High Quality</label>
        <label class="toggle @(_p1MenuIndex == 5 ? "menu-focused" : "")"><input type="checkbox" @bind="_drawGrid" /> Grid Overlay</label>
        <label class="toggle @(_p1MenuIndex == 6 ? "menu-focused" : "")"><input type="checkbox" @bind="_showScoreboard" /> Scoreboard</label>
        <label class="toggle @(_p1MenuIndex == 7 ? "menu-focused" : "")"><input type="checkbox" @bind="_splitScreen" /> Split Screen (2P)</label>
    </div>
</div>

@* ── P2 Sidebar (right side, split screen only) ── *@
@if (_splitScreen)
{
<div class="snake-sidebar @(_p2SidebarOpen ? "open" : "")">
    <h2 style="margin:0 0 12px; font-size:1.1rem; letter-spacing:1px;">PLAYER 2</h2>

    <div class="field-group @(_p2MenuIndex == 0 ? "menu-focused" : "")">
        <label>P2 Name</label>
        <input id="p2NameInput" @bind="Player2Name" disabled="@(_p2Playing)" />
    </div>

    <div class="skin-section @(_p2MenuIndex == 1 ? "menu-focused" : "")" style="margin-top:6px; padding:4px;">
        <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.5px;opacity:0.6;margin-bottom:4px;">P2 Skin</label>
        <div class="skin-grid">
            <SkinGrid SelectedIndex="_p2SkinIndex"
                      OnSkinSelected="((idx) => _p2SkinIndex = idx)"
                      IdPrefix="p2" />
        </div>
        <div class="skin-preview-bar">
            <BECanvas Width="160" Height="40" @ref="_p2PreviewRef"></BECanvas>
            <span style="font-size:0.72rem;opacity:0.6;">@SnakeSkin.AllSkins[_p2SkinIndex].Name</span>
        </div>
    </div>

    <div style="display:flex; gap:6px; margin-top:8px;">
        <button class="btn-snake @(_p2MenuIndex == 2 ? "menu-focused" : "")" @onclick="ConnectP2">Connect P2</button>
    </div>

    <div class="status-line">@_p2Status @if (_p2Status == "Disconnected" || _p2Status == "Game Over") { <span style="opacity:0.5; font-size:0.85em;">— Right Shift to start</span> }</div>
</div>
}

@* ── Canvas ── *@
<div id="snakeCanvas" style="position:fixed; inset:0; z-index:1; background:#7c9c45; overflow:hidden;">
    <BECanvas Width="1920" Height="1080" @ref="_canvasReference"></BECanvas>
</div>

@* ── Scoreboard Overlay ── *@
@if (_showScoreboard && GameController.PlayerId.HasValue)
{
    <div id="scoreboardOverlay" class="scoreboard-overlay">
        <strong>SCOREBOARD</strong>
        <ul>
            @foreach (var s in GameController.GetSnakes().Where(x => x.Alive == true).OrderByDescending(x => x.Score ?? 0))
            {
                <li @onclick="(() => { _centerTargetSnakeId = s.Id; })" class="@(s.Id == GameController.PlayerId ? "self" : "")">
                    <span>@(s.Name ?? "?")</span>
                    <span>@(s.Score ?? 0)</span>
                </li>
            }
        </ul>
    </div>
}

@* ── Death Overlay ── *@
@if (_showDeathScreen && !(_splitScreen ? _p1SidebarOpen : _sidebarOpen))
{
    <div class="death-overlay" style="@(_splitScreen ? "right:50%; left:0;" : "")">
        <h1>GAME OVER</h1>
        <div class="death-scores">
            <h3>High Scores</h3>
            <ul>
                @foreach (var s in GameController.GetSnakes().OrderByDescending(x => x.Score ?? 0).Take(5))
                {
                    <li>
                        <span>@(s.Name ?? "Anonymous")</span>
                        <span>@(s.Score ?? 0)</span>
                    </li>
                }
            </ul>
        </div>
        <button class="btn-respawn" @onclick="RespawnP1">Respawn</button>
        <span class="respawn-hint">@(_splitScreen ? "Shift to respawn • Tab for menu" : "Shift to respawn • Tab/Del for menu")</span>
    </div>
}
@if (_p2ShowDeath && _splitScreen && !_p2SidebarOpen)
{
    <div class="death-overlay" style="left:50%; right:0;">
        <h1>GAME OVER</h1>
        <div class="death-scores">
            <h3>High Scores</h3>
            <ul>
                @foreach (var s in (_p2Game?.GetSnakes() ?? Array.Empty<Snake>()).OrderByDescending(x => x.Score ?? 0).Take(5))
                {
                    <li>
                        <span>@(s.Name ?? "Anonymous")</span>
                        <span>@(s.Score ?? 0)</span>
                    </li>
                }
            </ul>
        </div>
        <button class="btn-respawn" @onclick="RespawnP2">Respawn</button>
        <span class="respawn-hint">Right Shift to respawn • Del for menu</span>
    </div>
}

@code
{
    // ==================== Constants ====================
    private const int FrameDelayMs = 16;

    // ==================== Private Fields ====================
    private readonly SnakeRenderer _renderer = new();
    private BECanvasComponent? _canvasReference;
    private Canvas2DContext? _context;
    private BECanvasComponent? _p1PreviewRef;
    private BECanvasComponent? _p2PreviewRef;
    private Canvas2DContext? _p1PreviewCtx;
    private Canvas2DContext? _p2PreviewCtx;
    private int _lastP1PreviewSkin = -1;
    private int _lastP2PreviewSkin = -1;
    private CancellationTokenSource? _renderCts;
    private readonly Stopwatch _frameStopwatch = new();
    private int _viewW = 1920;
    private int _viewH = 1080;

    // P1 per-player state (uses DI-injected controllers)
    private readonly Dictionary<int, SnakeRenderer.DeathAnim> _p1DeathAnims = new();
    private bool _showDeathScreen;
    private int _frozenCameraX;
    private int _frozenCameraY;
    private readonly List<string> _p1MoveQueue = new();
    private readonly object _p1MoveLock = new();
    private string? _p1LastSentDir;
    private int? _centerTargetSnakeId;
    private volatile bool _p1Ready;
    private readonly SnakeRenderer.CameraState _p1Cam = new();

    // P2 per-player state (manually created controllers)
    private NetworkController? _p2Network;
    private GameController? _p2Game;
    private readonly Dictionary<int, SnakeRenderer.DeathAnim> _p2DeathAnims = new();
    private bool _p2ShowDeath;
    private int _p2FrozenCamX;
    private int _p2FrozenCamY;
    private readonly List<string> _p2MoveQueue = new();
    private readonly object _p2MoveLock = new();
    private string? _p2LastSentDir;
    private volatile bool _p2Ready;
    private readonly SnakeRenderer.CameraState _p2Cam = new();

    // Head screen position for scoreboard dithering
    private double _p1HeadScreenX, _p1HeadScreenY;

    // ==================== UI State ====================
    private string Host { get; set; } = "localhost";
    private int Port { get; set; } = 11000;
    private string PlayerName { get; set; } = "Player 1";
    private string Player2Name { get; set; } = "Player 2";
    private string _status = "Disconnected";
    private string _p2Status = "Disconnected";
    private bool _splitScreen;
    private bool _wasSplitScreen;
    private bool _drawGrid = true;
    private bool _highQualityTextures = true;
    private bool _sidebarOpen = true;
    private bool _p1SidebarOpen = true;
    private bool _p2SidebarOpen = true;
    private int _p1MenuIndex = 1;
    private int _p2MenuIndex = 1;
    private const int P1MenuMax = 7;
    private const int P2MenuMax = 2;
    private bool _p1Playing => GameController.PlayerId.HasValue && !_showDeathScreen;
    private bool _p2Playing => _p2Game?.PlayerId.HasValue == true && !_p2ShowDeath;
    private bool _showScoreboard = true;
    private int _p1SkinIndex;
    private int _p2SkinIndex = 1;
    private static readonly Dictionary<string, string> _opposites = new()
    {
        ["up"] = "down", ["down"] = "up", ["left"] = "right", ["right"] = "left"
    };

    // Dither: compute star radius from snake-to-scoreboard distance.
    // Positive r = dithered (star shapes in mask). Negative = no dithering.
    // JS receives this every frame and builds the SVG mask directly on the DOM.
    private const double DitherCell = 5.0;
    private const double DitherHalf = DitherCell / 2.0;
    private const double DitherMaxR = DitherHalf * 2.0;   // overflows cell → clips to solid
    private const double DitherMinR = DitherHalf * 0.40;   // 1px → always visible dots

    private double ComputeDitherRadius()
    {
        const double sbLeft = 12, sbTop = 12, sbRight = 12 + 212, sbBottom = 12 + 180;
        const double fadeDistance = 80.0;

        double nearX = Math.Clamp(_p1HeadScreenX, sbLeft, sbRight);
        double nearY = Math.Clamp(_p1HeadScreenY, sbTop, sbBottom);
        double dx = _p1HeadScreenX - nearX;
        double dy = _p1HeadScreenY - nearY;
        double dist = Math.Sqrt(dx * dx + dy * dy);

        if (dist >= fadeDistance) return -1; // signal: no dithering

        double tLinear = 1.0 - dist / fadeDistance;
        double t = tLinear * tLinear;

        return DitherMaxR - t * (DitherMaxR - DitherMinR);
    }

    // ==================== Lifecycle ====================

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Create P2 controllers (P1 uses DI-injected ones)
        _p2Network = new NetworkController();
        _p2Game = new GameController(_p2Network);

        await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/SnakeGUI.razor.js");
        _context = await _canvasReference!.CreateCanvas2DAsync();
        await JsRuntime.InvokeAsync<object>("initRenderJS", DotNetObjectReference.Create(this));

        _renderCts = new CancellationTokenSource();
        _ = Task.Run(() => RenderLoopAsync(_renderCts.Token));

        NetworkController.OnDisconnected += () => _ = InvokeAsync(() => { _status = "Disconnected"; StateHasChanged(); });
        _p2Network.OnDisconnected += () => _ = InvokeAsync(() => { _p2Status = "Disconnected"; StateHasChanged(); });

        GameController.OnPlayerDied += OnP1Died;
        _p2Game.OnPlayerDied += OnP2Died;
    }

    public void Dispose()
    {
        try { _renderCts?.Cancel(); } catch { }
        GameController.OnPlayerDied -= OnP1Died;
        if (_p2Game != null) _p2Game.OnPlayerDied -= OnP2Died;
        _p2Network?.Dispose();
    }

    // ==================== Input ====================

    [JSInvokable]
    public void UpdateViewportSize(int[] dims)
    {
        if (dims is { Length: 2 } && dims[0] > 0 && dims[1] > 0)
        {
            _viewW = dims[0];
            _viewH = dims[1];
        }
    }

    [JSInvokable]
    public void HandleKeyPress(string key)
    {
        bool p1SidebarVis = _splitScreen ? _p1SidebarOpen : _sidebarOpen;
        bool p2SidebarVis = _splitScreen && _p2SidebarOpen;
        bool p1CanOpen = _showDeathScreen || !GameController.PlayerId.HasValue;
        bool p2CanOpen = _p2ShowDeath || _p2Game == null || _p2Game.PlayerId.HasValue != true;

        // ── Tab: P1 menu action / open ──
        if (key == "Tab")
        {
            if (p1SidebarVis)
                ActivateP1MenuItem();
            else if (!_splitScreen && !p1SidebarVis && p1CanOpen)
                OpenP1Sidebar();
            else if (_splitScreen && !_p1SidebarOpen && p1CanOpen)
                OpenP1Sidebar();
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        // ── Delete/Backspace: P2 action (split) or P1 fallback (single) ──
        if (key == "Delete" || key == "Backspace")
        {
            if (_splitScreen)
            {
                if (p2SidebarVis) ActivateP2MenuItem();
                else if (p2CanOpen) OpenP2Sidebar();
            }
            else
            {
                if (p1SidebarVis) ActivateP1MenuItem();
                else if (p1CanOpen) OpenP1Sidebar();
            }
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        // ── Enter: activate focused item in whichever sidebar is open ──
        if (key == "Enter")
        {
            if (p1SidebarVis) ActivateP1MenuItem();
            if (p2SidebarVis) ActivateP2MenuItem();
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        // ── Shift: respawn / connect ──
        if (key == "ShiftLeft")
        {
            if (_showDeathScreen) { RespawnP1(); return; }
            if (!GameController.PlayerId.HasValue && _status != "Connecting...")
            { _ = InvokeAsync(() => Connect()); return; }
            return;
        }
        if (key == "ShiftRight")
        {
            if (_splitScreen)
            {
                if (_p2ShowDeath) { RespawnP2(); return; }
                if (_p2Game != null && !_p2Game.PlayerId.HasValue && _p2Status != "Connecting...")
                { _ = InvokeAsync(() => ConnectP2()); return; }
                return;
            }
            // Single-player: Right Shift also controls P1
            if (_showDeathScreen) { RespawnP1(); return; }
            if (!GameController.PlayerId.HasValue && _status != "Connecting...")
            { _ = InvokeAsync(() => Connect()); return; }
            return;
        }

        // ── Escape: close open sidebar ──
        if (key == "Escape")
        {
            if (p1SidebarVis) { if (_splitScreen) _p1SidebarOpen = false; else _sidebarOpen = false; }
            if (p2SidebarVis) _p2SidebarOpen = false;
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        // ── WASD: P1 menu nav (when sidebar open) or movement ──
        var wasdDir = key.ToLowerInvariant() switch
        {
            "w" => "up", "a" => "left", "s" => "down", "d" => "right",
            _ => (string?)null
        };
        if (wasdDir != null)
        {
            if (p1SidebarVis)
            {
                NavigateMenu(ref _p1MenuIndex, P1MenuMax, wasdDir, isP1: true);
                _ = InvokeAsync(StateHasChanged);
            }
            else
            {
                if (_showDeathScreen || !_p1Ready) return;
                EnqueueMove(_p1MoveQueue, _p1MoveLock, wasdDir);
            }
            return;
        }

        // ── Arrow keys: P2 menu nav (split) or P1 fallback (single) ──
        var arrowDir = key switch
        {
            "ArrowUp" => "up", "ArrowLeft" => "left",
            "ArrowDown" => "down", "ArrowRight" => "right",
            _ => (string?)null
        };
        if (arrowDir == null) return;

        if (_splitScreen)
        {
            if (p2SidebarVis)
            {
                NavigateMenu(ref _p2MenuIndex, P2MenuMax, arrowDir, isP1: false);
                _ = InvokeAsync(StateHasChanged);
            }
            else
            {
                if (_p2ShowDeath || !_p2Ready || _p2Game == null) return;
                EnqueueMove(_p2MoveQueue, _p2MoveLock, arrowDir);
            }
        }
        else
        {
            if (p1SidebarVis)
            {
                NavigateMenu(ref _p1MenuIndex, P1MenuMax, arrowDir, isP1: true);
                _ = InvokeAsync(StateHasChanged);
            }
            else
            {
                if (_showDeathScreen || !_p1Ready) return;
                EnqueueMove(_p1MoveQueue, _p1MoveLock, arrowDir);
            }
        }
    }

    private void NavigateMenu(ref int idx, int max, string dir, bool isP1)
    {
        switch (dir)
        {
            case "up":
                idx = idx <= 0 ? max : idx - 1;
                break;
            case "down":
                idx = idx >= max ? 0 : idx + 1;
                break;
            case "left":
                if (idx == 1)
                {
                    if (isP1) _p1SkinIndex = (_p1SkinIndex - 1 + SnakeSkin.AllSkins.Length) % SnakeSkin.AllSkins.Length;
                    else _p2SkinIndex = (_p2SkinIndex - 1 + SnakeSkin.AllSkins.Length) % SnakeSkin.AllSkins.Length;
                }
                break;
            case "right":
                if (idx == 1)
                {
                    if (isP1) _p1SkinIndex = (_p1SkinIndex + 1) % SnakeSkin.AllSkins.Length;
                    else _p2SkinIndex = (_p2SkinIndex + 1) % SnakeSkin.AllSkins.Length;
                }
                break;
        }
    }

    private void ActivateP1MenuItem()
    {
        switch (_p1MenuIndex)
        {
            case 0: _ = JsRuntime.InvokeVoidAsync("focusSidebarInput", "p1NameInput"); break;
            case 1: break;
            case 2:
                if (_splitScreen) _p1SidebarOpen = false; else _sidebarOpen = false;
                _ = InvokeAsync(() => Connect());
                break;
            case 3:
                if (_splitScreen) _p1SidebarOpen = false; else _sidebarOpen = false;
                _ = InvokeAsync(() => Reconnect());
                break;
            case 4: _highQualityTextures = !_highQualityTextures; break;
            case 5: _drawGrid = !_drawGrid; break;
            case 6: _showScoreboard = !_showScoreboard; break;
            case 7: _splitScreen = !_splitScreen; break;
        }
    }

    private void ActivateP2MenuItem()
    {
        switch (_p2MenuIndex)
        {
            case 0: _ = JsRuntime.InvokeVoidAsync("focusSidebarInput", "p2NameInput"); break;
            case 1: break;
            case 2:
                _p2SidebarOpen = false;
                _ = InvokeAsync(() => ConnectP2());
                break;
        }
    }

    private void OpenP1Sidebar()
    {
        if (_splitScreen) _p1SidebarOpen = true; else _sidebarOpen = true;
        _p1MenuIndex = 1;
    }

    private void OpenP2Sidebar()
    {
        _p2SidebarOpen = true;
        _p2MenuIndex = 1;
    }

    private static string? GetSnakeHeading(GameController gc)
    {
        var snake = gc.GetPlayerSnake();
        if (snake?.Body == null || snake.Body.Count < 2) return null;
        var head = snake.Body[^1];
        var neck = snake.Body[^2];
        var dx = head.X - neck.X;
        var dy = head.Y - neck.Y;
        if (dx == 0 && dy == 0) return null;
        return Math.Abs(dx) > Math.Abs(dy)
            ? (dx > 0 ? "right" : "left")
            : (dy > 0 ? "down" : "up");
    }

    private static void EnqueueMove(List<string> queue, object queueLock, string cmd)
    {
        lock (queueLock)
        {
            if (queue.Count >= 2) return;
            if (queue.Count > 0 && queue[^1] == cmd) return;
            queue.Add(cmd);
        }
    }

    private static string? DequeueMove(List<string> queue, object queueLock, GameController gc, ref string? lastSentDir)
    {
        lock (queueLock)
        {
            if (queue.Count == 0) return null;

            var heading = lastSentDir ?? GetSnakeHeading(gc);

            if (queue.Count == 1)
            {
                var move = queue[0];
                queue.RemoveAt(0);
                if (heading != null && _opposites.TryGetValue(move, out var opp) && opp == heading)
                    return null;
                lastSentDir = move;
                return move;
            }

            var first = queue[0];
            var second = queue[1];
            bool firstIs180 = heading != null && _opposites.TryGetValue(first, out var o1) && o1 == heading;
            bool secondIs180 = heading != null && _opposites.TryGetValue(second, out var o2) && o2 == heading;

            if (firstIs180 && !secondIs180)
            {
                queue.RemoveAt(1);
                lastSentDir = second;
                return second;
            }

            queue.RemoveAt(0);
            if (firstIs180) return null;
            lastSentDir = first;
            return first;
        }
    }

    // ==================== Connection ====================

    private async Task Connect(bool closeSidebar = true)
    {
        _showDeathScreen = false;
        lock (_p1MoveLock) _p1MoveQueue.Clear();
        _p1LastSentDir = null;
        _p1Ready = false;
        _p1Cam.Reset();
        if (closeSidebar)
        {
            if (_splitScreen) _p1SidebarOpen = false;
            else _sidebarOpen = false;
        }
        _renderer.ClearWallCache(GameController);
        GameController.Disconnect();
        try
        {
            _status = "Connecting...";
            StateHasChanged();
            await GameController.ConnectAsync(Host, Port, PlayerName, _p1SkinIndex);
            _status = "Connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _status = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    private Task Reconnect() => Connect(closeSidebar: false);

    private async Task ConnectP2()
    {
        if (_p2Game == null) return;
        _p2ShowDeath = false;
        lock (_p2MoveLock) _p2MoveQueue.Clear();
        _p2LastSentDir = null;
        _p2Ready = false;
        _p2Cam.Reset();
        _renderer.ClearWallCache(_p2Game);
        _p2SidebarOpen = false;
        _p2Game.Disconnect();
        try
        {
            _p2Status = "Connecting...";
            StateHasChanged();
            await _p2Game.ConnectAsync(Host, Port, Player2Name, _p2SkinIndex);
            _p2Status = "Connected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _p2Status = "Error: " + ex.Message;
            StateHasChanged();
        }
    }

    private void RespawnP1()
    {
        _showDeathScreen = false;
        if (_splitScreen) _p1SidebarOpen = false; else _sidebarOpen = false;
        lock (_p1MoveLock) _p1MoveQueue.Clear();
        _p1LastSentDir = null;
        _ = GameController.SendMoveAsync("respawn");
        _ = InvokeAsync(StateHasChanged);
    }

    private void RespawnP2()
    {
        _p2ShowDeath = false;
        _p2SidebarOpen = false;
        lock (_p2MoveLock) _p2MoveQueue.Clear();
        _p2LastSentDir = null;
        if (_p2Game != null) _ = _p2Game.SendMoveAsync("respawn");
        _ = InvokeAsync(StateHasChanged);
    }

    private void Respawn() => RespawnP1();

    // ==================== Game State ====================

    private void OnP1Died()
    {
        if (_showDeathScreen) return;
        _showDeathScreen = true;
        _status = "Game Over";

        var player = GameController.GetPlayerSnake();
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _frozenCameraX = head.X;
            _frozenCameraY = head.Y;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    private void OnP2Died()
    {
        if (_p2ShowDeath) return;
        _p2ShowDeath = true;
        _p2Status = "Game Over";

        var player = _p2Game?.GetPlayerSnake();
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _p2FrozenCamX = head.X;
            _p2FrozenCamY = head.Y;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    // ==================== Render Loop ====================

    private async Task RenderLoopAsync(CancellationToken ct)
    {
        _frameStopwatch.Start();
        int tick = 0;
        var frameSw = new Stopwatch();
        try
        {
            while (!ct.IsCancellationRequested)
            {
                frameSw.Restart();
                try
                {
                    // P1 move
                    var move1 = DequeueMove(_p1MoveQueue, _p1MoveLock, GameController, ref _p1LastSentDir);
                    if (move1 != null) _ = GameController.SendMoveAsync(move1);

                    // P2 move
                    if (_splitScreen && _p2Game != null)
                    {
                        var move2 = DequeueMove(_p2MoveQueue, _p2MoveLock, _p2Game, ref _p2LastSentDir);
                        if (move2 != null) _ = _p2Game.SendMoveAsync(move2);
                    }

                    await DrawFrame();

                    // Mark players ready once their snake has been rendered
                    if (!_p1Ready && GameController.GetPlayerSnake()?.Body?.Count > 0)
                        _p1Ready = true;
                    if (!_p2Ready && _p2Game?.GetPlayerSnake()?.Body?.Count > 0)
                        _p2Ready = true;

                    if (++tick % 6 == 0) await InvokeAsync(StateHasChanged);
                }
                catch { /* skip frame */ }
                var drawMs = (int)frameSw.ElapsedMilliseconds;
                var remaining = FrameDelayMs - drawMs;
                if (remaining > 0)
                    await Task.Delay(remaining, ct);
            }
        }
        catch (TaskCanceledException) { }
    }

    // ==================== Drawing ====================

    private async Task DrawFrame()
    {
        if (_context == null) return;

        var elapsed = _frameStopwatch.Elapsed.TotalSeconds;
        _frameStopwatch.Restart();

        await _context.BeginBatchAsync();
        await _context.SetFillStyleAsync(_highQualityTextures ? "#7c9c45" : "#e8f5ff");
        await _context.FillRectAsync(0, 0, _viewW, _viewH);

        if (_splitScreen && _p2Game != null)
        {
            var halfW = _viewW / 2;

            // Resolve P1 center target
            if (_centerTargetSnakeId.HasValue)
            {
                if (!GameController.GetSnakes().Any(s => s.Id == _centerTargetSnakeId.Value))
                    _centerTargetSnakeId = null;
            }

            // Left viewport — P1 (WASD)
            var p1Head = await _renderer.DrawViewport(_context, GameController, _p1DeathAnims, _showDeathScreen,
                _frozenCameraX, _frozenCameraY, _centerTargetSnakeId,
                0, 0, halfW, _viewH, elapsed, _p1Cam, SnakeSkin.AllSkins[_p1SkinIndex], _drawGrid, _highQualityTextures);
            if (p1Head.HasValue) { _p1HeadScreenX = p1Head.Value.headX; _p1HeadScreenY = p1Head.Value.headY; }

            // Right viewport — P2 (Arrows)
            await _renderer.DrawViewport(_context, _p2Game, _p2DeathAnims, _p2ShowDeath,
                _p2FrozenCamX, _p2FrozenCamY, null,
                halfW, 0, halfW, _viewH, elapsed, _p2Cam, SnakeSkin.AllSkins[_p2SkinIndex], _drawGrid, _highQualityTextures);

            // Divider line
            await _context.SetStrokeStyleAsync("rgba(255,255,255,0.4)");
            await _context.SetLineWidthAsync(2);
            await _context.BeginPathAsync();
            await _context.MoveToAsync(halfW, 0);
            await _context.LineToAsync(halfW, _viewH);
            await _context.StrokeAsync();

            // Player labels
            await _context.SetFillStyleAsync("rgba(255,255,255,0.5)");
            await _context.SetFontAsync("bold 16px Arial");
            await _context.FillTextAsync("P1 (WASD)", 10, 24);
            await _context.FillTextAsync("P2 (Arrows)", halfW + 10, 24);
        }
        else
        {
            // Resolve center target
            if (_centerTargetSnakeId.HasValue)
            {
                if (!GameController.GetSnakes().Any(s => s.Id == _centerTargetSnakeId.Value))
                    _centerTargetSnakeId = null;
            }

            var p1Head = await _renderer.DrawViewport(_context, GameController, _p1DeathAnims, _showDeathScreen,
                _frozenCameraX, _frozenCameraY, _centerTargetSnakeId,
                0, 0, _viewW, _viewH, elapsed, _p1Cam, SnakeSkin.AllSkins[_p1SkinIndex], _drawGrid, _highQualityTextures);
            if (p1Head.HasValue) { _p1HeadScreenX = p1Head.Value.headX; _p1HeadScreenY = p1Head.Value.headY; }
        }

        await _context.EndBatchAsync();

        // Redraw skin previews when selection changes
        if (_p1SkinIndex != _lastP1PreviewSkin)
        {
            _p1PreviewCtx ??= _p1PreviewRef != null ? await _p1PreviewRef.CreateCanvas2DAsync() : null;
            if (_p1PreviewCtx != null) { await _renderer.DrawSkinPreview(_p1PreviewCtx, SnakeSkin.AllSkins[_p1SkinIndex]); _lastP1PreviewSkin = _p1SkinIndex; }
        }
        // Invalidate P2 preview when split-screen is (re-)enabled — the BECanvas DOM element
        // is destroyed on toggle-off and recreated on toggle-on, making the old context stale.
        if (_splitScreen && !_wasSplitScreen)
        {
            _p2PreviewCtx = null;
            _lastP2PreviewSkin = -1;
        }
        _wasSplitScreen = _splitScreen;

        if (_splitScreen && (_p2SkinIndex != _lastP2PreviewSkin || _p2PreviewCtx == null))
        {
            _p2PreviewCtx = _p2PreviewRef != null ? await _p2PreviewRef.CreateCanvas2DAsync() : null;
            if (_p2PreviewCtx != null) { await _renderer.DrawSkinPreview(_p2PreviewCtx, SnakeSkin.AllSkins[_p2SkinIndex]); _lastP2PreviewSkin = _p2SkinIndex; }
        }

        // Update scoreboard dither mask every frame via JS (bypasses Blazor render cycle)
        if (_showScoreboard && GameController.PlayerId.HasValue)
        {
            double ditherR = ComputeDitherRadius();
            await JsRuntime.InvokeVoidAsync("updateScoreboardDither", ditherR);
        }
    }
}
