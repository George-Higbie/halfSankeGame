@page "/snake"
@layout GUI.Components.Layout.EmptyLayout
@implements IDisposable
@rendermode InteractiveServer
@using Blazor.Extensions
@using Blazor.Extensions.Canvas
@using Blazor.Extensions.Canvas.Canvas2D
@using System.Diagnostics
@using GUI.Components.Controllers
@using GUI.Components.Models
@using System.Linq
@inject IJSRuntime JsRuntime;
@inject GameController GameController
@inject GUI.Components.Controllers.NetworkController NetworkController

<PageTitle>Snake</PageTitle>

@* ── Sidebar Toggle ── *@
<button class="sidebar-toggle" @onclick="(() => _sidebarOpen = !_sidebarOpen)">
    @(_sidebarOpen ? "✕" : "☰")
</button>

@* ── Sidebar ── *@
<div class="snake-sidebar @(_sidebarOpen ? "open" : "")">
    <h2 style="margin:0 0 12px; font-size:1.3rem; letter-spacing:1px;">SNAKE</h2>

    <div class="field-group">
        <label>Host</label>
        <input @bind="Host" />
    </div>
    <div class="field-group">
        <label>Port</label>
        <input type="number" @bind="Port" />
    </div>
    <div class="field-group">
        <label>@(_splitScreen ? "P1 Name" : "Name")</label>
        <input @bind="PlayerName" />
    </div>

    <div style="margin-top:6px;">
        <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.5px;opacity:0.6;margin-bottom:4px;">@(_splitScreen ? "P1 Skin" : "Skin")</label>
        <div class="skin-grid">
            @for (int i = 0; i < SnakeSkin.AllSkins.Length; i++)
            {
                var idx = i;
                var skin = SnakeSkin.AllSkins[idx];
                <button class="skin-tile @(idx == _p1SkinIndex ? "skin-active" : "")"
                        @onclick="(() => _p1SkinIndex = idx)" title="@skin.Name">
                    <svg width="18" height="18" viewBox="0 0 18 18">
                        <defs><clipPath id="p1c@(idx)"><circle cx="9" cy="9" r="8"/></clipPath></defs>
                        <circle cx="9" cy="9" r="8" fill="@skin.BodyColor"/>
                        @if (skin.Pattern == BodyPattern.Stripe && skin.BodyAccent != null)
                        {
                            <line x1="1" y1="6" x2="17" y2="6" stroke="@skin.BodyAccent" stroke-width="2" clip-path="url(#p1c@(idx))"/>
                            <line x1="1" y1="12" x2="17" y2="12" stroke="@(skin.BodyAccent2 ?? skin.BodyAccent)" stroke-width="2" clip-path="url(#p1c@(idx))"/>
                        }
                        else if (skin.Pattern == BodyPattern.Diamond && skin.BodyAccent != null)
                        {
                            <polygon points="9,3 13,9 9,15 5,9" fill="@skin.BodyAccent" opacity="0.6" clip-path="url(#p1c@(idx))"/>
                        }
                        else if (skin.Pattern == BodyPattern.Checker && skin.BodyAccent != null)
                        {
                            <rect x="1" y="1" width="8" height="8" fill="@skin.BodyAccent" opacity="0.5" clip-path="url(#p1c@(idx))"/>
                            <rect x="9" y="9" width="8" height="8" fill="@(skin.BodyAccent2 ?? skin.BodyAccent)" opacity="0.5" clip-path="url(#p1c@(idx))"/>
                        }
                        else if (skin.Pattern == BodyPattern.Wave && skin.BodyAccent != null)
                        {
                            <path d="M1,9 Q5,5 9,9 Q13,13 17,9" stroke="@skin.BodyAccent" stroke-width="2" fill="none" opacity="0.7" clip-path="url(#p1c@(idx))"/>
                        }
                        <circle cx="7" cy="7" r="3" fill="white" opacity="0.15"/>
                    </svg>
                </button>
            }
        </div>
        <div class="skin-preview-bar">
            <BECanvas Width="160" Height="40" @ref="_p1PreviewRef"></BECanvas>
            <span style="font-size:0.72rem;opacity:0.6;">@SnakeSkin.AllSkins[_p1SkinIndex].Name</span>
        </div>
    </div>

    <div style="display:flex; gap:6px; margin-top:8px;">
        <button class="btn-snake" @onclick="(() => Connect())">@(_splitScreen ? "Connect P1" : "Connect")</button>
        <button class="btn-snake btn-secondary" @onclick="(() => Reconnect())">Reconnect</button>
    </div>

    <div class="status-line">@_status</div>

    <div style="margin-top:12px; border-top:1px solid rgba(255,255,255,0.1); padding-top:10px;">
        <label class="toggle"><input type="checkbox" @bind="_highQualityTextures" /> High Quality</label>
        <label class="toggle"><input type="checkbox" @bind="_drawGrid" /> Grid Overlay</label>
        <label class="toggle"><input type="checkbox" @bind="_showScoreboard" /> Scoreboard</label>
        <label class="toggle"><input type="checkbox" @bind="_splitScreen" /> Split Screen (2P)</label>
    </div>

    @if (_splitScreen)
    {
    <div style="margin-top:12px; border-top:1px solid rgba(255,255,255,0.1); padding-top:10px;">
        <strong style="font-size:0.85rem; text-transform:uppercase; letter-spacing:1px; opacity:0.7;">Player 2 (Arrows)</strong>
        <div class="field-group" style="margin-top:6px;">
            <label>P2 Name</label>
            <input @bind="Player2Name" />
        </div>
        <div style="margin-top:6px;">
            <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.5px;opacity:0.6;margin-bottom:4px;">P2 Skin</label>
            <div class="skin-grid">
                @for (int i = 0; i < SnakeSkin.AllSkins.Length; i++)
                {
                    var idx = i;
                    var skin = SnakeSkin.AllSkins[idx];
                    <button class="skin-tile @(idx == _p2SkinIndex ? "skin-active" : "")"
                            @onclick="(() => _p2SkinIndex = idx)" title="@skin.Name">
                        <svg width="18" height="18" viewBox="0 0 18 18">
                            <defs><clipPath id="p2c@(idx)"><circle cx="9" cy="9" r="8"/></clipPath></defs>
                            <circle cx="9" cy="9" r="8" fill="@skin.BodyColor"/>
                            @if (skin.Pattern == BodyPattern.Stripe && skin.BodyAccent != null)
                            {
                                <line x1="1" y1="6" x2="17" y2="6" stroke="@skin.BodyAccent" stroke-width="2" clip-path="url(#p2c@(idx))"/>
                                <line x1="1" y1="12" x2="17" y2="12" stroke="@(skin.BodyAccent2 ?? skin.BodyAccent)" stroke-width="2" clip-path="url(#p2c@(idx))"/>
                            }
                            else if (skin.Pattern == BodyPattern.Diamond && skin.BodyAccent != null)
                            {
                                <polygon points="9,3 13,9 9,15 5,9" fill="@skin.BodyAccent" opacity="0.6" clip-path="url(#p2c@(idx))"/>
                            }
                            else if (skin.Pattern == BodyPattern.Checker && skin.BodyAccent != null)
                            {
                                <rect x="1" y="1" width="8" height="8" fill="@skin.BodyAccent" opacity="0.5" clip-path="url(#p2c@(idx))"/>
                                <rect x="9" y="9" width="8" height="8" fill="@(skin.BodyAccent2 ?? skin.BodyAccent)" opacity="0.5" clip-path="url(#p2c@(idx))"/>
                            }
                            else if (skin.Pattern == BodyPattern.Wave && skin.BodyAccent != null)
                            {
                                <path d="M1,9 Q5,5 9,9 Q13,13 17,9" stroke="@skin.BodyAccent" stroke-width="2" fill="none" opacity="0.7" clip-path="url(#p2c@(idx))"/>
                            }
                            <circle cx="7" cy="7" r="3" fill="white" opacity="0.15"/>
                        </svg>
                    </button>
                }
            </div>
            <div class="skin-preview-bar">
                <BECanvas Width="160" Height="40" @ref="_p2PreviewRef"></BECanvas>
                <span style="font-size:0.72rem;opacity:0.6;">@SnakeSkin.AllSkins[_p2SkinIndex].Name</span>
            </div>
        </div>
        <div style="display:flex; gap:6px; margin-top:8px;">
            <button class="btn-snake" @onclick="ConnectP2">Connect P2</button>
        </div>
        <div class="status-line">@_p2Status</div>
    </div>
    }

</div>

@* ── Canvas ── *@
<div id="snakeCanvas" style="position:fixed; inset:0; z-index:1; background:#7c9c45; overflow:hidden;">
    <BECanvas Width="1920" Height="1080" @ref="_canvasReference"></BECanvas>
</div>

@* ── Scoreboard Overlay ── *@
@if (_showScoreboard && GameController.PlayerId.HasValue)
{
    <div id="scoreboardOverlay" class="scoreboard-overlay">
        <strong>SCOREBOARD</strong>
        <ul>
            @foreach (var s in GameController.GetSnakes().Where(x => x.Alive == true).OrderByDescending(x => x.Score ?? 0))
            {
                <li @onclick="(() => { _centerTargetSnakeId = s.Id; })" class="@(s.Id == GameController.PlayerId ? "self" : "")">
                    <span>@(s.Name ?? "?")</span>
                    <span>@(s.Score ?? 0)</span>
                </li>
            }
        </ul>
    </div>
}

@* ── Death Overlay ── *@
@if (_showDeathScreen)
{
    <div class="death-overlay" style="@(_splitScreen ? "right:50%; left:0;" : "")">
        @if (_p1ShowMenu)
        {
            <div class="death-menu">
                <h2 style="margin:0 0 16px; font-size:1.5rem; letter-spacing:2px;">MENU</h2>
                <div class="menu-item @(_p1MenuFocus == 0 ? "menu-focused" : "")">
                    <label style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px; opacity:0.6;">Skin</label>
                    <div class="menu-skin-selector">
                        <span class="menu-arrow @(_p1MenuFocus == 0 ? "" : "dim")">◀</span>
                        <div class="skin-preview-bar" style="margin:0; flex:1; justify-content:center;">
                            @{ var ms1 = SnakeSkin.AllSkins[_p1SkinIndex]; }
                            <svg width="80" height="22" viewBox="0 0 100 22">
                                <path d="M 5 11 Q 15 5, 30 11 Q 45 17, 60 11 Q 75 5, 85 11"
                                      stroke="@ms1.BodyColor" stroke-width="7" fill="none" stroke-linecap="round"/>
                                <circle cx="88" cy="11" r="4" fill="@ms1.HeadColor"/>
                                <circle cx="89.5" cy="9.5" r="1.2" fill="@ms1.EyeColor"/>
                                <circle cx="89.5" cy="12.5" r="1.2" fill="@ms1.EyeColor"/>
                            </svg>
                            <span style="font-size:0.75rem; opacity:0.8;">@ms1.Name</span>
                        </div>
                        <span class="menu-arrow @(_p1MenuFocus == 0 ? "" : "dim")">▶</span>
                    </div>
                </div>
                <div class="menu-item menu-btn @(_p1MenuFocus == 1 ? "menu-focused" : "")" @onclick="(() => { _p1ShowMenu = false; RespawnP1(); })">
                    Respawn
                </div>
                <div class="menu-item menu-btn @(_p1MenuFocus == 2 ? "menu-focused" : "")" @onclick="(() => { _p1ShowMenu = false; _ = Connect(); })">
                    Reconnect
                </div>
                <span class="menu-hint">@(_splitScreen ? "W/S: Navigate • A/D: Skin • Shift: Select • Tab: Close" : "W/S or ↑↓: Navigate • A/D or ←→: Skin • Shift/Enter: Select • Tab/Del: Close")</span>
            </div>
        }
        else
        {
            <h1>GAME OVER</h1>
            <div class="death-scores">
                <h3>High Scores</h3>
                <ul>
                    @foreach (var s in GameController.GetSnakes().OrderByDescending(x => x.Score ?? 0).Take(5))
                    {
                        <li>
                            <span>@(s.Name ?? "Anonymous")</span>
                            <span>@(s.Score ?? 0)</span>
                        </li>
                    }
                </ul>
            </div>
            <button class="btn-respawn" @onclick="RespawnP1">Respawn</button>
            <span class="respawn-hint">@(_splitScreen ? "Shift to respawn • Tab for menu" : "Shift to respawn • Tab or Del for menu")</span>
        }
    </div>
}
@if (_p2ShowDeath && _splitScreen)
{
    <div class="death-overlay" style="left:50%; right:0;">
        @if (_p2ShowMenu)
        {
            <div class="death-menu">
                <h2 style="margin:0 0 16px; font-size:1.5rem; letter-spacing:2px;">MENU</h2>
                <div class="menu-item @(_p2MenuFocus == 0 ? "menu-focused" : "")">
                    <label style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px; opacity:0.6;">Skin</label>
                    <div class="menu-skin-selector">
                        <span class="menu-arrow @(_p2MenuFocus == 0 ? "" : "dim")">◀</span>
                        <div class="skin-preview-bar" style="margin:0; flex:1; justify-content:center;">
                            @{ var ms2 = SnakeSkin.AllSkins[_p2SkinIndex]; }
                            <svg width="80" height="22" viewBox="0 0 100 22">
                                <path d="M 5 11 Q 15 5, 30 11 Q 45 17, 60 11 Q 75 5, 85 11"
                                      stroke="@ms2.BodyColor" stroke-width="7" fill="none" stroke-linecap="round"/>
                                <circle cx="88" cy="11" r="4" fill="@ms2.HeadColor"/>
                                <circle cx="89.5" cy="9.5" r="1.2" fill="@ms2.EyeColor"/>
                                <circle cx="89.5" cy="12.5" r="1.2" fill="@ms2.EyeColor"/>
                            </svg>
                            <span style="font-size:0.75rem; opacity:0.8;">@ms2.Name</span>
                        </div>
                        <span class="menu-arrow @(_p2MenuFocus == 0 ? "" : "dim")">▶</span>
                    </div>
                </div>
                <div class="menu-item menu-btn @(_p2MenuFocus == 1 ? "menu-focused" : "")" @onclick="(() => { _p2ShowMenu = false; RespawnP2(); })">
                    Respawn
                </div>
                <div class="menu-item menu-btn @(_p2MenuFocus == 2 ? "menu-focused" : "")" @onclick="(() => { _p2ShowMenu = false; _ = ConnectP2(); })">
                    Reconnect
                </div>
                <span class="menu-hint">↑↓: Navigate • ←→: Skin • Enter: Select • Del: Close</span>
            </div>
        }
        else
        {
            <h1>GAME OVER</h1>
            <div class="death-scores">
                <h3>High Scores</h3>
                <ul>
                    @foreach (var s in (_p2Game?.GetSnakes() ?? Array.Empty<Snake>()).OrderByDescending(x => x.Score ?? 0).Take(5))
                    {
                        <li>
                            <span>@(s.Name ?? "Anonymous")</span>
                            <span>@(s.Score ?? 0)</span>
                        </li>
                    }
                </ul>
            </div>
            <button class="btn-respawn" @onclick="RespawnP2">Respawn</button>
            <span class="respawn-hint">Right Shift to respawn • Del for menu</span>
        }
    </div>
}

@* ── Scoped Styles ── *@
<style>
    .snake-sidebar {
        position: fixed;
        right: 0; top: 0; bottom: 0;
        width: 220px;
        z-index: 10;
        background: rgba(18, 18, 24, 0.92);
        backdrop-filter: blur(12px);
        color: #e0e0e0;
        padding: 20px 16px;
        font-family: 'Segoe UI', system-ui, sans-serif;
        font-size: 0.9rem;
        overflow-y: auto;
        border-left: 1px solid rgba(255,255,255,0.06);
        transform: translateX(100%);
        transition: transform 0.2s ease;
    }
    .snake-sidebar.open {
        transform: translateX(0);
    }
    .sidebar-toggle {
        position: fixed;
        right: 12px; top: 12px;
        z-index: 20;
        width: 36px; height: 36px;
        border: none;
        border-radius: 6px;
        background: rgba(18, 18, 24, 0.7);
        color: #e0e0e0;
        font-size: 1.2rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
        transition: background 0.15s;
    }
    .sidebar-toggle:hover { background: rgba(18, 18, 24, 0.9); }
    .snake-sidebar .field-group {
        margin-bottom: 6px;
    }
    .snake-sidebar .field-group label {
        display: block;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.6;
        margin-bottom: 2px;
    }
    .snake-sidebar input[type="text"],
    .snake-sidebar input[type="number"],
    .snake-sidebar input:not([type]) {
        width: 100%;
        padding: 6px 8px;
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 4px;
        background: rgba(255,255,255,0.08);
        color: #fff;
        font-size: 0.85rem;
        box-sizing: border-box;
    }
    .snake-sidebar input:focus {
        outline: none;
        border-color: #4caf50;
    }
    .btn-snake {
        flex: 1;
        padding: 7px 0;
        border: none;
        border-radius: 4px;
        background: #4caf50;
        color: #fff;
        font-weight: 600;
        font-size: 0.8rem;
        cursor: pointer;
        transition: background 0.15s;
    }
    .btn-snake:hover { background: #43a047; }
    .btn-snake.btn-secondary {
        background: rgba(255,255,255,0.1);
    }
    .btn-snake.btn-secondary:hover { background: rgba(255,255,255,0.18); }
    .status-line {
        margin-top: 8px;
        font-size: 0.8rem;
        opacity: 0.7;
    }
    .toggle {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.82rem;
        margin-bottom: 4px;
        cursor: pointer;
    }
    .scoreboard-overlay {
        position: fixed;
        top: 12px;
        left: 12px;
        z-index: 5;
        background: rgba(18, 18, 24, 0.75);
        backdrop-filter: blur(8px);
        border-radius: 8px;
        padding: 12px 16px;
        color: #e0e0e0;
        font-family: 'Segoe UI', system-ui, sans-serif;
        font-size: 0.85rem;
        min-width: 180px;
        -webkit-mask-repeat: repeat;
        mask-repeat: repeat;
        -webkit-mask-size: 5px 5px;
        mask-size: 5px 5px;
    }
    .scoreboard-overlay strong {
        display: block;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.7;
        margin-bottom: 8px;
    }
    .scoreboard-overlay ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .scoreboard-overlay li {
        display: flex;
        justify-content: space-between;
        padding: 3px 6px;
        border-radius: 3px;
        cursor: pointer;
        font-size: 0.82rem;
        transition: background 0.1s;
    }
    .scoreboard-overlay li:hover {
        background: rgba(255,255,255,0.1);
    }
    .scoreboard-overlay li.self {
        background: rgba(76,175,80,0.2);
    }

    /* Death overlay */
    .death-overlay {
        position: fixed;
        inset: 0;
        z-index: 20;
        background: rgba(0,0,0,0.75);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: #fff;
        animation: fadeIn 0.6s ease forwards;
        opacity: 0;
    }
    .death-overlay h1 {
        font-size: 4rem;
        color: #ff4444;
        font-weight: 800;
        margin: 0 0 20px;
        text-shadow: 0 2px 12px rgba(255,68,68,0.5);
        letter-spacing: 4px;
    }
    .death-scores {
        background: rgba(255,255,255,0.07);
        border-radius: 10px;
        padding: 16px 24px;
        min-width: 220px;
    }
    .death-scores h3 {
        margin: 0 0 10px;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.7;
    }
    .death-scores ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .death-scores li {
        display: flex;
        justify-content: space-between;
        padding: 5px 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        font-size: 1rem;
    }
    .btn-respawn {
        margin-top: 24px;
        font-size: 1.3rem;
        padding: 12px 40px;
        background: #4caf50;
        color: #fff;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 4px 16px rgba(76,175,80,0.4);
        transition: background 0.15s, transform 0.1s;
    }
    .btn-respawn:hover { background: #43a047; transform: translateY(-1px); }
    .respawn-hint {
        margin-top: 10px;
        font-size: 0.85rem;
        opacity: 0.5;
        letter-spacing: 0.5px;
    }
    .skin-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }
    .skin-tile {
        width: 24px; height: 24px;
        border: 2px solid transparent;
        border-radius: 50%;
        background: rgba(255,255,255,0.06);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        transition: border-color 0.15s;
    }
    .skin-tile:hover { border-color: rgba(255,255,255,0.3); }
    .skin-tile.skin-active { border-color: #4caf50; box-shadow: 0 0 6px rgba(76,175,80,0.4); }
    .skin-dot {
        width: 14px; height: 14px;
        border-radius: 50%;
        display: block;
    }
    .skin-preview-bar {
        margin-top: 6px;
        background: rgba(255,255,255,0.05);
        border-radius: 6px;
        padding: 4px 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    @@keyframes fadeIn { to { opacity: 1; } }

    /* Death menu */
    .death-menu {
        background: rgba(18, 18, 24, 0.92);
        backdrop-filter: blur(12px);
        border-radius: 12px;
        padding: 24px 28px;
        min-width: 260px;
        max-width: 340px;
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 10px;
        color: #e0e0e0;
        font-family: 'Segoe UI', system-ui, sans-serif;
        animation: fadeIn 0.3s ease forwards;
        opacity: 0;
    }
    .menu-item {
        padding: 8px 12px;
        border-radius: 6px;
        border: 2px solid transparent;
        transition: border-color 0.15s, background 0.15s;
    }
    .menu-item.menu-focused {
        border-color: #4caf50;
        background: rgba(76,175,80,0.12);
    }
    .menu-item.menu-btn {
        text-align: center;
        font-weight: 700;
        font-size: 1.05rem;
        cursor: pointer;
        padding: 10px 12px;
        background: rgba(255,255,255,0.07);
        border-radius: 6px;
        transition: background 0.15s, border-color 0.15s;
    }
    .menu-item.menu-btn:hover {
        background: rgba(255,255,255,0.14);
    }
    .menu-skin-selector {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 4px;
    }
    .menu-arrow {
        font-size: 1rem;
        opacity: 0.7;
        user-select: none;
    }
    .menu-arrow.dim { opacity: 0.2; }
    .menu-hint {
        font-size: 0.72rem;
        opacity: 0.4;
        text-align: center;
        margin-top: 8px;
        letter-spacing: 0.3px;
    }
</style>

@code
{
    // ==================== Constants ====================
    private const int SnakeWidth = 10;
    private const int WallHalfWidth = 25;
    private const int WallThickness = 50;
    private const double BitDistance = 20.0;
    private const double ExplosionDelay = 0.05;
    private const double ParticleLifespan = 0.6;
    private const int FrameDelayMs = 16;
    private const int GridSpacing = 50;
