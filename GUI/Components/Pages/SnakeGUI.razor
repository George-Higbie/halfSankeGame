    /// <summary>Handles the P1 death event: freezes camera and shows the death overlay.</summary>
    private void OnP1Died()
    {
        if (_showDeathScreen) return;
        _showDeathScreen = true;
        _status = "Game Over";

        var player = GameController.GetRenderSnapshot().PlayerSnake;
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _frozenCameraX = head.X;
            _frozenCameraY = head.Y;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>Handles the P2 death event: freezes camera and shows the death overlay.</summary>
    private void OnP2Died()
    {
        if (_p2ShowDeath) return;
        _p2ShowDeath = true;
        _p2Status = "Game Over";

        var player = _p2Game?.GetRenderSnapshot().PlayerSnake;
        if (player?.Body?.Count > 0)
        {
            var head = player.Body[^1];
            _p2FrozenCamX = head.X;
            _p2FrozenCamY = head.Y;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    // ==================== Render Loop ====================

    /// <summary>
    /// Main gameplay loop running at ~60 FPS. Each tick dequeues buffered moves,
    /// publishes the latest render state to the browser-side canvas renderer,
    /// updates preview canvases, and triggers periodic Blazor UI refreshes.
    /// </summary>
    private async Task RenderLoopAsync(CancellationToken ct)
    {
        int tick = 0;
        var frameSw = new Stopwatch();
        try
        {
            while (!ct.IsCancellationRequested)
            {
                frameSw.Restart();
                try
                {
                    var p1Snapshot = GameController.GetRenderSnapshot();
                    var p2Snapshot = _splitScreen && _p2Game != null ? _p2Game.GetRenderSnapshot() : null;

                    // P1 move — skip one frame after sending so the server
                    // processes each turn before receiving the next one.
                    if (_p1MoveCooldown > 0) _p1MoveCooldown--;
                    else
                    {
                        var move1 = DequeueMove(_p1MoveQueue, _p1MoveLock, GameController, ref _p1LastSentDir);
                        if (move1 != null) { _ = GameController.SendMoveAsync(move1); _p1MoveCooldown = MoveSendCooldownFrames; }
                    }

                    // P2 move
                    if (_splitScreen && _p2Game != null)
                    {
                        if (_p2MoveCooldown > 0) _p2MoveCooldown--;
                        else
                        {
                            var move2 = DequeueMove(_p2MoveQueue, _p2MoveLock, _p2Game, ref _p2LastSentDir);
                            if (move2 != null) { _ = _p2Game.SendMoveAsync(move2); _p2MoveCooldown = MoveSendCooldownFrames; }
                        }
                    }

                    await PublishBrowserRenderStateAsync(p1Snapshot, p2Snapshot);
                    await RefreshSkinPreviewsAsync();

                    // Mark players ready once the first player body arrives.
                    if (!_p1Ready && p1Snapshot.PlayerSnake?.Body?.Count > 0)
                        _p1Ready = true;
                    if (!_p2Ready && p2Snapshot?.PlayerSnake?.Body?.Count > 0)
                        _p2Ready = true;

                    if (++tick % 6 == 0) await InvokeAsync(StateHasChanged);
                }
                catch { /* skip frame */ }
                var drawMs = (int)frameSw.ElapsedMilliseconds;
                var remaining = FrameDelayMs - drawMs;
                if (remaining > 0)
                    await Task.Delay(remaining, ct);
            }
        }
        catch (TaskCanceledException) { }
    }

    // ==================== Browser Rendering ====================

    /// <summary>
    /// Publishes the latest world state and rendering options to the browser-side
    /// canvas renderer when the effective render state changes.
    /// </summary>
    private async Task PublishBrowserRenderStateAsync(GameController.RenderSnapshot p1Snapshot, GameController.RenderSnapshot? p2Snapshot)
    {
        if (_centerTargetSnakeId.HasValue && !p1Snapshot.Snakes.Any(s => s.Id == _centerTargetSnakeId.Value))
        {
            _centerTargetSnakeId = null;
        }

        var renderKeyBuilder = new HashCode();
        renderKeyBuilder.Add(_viewW);
        renderKeyBuilder.Add(_viewH);
        renderKeyBuilder.Add(_splitScreen);
        renderKeyBuilder.Add(_drawGrid);
        renderKeyBuilder.Add(_highQualityTextures);
        renderKeyBuilder.Add(_showScoreboard);
        renderKeyBuilder.Add(_showDeathScreen);
        renderKeyBuilder.Add(_p2ShowDeath);
        renderKeyBuilder.Add(_centerTargetSnakeId);
        renderKeyBuilder.Add(_p1SkinIndex);
        renderKeyBuilder.Add(_p2SkinIndex);
        renderKeyBuilder.Add(_frozenCameraX);
        renderKeyBuilder.Add(_frozenCameraY);
        renderKeyBuilder.Add(_p2FrozenCamX);
        renderKeyBuilder.Add(_p2FrozenCamY);
        renderKeyBuilder.Add(p1Snapshot.Version);
        renderKeyBuilder.Add(p2Snapshot?.Version ?? -1);
        int renderKey = renderKeyBuilder.ToHashCode();

        if (renderKey == _lastBrowserRenderStateKey)
        {
            return;
        }

        _lastBrowserRenderStateKey = renderKey;

        await JsRuntime.InvokeVoidAsync("setSnakeRenderState", new
        {
            viewW = _viewW,
            viewH = _viewH,
            splitScreen = _splitScreen,
            drawGrid = _drawGrid,
            highQualityTextures = _highQualityTextures,
            showScoreboard = _showScoreboard && GameController.PlayerId.HasValue,
            p1 = new
            {
                version = p1Snapshot.Version,
                playerId = p1Snapshot.PlayerId,
                worldSize = p1Snapshot.WorldSize ?? 2000,
                playerSkinIndex = _p1SkinIndex,
                showDeath = _showDeathScreen,
                frozenCameraX = _frozenCameraX,
                frozenCameraY = _frozenCameraY,
                centerTargetSnakeId = _centerTargetSnakeId,
                snakes = p1Snapshot.Snakes,
                walls = p1Snapshot.Walls,
                powerups = p1Snapshot.Powerups
            },
            p2 = _splitScreen && p2Snapshot != null
                ? new
                {
                    version = p2Snapshot.Version,
                    playerId = p2Snapshot.PlayerId,
                    worldSize = p2Snapshot.WorldSize ?? 2000,
                    playerSkinIndex = _p2SkinIndex,
                    showDeath = _p2ShowDeath,
                    frozenCameraX = _p2FrozenCamX,
                    frozenCameraY = _p2FrozenCamY,
                    centerTargetSnakeId = (int?)null,
                    snakes = p2Snapshot.Snakes,
                    walls = p2Snapshot.Walls,
                    powerups = p2Snapshot.Powerups
                }
                : null
        });
    }

    /// <summary>Refreshes the small skin-preview canvases when the selection changes.</summary>
    private async Task RefreshSkinPreviewsAsync()
    {
        if (_p1SkinIndex != _lastP1PreviewSkin)
        {
            _p1PreviewCtx ??= _p1PreviewRef != null ? await _p1PreviewRef.CreateCanvas2DAsync() : null;
            if (_p1PreviewCtx != null) { await _renderer.DrawSkinPreview(_p1PreviewCtx, SnakeSkin.AllSkins[_p1SkinIndex]); _lastP1PreviewSkin = _p1SkinIndex; }
        }

        // Invalidate P2 preview when split-screen is (re-)enabled because the BECanvas DOM
        // element is destroyed on toggle-off and recreated on toggle-on.
        if (_splitScreen && !_wasSplitScreen)
        {
            _p2PreviewCtx = null;
            _lastP2PreviewSkin = -1;
        }
        _wasSplitScreen = _splitScreen;

        if (_splitScreen && (_p2SkinIndex != _lastP2PreviewSkin || _p2PreviewCtx == null))
        {
            _p2PreviewCtx = _p2PreviewRef != null ? await _p2PreviewRef.CreateCanvas2DAsync() : null;
            if (_p2PreviewCtx != null) { await _renderer.DrawSkinPreview(_p2PreviewCtx, SnakeSkin.AllSkins[_p2SkinIndex]); _lastP2PreviewSkin = _p2SkinIndex; }
        }
    }
